---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="WOLTZ - Premium Streetwear" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@100;200;300;400;500&display=swap" rel="stylesheet">
    <title>{title}</title>
    <style is:inline>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      body {
        font-family: 'Inter', sans-serif;
        background-color: #0a0e17;
        color: #e2e8f0;
        overflow-x: hidden;
        cursor: none;
      }
      
      @media (hover: none) and (pointer: coarse) {
        body {
          cursor: auto;
        }
        #cursor {
          display: none !important;
        }
      }
      
      /* Cursor Personalizado - SEM mix-blend-mode */
      #cursor {
        position: fixed;
        top: 0;
        left: 0;
        width: 24px;
        height: 24px;
        border: 1.5px solid rgba(255, 255, 255, 0.5);
        border-radius: 50%;
        pointer-events: none;
        z-index: 99999;
        transform: translate(-50%, -50%);
        transition: width 0.3s ease, height 0.3s ease, border-color 0.3s ease, background-color 0.3s ease;
        will-change: transform, width, height;
      }
      
      #cursor.hovering {
        width: 60px;
        height: 60px;
        border-color: rgba(255, 255, 255, 0.8);
        background-color: rgba(255, 255, 255, 0.1);
      }
    </style>
  </head>
  <body>
    <div id="cursor"></div>
    <slot />
    <script is:inline src="/src/scripts/main.js"></script>
  </body>
</html>
