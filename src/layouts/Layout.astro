import { supabase } from '../lib/supabase';

// Busca configurações do tema
// Busca configurações do tema SEMPRE DO BANCO
let themeSettings: any = {};
try {
  const { data } = await supabase
  const { data, error } = await supabase
   .from('theme_settings')
    .select('*');
    .select('*')
    .order('updated_at', { ascending: false });
 
  if (error) throw error;
  
  const latestSettings = new Map();
 data?.forEach((row: any) => {
    themeSettings[row.key] = row.value;
    if (!latestSettings.has(row.key)) {
      latestSettings.set(row.key, row.value);
    }
 });
  
  themeSettings = Object.fromEntries(latestSettings);
  console.log('Layout loaded', Object.keys(themeSettings).length, 'theme settings');
} catch (e) {
 console.error('Failed to load theme settings:', e);
}
