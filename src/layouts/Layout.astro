---
import { supabase } from '../lib/supabase';

// 1. BUSCA AS CONFIGURAÇÕES DO BANCO DE DADOS
let themeSettings: any = {};
try {
  const { data, error } = await supabase
    .from('theme_settings')
    .select('*');
  
  if (!error && data) {
    data.forEach((row: any) => {
      // Extrai apenas o valor da string JSON "{ value: '#fff' }"
      try {
        const parsed = typeof row.value === 'string' ? JSON.parse(row.value) : row.value;
        themeSettings[row.key] = parsed.value || parsed;
      } catch (e) {
        themeSettings[row.key] = row.value;
      }
    });
  }
} catch (e) {
  console.error('Erro ao carregar tema:', e);
}

// 2. DEFINE OS VALORES PADRÃO E EXTRAI VARIÁVEIS POR SEÇÃO
const colors = {
  primary: themeSettings['colors.primary'] || '#ffffff',
  secondary: themeSettings['colors.secondary'] || '#6b7c93',
  background: themeSettings['colors.background'] || '#121214',
  surface: themeSettings['colors.surface'] || '#1a1a1e',
  text: themeSettings['colors.text'] || '#ffffff',
  textMuted: themeSettings['colors.text_muted'] || 'rgba(255,255,255,0.4)',
  accent: themeSettings['colors.accent'] || '#a8b5c6',
  success: themeSettings['colors.success'] || '#22c55e',
  error: themeSettings['colors.error'] || '#ef4444',
};

const header = {
  bg: themeSettings['header.bg_color'] || 'transparent',
  text: themeSettings['header.text_color'] || colors.text,
};

const hero = {
  title: themeSettings['hero.title_color'] || colors.text,
  subtitle: themeSettings['hero.subtitle_color'] || colors.textMuted,
  label: themeSettings['hero.label_color'] || colors.textMuted,
  price: themeSettings['hero.price_color'] || colors.text,
};

const collection = {
  bg: themeSettings['collection.bg_color'] || '#6b7c93',
  title: themeSettings['collection.title_color'] || colors.text,
  cardBg: themeSettings['collection.card_bg'] || '#5f7085',
  productName: themeSettings['collection.product_name_color'] || colors.text,
  productDesc: themeSettings['collection.product_desc_color'] || colors.textMuted,
  price: themeSettings['collection.price_color'] || colors.text,
  cartIcon: themeSettings['collection.cart_icon_color'] || colors.textMuted,
  filtersBtnBg: themeSettings['collection.filters_btn_bg'] || 'transparent',
  filtersBtnBorder: themeSettings['collection.filters_btn_border'] || 'rgba(255,255,255,0.3)',
  filtersBtnText: themeSettings['collection.filters_btn_text'] || colors.text,
};

const footer = {
  bg: themeSettings['footer.bg_color'] || '#6b7c93',
  text: themeSettings['footer.text_color'] || colors.text,
  muted: themeSettings['footer.muted_text'] || colors.textMuted,
  lettering: themeSettings['footer.lettering_color'] || 'rgba(255,255,255,0.07)',
  border: themeSettings['footer.border_color'] || 'rgba(255,255,255,0.2)',
  socialBg: themeSettings['footer.social_icon_bg'] || 'transparent',
  socialBorder: themeSettings['footer.social_icon_border'] || 'rgba(255,255,255,0.3)',
  socialColor: themeSettings['footer.social_icon_color'] || colors.text,
  newsletterBg: themeSettings['footer.newsletter_input_bg'] || 'transparent',
  newsletterBorder: themeSettings['footer.newsletter_input_border'] || 'rgba(255,255,255,0.4)',
};

const global = {
  cursor: themeSettings['global.cursor_color'] || colors.text,
  toastBg: themeSettings['global.toast_bg'] || 'rgba(0,0,0,0.8)',
  toastText: themeSettings['global.toast_text'] || colors.text,
};

const typography = {
  heading: themeSettings['typography.font_heading'] || 'Anton',
  body: themeSettings['typography.font_body'] || 'Inter, sans-serif',
  mono: themeSettings['typography.font_mono'] || 'VCR OSD Mono, monospace',
};

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@100;200;300;400;500&display=swap" rel="stylesheet" />
    
    <!-- INJEÇÃO DAS VARIÁVEIS CSS NO :ROOT -->
    <style is:global>
      :root {
        /* CORES GERAIS */
        --color-primary: {colors.primary};
        --color-secondary: {colors.secondary};
        --color-background: {colors.background};
        --color-surface: {colors.surface};
        --color-text: {colors.text};
        --color-text-muted: {colors.textMuted};
        --color-accent: {colors.accent};
        
        /* HEADER */
        --header-bg: {header.bg};
        --header-text: {header.text};
        
        /* HERO */
        --hero-title: {hero.title};
        --hero-subtitle: {hero.subtitle};
        --hero-label: {hero.label};
        --hero-price: {hero.price};
        
        /* COLLECTION */
        --collection-bg: {collection.bg};
        --collection-title: {collection.title};
        --collection-card-bg: {collection.cardBg};
        --collection-product-name: {collection.productName};
        --collection-product-desc: {collection.productDesc};
        --collection-price: {collection.price};
        --collection-cart-icon: {collection.cartIcon};
        --collection-filters-bg: {collection.filtersBtnBg};
        --collection-filters-border: {collection.filtersBtnBorder};
        --collection-filters-text: {collection.filtersBtnText};
        
        /* FOOTER */
        --footer-bg: {footer.bg};
        --footer-text: {footer.text};
        --footer-muted: {footer.muted};
        --footer-lettering: {footer.lettering};
        --footer-border: {footer.border};
        --footer-social-bg: {footer.socialBg};
        --footer-social-border: {footer.socialBorder};
        --footer-social-color: {footer.socialColor};
        --footer-newsletter-bg: {footer.newsletterBg};
        --footer-newsletter-border: {footer.newsletterBorder};
        
        /* GLOBAL UI */
        --cursor-color: {global.cursor};
        --toast-bg: {global.toastBg};
        --toast-text: {global.toastText};
        
        /* TYPOGRAPHY */
        --font-heading: '{typography.heading}';
        --font-body: '{typography.body}';
        --font-mono: '{typography.mono}';
      }
      
      /* RESET BÁSICO E APLICAÇÃO DAS FONTES */
      * { margin: 0; padding: 0; box-sizing: border-box; }
      
      body {
        font-family: var(--font-body);
        background-color: var(--color-background);
        color: var(--color-text);
        cursor: none !important;
      }
      
      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
        text-transform: uppercase;
        color: var(--color-text);
      }
      
      a { color: inherit; text-decoration: none; }
      
      button {
        cursor: none;
        border: none;
        background: none;
        font-family: inherit;
        color: inherit;
      }
      
      img { max-width: 100%; height: auto; display: block; }
      
      /* CURSOR CUSTOMIZADO */
      #custom-cursor {
        position: fixed;
        top: 0; left: 0;
        width: 24px; height: 24px;
        border: 1.5px solid var(--cursor-color);
        border-radius: 50%;
        pointer-events: none;
        z-index: 99999;
        transform: translate(-50%, -50%);
        transition: width 0.2s, height 0.2s, background-color 0.2s;
      }
      
      #custom-cursor.active {
        width: 50px; height: 50px;
        background-color: var(--cursor-color);
        opacity: 0.2;
      }
      
      /* TOAST NOTIFICATION */
      #cart-toast {
        position: fixed; bottom: 2rem; left: 50%;
        transform: translateX(-50%) translateY(100px);
        background: var(--toast-bg);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 1rem 2rem; border-radius: 12px;
        z-index: 10000; opacity: 0;
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        display: flex; align-items: center; gap: 0.75rem;
      }
      
      #cart-toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }
      #cart-toast-message { color: var(--toast-text); font-size: 0.875rem; }
      #cart-toast svg { width: 20px; height: 20px; color: var(--color-success); }
      
      @media (hover: none) and (pointer: coarse) {
        body { cursor: auto !important; }
        #custom-cursor { display: none !important; }
      }
    </style>
    
    <slot name="head" />
  </head>
  <body>
    <!-- ELEMENTOS GLOBAIS FIXOS -->
    <div id="custom-cursor"></div>
    
    <div id="cart-toast">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
      <span id="cart-toast-message">Added to cart</span>
    </div>
    
    <slot />
    
    <!-- SCRIPT DO CURSOR (GLOBAL) -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const cursor = document.getElementById('custom-cursor');
        if (!cursor) return;

        let mouseX = 0, mouseY = 0, cursorX = 0, cursorY = 0;

        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX; mouseY = e.clientY;
        });

        function animate() {
          cursorX += (mouseX - cursorX) * 0.2;
          cursorY += (mouseY - cursorY) * 0.2;
          cursor.style.left = cursorX + 'px';
          cursor.style.top = cursorY + 'px';
          requestAnimationFrame(animate);
        }
        animate();

        const addHover = (el) => {
          el.addEventListener('mouseenter', () => cursor.classList.add('active'));
          el.addEventListener('mouseleave', () => cursor.classList.remove('active'));
        };

        document.querySelectorAll('a, button, .clickable, input').forEach(addHover);
        
        new MutationObserver((mutations) => {
          mutations.forEach((m) => {
            m.addedNodes.forEach((node) => {
              if (node.nodeType === 1) {
                if (node.matches && node.matches('a, button, .clickable, input')) addHover(node);
                if (node.querySelectorAll) node.querySelectorAll('a, button, .clickable, input').forEach(addHover);
              }
            });
          });
        }).observe(document.body, { childList: true, subtree: true });
      });
    </script>
  </body>
</html>
