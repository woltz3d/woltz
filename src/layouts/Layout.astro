---
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  import.meta.env.SUPABASE_URL,
  import.meta.env.SUPABASE_ANON_KEY
);

// Carregar configurações do tema
let themeData: any = {};
try {
  const { data, error } = await supabase
    .from('theme_settings')
    .select('*');
  
  if (!error && data) {
    data.forEach((row: any) => {
      themeData[row.key] = row.value;
    });
  }
} catch (e) {
  console.error('Failed to load theme settings:', e);
}

// Valores padrão
const theme = {
  'header.bg_color': themeData['header.bg_color'] || '#121214',
  'header.text_color': themeData['header.text_color'] || '#ffffff',
  'hero.title_color': themeData['hero.title_color'] || '#ffffff',
  'hero.subtitle_color': themeData['hero.subtitle_color'] || 'rgba(255,255,255,0.6)',
  'hero.label_color': themeData['hero.label_color'] || 'rgba(255,255,255,0.4)',
  'hero.price_color': themeData['hero.price_color'] || '#ffffff',
  'hero.overlay_opacity': themeData['hero.overlay_opacity'] || '0.6',
  'collection.bg_color': themeData['collection.bg_color'] || '#6b7c93',
  'collection.title_color': themeData['collection.title_color'] || '#ffffff',
  'collection.card_bg': themeData['collection.card_bg'] || '#5f7085',
  'collection.product_name_color': themeData['collection.product_name_color'] || '#ffffff',
  'collection.product_desc_color': themeData['collection.product_desc_color'] || 'rgba(255,255,255,0.6)',
  'collection.price_color': themeData['collection.price_color'] || '#ffffff',
  'collection.cart_icon_color': themeData['collection.cart_icon_color'] || '#ffffff',
  'collection.filters_btn_bg': themeData['collection.filters_btn_bg'] || 'rgba(255,255,255,0.1)',
  'collection.filters_btn_border': themeData['collection.filters_btn_border'] || 'rgba(255,255,255,0.3)',
  'collection.filters_btn_text': themeData['collection.filters_btn_text'] || '#ffffff',
  'footer.bg_color': themeData['footer.bg_color'] || '#6b7c93',
  'footer.text_color': themeData['footer.text_color'] || '#ffffff',
  'footer.muted_text': themeData['footer.muted_text'] || 'rgba(255,255,255,0.4)',
  'footer.lettering_color': themeData['footer.lettering_color'] || 'rgba(255,255,255,0.07)',
  'footer.border_color': themeData['footer.border_color'] || 'rgba(255,255,255,0.2)',
  'global.cursor_color': themeData['global.cursor_color'] || '#ffffff',
  'typography.font_heading': themeData['typography.font_heading'] || 'Anton',
  'typography.font_body': themeData['typography.font_body'] || 'Inter, sans-serif',
  'typography.font_mono': themeData['typography.font_mono'] || 'VCR OSD Mono, monospace',
};

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="WOLTZ - Premium Digital Fashion" />
  <title>{title}</title>
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
  
  <style is:global>
    @import url('https://fonts.cdnfonts.com/css/vcr-osd-mono');
    
    :root {
      --header-bg: {theme['header.bg_color']};
      --header-text: {theme['header.text_color']};
      --hero-title: {theme['hero.title_color']};
      --hero-subtitle: {theme['hero.subtitle_color']};
      --hero-label: {theme['hero.label_color']};
      --hero-price: {theme['hero.price_color']};
      --hero-overlay: {theme['hero.overlay_opacity']};
      --collection-bg: {theme['collection.bg_color']};
      --collection-title: {theme['collection.title_color']};
      --collection-card-bg: {theme['collection.card_bg']};
      --collection-product-name: {theme['collection.product_name_color']};
      --collection-product-desc: {theme['collection.product_desc_color']};
      --collection-price: {theme['collection.price_color']};
      --collection-cart-icon: {theme['collection.cart_icon_color']};
      --collection-filters-btn-bg: {theme['collection.filters_btn_bg']};
      --collection-filters-btn-border: {theme['collection.filters_btn_border']};
      --collection-filters-btn-text: {theme['collection.filters_btn_text']};
      --footer-bg: {theme['footer.bg_color']};
      --footer-text: {theme['footer.text_color']};
      --footer-muted: {theme['footer.muted_text']};
      --footer-lettering: {theme['footer.lettering_color']};
      --footer-border: {theme['footer.border_color']};
      --cursor-color: {theme['global.cursor_color']};
      --font-heading: {theme['typography.font_heading']};
      --font-body: {theme['typography.font_body']};
      --font-mono: {theme['typography.font_mono']};
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: var(--font-body);
      background: #0a0a0c;
      color: #fff;
      overflow-x: hidden;
      cursor: none !important;
    }
    
    body * {
      cursor: none !important;
    }
    
    .font-vcr { font-family: var(--font-mono); }
    
    .tech-card-asymmetric {
      clip-path: polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px);
      background-color: var(--collection-card-bg) !important;
    }
    
    /* CURSOR CUSTOMIZADO - BOLA BRANCA */
    #custom-cursor {
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      width: 24px !important;
      height: 24px !important;
      border: 2px solid var(--cursor-color) !important;
      border-radius: 50% !important;
      pointer-events: none !important;
      z-index: 2147483647 !important;
      transform: translate(-50%, -50%) !important;
      transition: width 0.2s ease, height 0.2s ease, background-color 0.2s ease !important;
      opacity: 1 !important;
      visibility: visible !important;
      display: block !important;
      background-color: transparent !important;
    }
    
    #custom-cursor.active {
      width: 50px !important;
      height: 50px !important;
      border: 2px solid #ffffff !important;
      background-color: rgba(255, 255, 255, 0.15) !important;
    }
    
    @media (hover: none) and (pointer: coarse) {
      body { cursor: auto !important; }
      body * { cursor: auto !important; }
      #custom-cursor { display: none !important; }
    }
    
    /* Scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.2);
      border-radius: 3px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: rgba(255,255,255,0.4);
    }
  </style>
</head>
<body>
  <!-- CURSOR CUSTOMIZADO -->
  <div id="custom-cursor"></div>
  
  <slot />
  
  <!-- SCRIPT DO CURSOR -->
  <script is:inline>
    (function() {
      var cursor = document.getElementById('custom-cursor');
      if (!cursor) return;
      
      cursor.style.display = 'block';
      cursor.style.opacity = '1';
      cursor.style.visibility = 'visible';
      
      var mouseX = window.innerWidth / 2;
      var mouseY = window.innerHeight / 2;
      var cursorX = mouseX;
      var cursorY = mouseY;
      
      cursor.style.left = mouseX + 'px';
      cursor.style.top = mouseY + 'px';
      
      window.onmousemove = function(e) {
        mouseX = e.clientX;
        mouseY = e.clientY;
      };
      
      function moveCursor() {
        cursorX += (mouseX - cursorX) * 0.15;
        cursorY += (mouseY - cursorY) * 0.15;
        cursor.style.left = cursorX + 'px';
        cursor.style.top = cursorY + 'px';
        requestAnimationFrame(moveCursor);
      }
      moveCursor();
      
      function addHover(el) {
        if (!el) return;
        el.onmouseenter = function() { cursor.className = 'active'; };
        el.onmouseleave = function() { cursor.className = ''; };
      }
      
      var clickables = document.querySelectorAll('a, button, [onclick], .clickable, input, select, textarea');
      for (var i = 0; i < clickables.length; i++) {
        addHover(clickables[i]);
      }
      
      var observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(m) {
          m.addedNodes.forEach(function(node) {
            if (node.nodeType === 1) {
              if (node.matches && node.matches('a, button, [onclick], .clickable, input, select, textarea')) {
                addHover(node);
              }
              if (node.querySelectorAll) {
                var newClickables = node.querySelectorAll('a, button, [onclick], .clickable, input, select, textarea');
                for (var i = 0; i < newClickables.length; i++) {
                  addHover(newClickables[i]);
                }
              }
            }
          });
        });
      });
      
      observer.observe(document.body, { childList: true, subtree: true });
    })();
  </script>
</body>
</html>
