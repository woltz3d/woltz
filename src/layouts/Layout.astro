---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="WOLTZ - Premium Streetwear" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@100;200;300;400;500&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body class="bg-woltz-bg text-woltz-text cursor-none">
    <div id="cursor" class="fixed top-0 left-0 w-6 h-6 border border-white/50 rounded-full pointer-events-none z-[9999] mix-blend-difference hidden md:block"></div>
    <slot />
    <script is:inline src="/src/scripts/main.js"></script>
  </body>
</html>
