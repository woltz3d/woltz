---
import { supabase } from '../lib/supabase';

// Busca configurações do tema
let themeSettings: any = {};
try {
  const { data } = await supabase
    .from('theme_settings')
    .select('*');
  
  data?.forEach((row: any) => {
    themeSettings[row.key] = row.value;
  });
} catch (e) {
  console.error('Failed to load theme settings:', e);
}

// Extrai valores com fallbacks
const colors = {
  primary: themeSettings['colors.primary']?.value || '#ffffff',
  secondary: themeSettings['colors.secondary']?.value || '#6b7c93',
  background: themeSettings['colors.background']?.value || '#121214',
  backgroundAlt: themeSettings['colors.background_alt']?.value || '#111113',
  text: themeSettings['colors.text']?.value || '#ffffff',
  textMuted: themeSettings['colors.text_muted']?.value || 'rgba(255,255,255,0.4)',
  accent: themeSettings['colors.accent']?.value || '#a8b5c6',
  success: themeSettings['colors.success']?.value || '#22c55e',
  error: themeSettings['colors.error']?.value || '#ef4444',
  warning: themeSettings['colors.warning']?.value || '#f59e0b',
};

const typography = {
  fontHeading: themeSettings['typography.font_heading']?.value || 'Anton',
  fontBody: themeSettings['typography.font_body']?.value || 'Inter, sans-serif',
  fontMono: themeSettings['typography.font_mono']?.value || 'VCR OSD Mono, monospace',
  sizeH1: themeSettings['typography.size_h1']?.value || 'clamp(3rem, 8vw, 6rem)',
  sizeH2: themeSettings['typography.size_h2']?.value || 'clamp(2rem, 5vw, 4rem)',
  sizeBody: themeSettings['typography.size_body']?.value || '1rem',
  weightHeading: themeSettings['typography.weight_heading']?.value || '400',
  weightBody: themeSettings['typography.weight_body']?.value || '400',
  trackingHeading: themeSettings['typography.tracking_heading']?.value || '-0.02em',
  trackingBody: themeSettings['typography.tracking_body']?.value || '0.05em',
};

const layout = {
  containerMaxWidth: themeSettings['layout.container_max_width']?.value || '1536px',
  sectionPadding: themeSettings['layout.section_padding']?.value || '3rem',
  gridGap: themeSettings['layout.grid_gap']?.value || '1.5rem',
  borderRadius: themeSettings['layout.border_radius']?.value || '0px',
  heroHeight: themeSettings['layout.hero_height']?.value || '100vh',
};

const branding = {
  siteName: themeSettings['branding.site_name']?.value || 'WOLTZ',
  logoUrl: themeSettings['branding.logo_url']?.value || '',
  faviconUrl: themeSettings['branding.favicon_url']?.value || '',
  tagline: themeSettings['branding.tagline']?.value || '',
};

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={branding.tagline} />
    <title>{title}</title>
    
    {branding.faviconUrl && <link rel="icon" href={branding.faviconUrl} />}
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    
    <!-- CSS Variables do Tema -->
    <style is:global>
      :root {
        /* Colors */
        --color-primary: {colors.primary};
        --color-secondary: {colors.secondary};
        --color-background: {colors.background};
        --color-background-alt: {colors.backgroundAlt};
        --color-text: {colors.text};
        --color-text-muted: {colors.textMuted};
        --color-accent: {colors.accent};
        --color-success: {colors.success};
        --color-error: {colors.error};
        --color-warning: {colors.warning};
        
        /* Typography */
        --font-heading: {typography.fontHeading};
        --font-body: {typography.fontBody};
        --font-mono: {typography.fontMono};
        --size-h1: {typography.sizeH1};
        --size-h2: {typography.sizeH2};
        --size-body: {typography.sizeBody};
        --weight-heading: {typography.weightHeading};
        --weight-body: {typography.weightBody};
        --tracking-heading: {typography.trackingHeading};
        --tracking-body: {typography.trackingBody};
        
        /* Layout */
        --container-max-width: {layout.containerMaxWidth};
        --section-padding: {layout.sectionPadding};
        --grid-gap: {layout.gridGap};
        --border-radius: {layout.borderRadius};
        --hero-height: {layout.heroHeight};
      }
      
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      body {
        font-family: var(--font-body);
        font-size: var(--size-body);
        font-weight: var(--weight-body);
        letter-spacing: var(--tracking-body);
        color: var(--color-text);
        background-color: var(--color-background);
        line-height: 1.6;
        cursor: none; /* Esconde o cursor padrão */
      }
      
      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
        font-weight: var(--weight-heading);
        letter-spacing: var(--tracking-heading);
        line-height: 1.1;
        text-transform: uppercase;
      }
      
      h1 { font-size: var(--size-h1); }
      h2 { font-size: var(--size-h2); }
      
      a {
        color: inherit;
        text-decoration: none;
        transition: opacity 0.3s ease;
      }
      
      a:hover {
        opacity: 0.7;
      }
      
      button {
        cursor: none; /* Botões também sem cursor padrão */
        border: none;
        background: none;
        font-family: inherit;
      }
      
      img {
        max-width: 100%;
        height: auto;
        display: block;
      }
      
      .container {
        max-width: var(--container-max-width);
        margin: 0 auto;
        padding: 0 var(--section-padding);
      }
      
      /* CURSOR CUSTOMIZADO */
      .custom-cursor {
        position: fixed;
        width: 20px;
        height: 20px;
        border: 2px solid var(--color-primary);
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
        transition: transform 0.15s ease, width 0.2s ease, height 0.2s ease, border-color 0.2s ease;
        transform: translate(-50%, -50%);
        mix-blend-mode: difference;
      }
      
      .custom-cursor.hover {
        width: 50px;
        height: 50px;
        border-color: var(--color-accent);
        background: rgba(255, 255, 255, 0.1);
      }
      
      /* Esconde cursor customizado em dispositivos touch */
      @media (hover: none) {
        body {
          cursor: auto;
        }
        button {
          cursor: pointer;
        }
        .custom-cursor {
          display: none;
        }
      }
    </style>
    
    <slot name="head" />
  </head>
  <body>
    <!-- Cursor Customizado -->
    <div class="custom-cursor" id="custom-cursor"></div>
    
    <slot />
    
    <!-- Script do Cursor -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const cursor = document.getElementById('custom-cursor');
        if (!cursor) return;
        
        let mouseX = 0;
        let mouseY = 0;
        let cursorX = 0;
        let cursorY = 0;
        
        // Atualiza posição do mouse
        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
        });
        
        // Animação suave do cursor
        function animateCursor() {
          const dx = mouseX - cursorX;
          const dy = mouseY - cursorY;
          
          cursorX += dx * 0.15;
          cursorY += dy * 0.15;
          
          cursor.style.left = cursorX + 'px';
          cursor.style.top = cursorY + 'px';
          
          requestAnimationFrame(animateCursor);
        }
        
        animateCursor();
        
        // Adiciona efeito hover em botões e links
        const interactiveElements = document.querySelectorAll('a, button, .clickable, input, textarea');
        
        interactiveElements.forEach(el => {
          el.addEventListener('mouseenter', () => {
            cursor.classList.add('hover');
          });
          
          el.addEventListener('mouseleave', () => {
            cursor.classList.remove('hover');
          });
        });
        
        // Observa mudanças no DOM (para elementos adicionados dinamicamente)
        const observer = new MutationObserver((mutations) => {
          mutations.forEach((mutation) => {
            mutation.addedNodes.forEach((node) => {
              if (node.nodeType === 1) {
                const newInteractive = node.querySelectorAll('a, button, .clickable, input, textarea');
                newInteractive.forEach(el => {
                  el.addEventListener('mouseenter', () => {
                    cursor.classList.add('hover');
                  });
                  
                  el.addEventListener('mouseleave', () => {
                    cursor.classList.remove('hover');
                  });
                });
              }
            });
          });
        });
        
        observer.observe(document.body, {
          childList: true,
          subtree: true
        });
      });
    </script>
  </body>
</html>
