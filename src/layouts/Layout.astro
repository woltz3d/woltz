---
import { supabase } from '../lib/supabase';

// Busca configurações do tema do banco
let themeSettings: any = {};
try {
  const { data, error } = await supabase
    .from('theme_settings')
    .select('*')
    .order('updated_at', { ascending: false });
  
  if (error) throw error;
  
  const latestSettings = new Map();
  data?.forEach((row: any) => {
    if (!latestSettings.has(row.key)) {
      latestSettings.set(row.key, row.value);
    }
  });
  
  themeSettings = Object.fromEntries(latestSettings);
} catch (e) {
  console.error('Failed to load theme settings:', e);
}

// Extrai valores com fallbacks
const colors = {
  primary: themeSettings['colors.primary']?.value || '#ffffff',
  secondary: themeSettings['colors.secondary']?.value || '#6b7c93',
  background: themeSettings['colors.background']?.value || '#121214',
  backgroundAlt: themeSettings['colors.background_alt']?.value || '#111113',
  text: themeSettings['colors.text']?.value || '#ffffff',
  textMuted: themeSettings['colors.text_muted']?.value || 'rgba(255,255,255,0.4)',
  accent: themeSettings['colors.accent']?.value || '#a8b5c6',
  success: themeSettings['colors.success']?.value || '#22c55e',
  error: themeSettings['colors.error']?.value || '#ef4444',
  warning: themeSettings['colors.warning']?.value || '#f59e0b',
};

const typography = {
  fontHeading: themeSettings['typography.font_heading']?.value || 'Anton',
  fontBody: themeSettings['typography.font_body']?.value || 'Inter, sans-serif',
  fontMono: themeSettings['typography.font_mono']?.value || 'VCR OSD Mono, monospace',
};

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@100;200;300;400;500&display=swap" rel="stylesheet" />
    
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      body {
        background-color: var(--color-background, #121214);
        color: var(--color-text, #ffffff);
        font-family: var(--font-body, 'Inter', sans-serif);
        cursor: none !important;
        overflow-x: hidden;
      }
      
      body * {
        cursor: none !important;
      }
      
      #custom-cursor {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        width: 24px !important;
        height: 24px !important;
        border: 2px solid var(--color-primary, #ffffff) !important;
        border-radius: 50% !important;
        pointer-events: none !important;
        z-index: 9999999 !important;
        transform: translate(-50%, -50%) !important;
        transition: width 0.2s ease, height 0.2s ease, background-color 0.2s ease !important;
        opacity: 1 !important;
        visibility: visible !important;
        display: block !important;
        background-color: transparent !important;
      }

      #custom-cursor.active {
        width: 50px !important;
        height: 50px !important;
        background-color: var(--color-primary, #ffffff) !important;
        opacity: 0.3 !important;
      }
      
      @media (hover: none) and (pointer: coarse) {
        body { cursor: auto !important; }
        body * { cursor: auto !important; }
        #custom-cursor { display: none !important; }
      }
    </style>
    
    <slot name="head" />
  </head>
  <body>
    <!-- CURSOR CUSTOMIZADO -->
    <div id="custom-cursor"></div>
    
    <slot />
    
    <!-- SCRIPT DO CURSOR -->
    <script>
      (function() {
        'use strict';
        
        const cursor = document.getElementById('custom-cursor');
        if (!cursor) {
          console.error('❌ Cursor element not found!');
          return;
        }
        
        console.log('✅ Cursor element found, initializing...');
        
        // Garante visibilidade inicial
        cursor.style.display = 'block';
        cursor.style.opacity = '1';
        cursor.style.visibility = 'visible';
        cursor.style.left = '0px';
        cursor.style.top = '0px';
        
        let mouseX = 0;
        let mouseY = 0;
        let cursorX = 0;
        let cursorY = 0;
        
        // Atualiza posição do mouse
        document.addEventListener('mousemove', function(e) {
          mouseX = e.clientX;
          mouseY = e.clientY;
        }, { passive: true });
        
        // Animação suave
        function animate() {
          cursorX += (mouseX - cursorX) * 0.15;
          cursorY += (mouseY - cursorY) * 0.15;
          cursor.style.left = cursorX + 'px';
          cursor.style.top = cursorY + 'px';
          requestAnimationFrame(animate);
        }
        animate();
        
        // Efeito hover em elementos clicáveis
        function addHoverEffect(el) {
          if (!el) return;
          el.addEventListener('mouseenter', function() {
            cursor.classList.add('active');
          });
          el.addEventListener('mouseleave', function() {
            cursor.classList.remove('active');
          });
        }
        
        // Aplica em todos elementos clicáveis
        const clickables = document.querySelectorAll('a, button, [onclick], .clickable, input, select, textarea');
        clickables.forEach(addHoverEffect);
        
        // Observer para elementos dinâmicos
        const observer = new MutationObserver(function(mutations) {
          mutations.forEach(function(mutation) {
            mutation.addedNodes.forEach(function(node) {
              if (node.nodeType === 1) {
                if (node.matches && node.matches('a, button, [onclick], .clickable, input, select, textarea')) {
                  addHoverEffect(node);
                }
                if (node.querySelectorAll) {
                  const newClickables = node.querySelectorAll('a, button, [onclick], .clickable, input, select, textarea');
                  newClickables.forEach(addHoverEffect);
                }
              }
            });
          });
        });
        
        observer.observe(document.body, {
          childList: true,
          subtree: true
        });
        
        console.log('✅ Custom cursor initialized successfully!');
      })();
    </script>
  </body>
</html>
