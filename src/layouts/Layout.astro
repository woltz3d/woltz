---
import { supabase } from '../lib/supabase';

// Busca configurações do tema
let themeSettings: any = {};
try {
  const { data, error } = await supabase
    .from('theme_settings')
    .select('*')
    .order('updated_at', { ascending: false });
  
  if (error) throw error;
  
  const latestSettings = new Map();
  data?.forEach((row: any) => {
    if (!latestSettings.has(row.key)) {
      latestSettings.set(row.key, row.value);
    }
  });
  
  themeSettings = Object.fromEntries(latestSettings);
} catch (e) {
  console.error('Failed to load theme settings:', e);
}

// Extrai valores com fallbacks
const colors = {
  primary: themeSettings['colors.primary']?.value || '#ffffff',
  secondary: themeSettings['colors.secondary']?.value || '#6b7c93',
  background: themeSettings['colors.background']?.value || '#121214',
  backgroundAlt: themeSettings['colors.background_alt']?.value || '#111113',
  text: themeSettings['colors.text']?.value || '#ffffff',
  textMuted: themeSettings['colors.text_muted']?.value || 'rgba(255,255,255,0.4)',
  accent: themeSettings['colors.accent']?.value || '#a8b5c6',
  success: themeSettings['colors.success']?.value || '#22c55e',
  error: themeSettings['colors.error']?.value || '#ef4444',
  warning: themeSettings['colors.warning']?.value || '#f59e0b',
};

const typography = {
  fontHeading: themeSettings['typography.font_heading']?.value || 'Anton',
  fontBody: themeSettings['typography.font_body']?.value || 'Inter, sans-serif',
  fontMono: themeSettings['typography.font_mono']?.value || 'VCR OSD Mono, monospace',
};

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@100;200;300;400;500&display=swap" rel="stylesheet" />
    
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      body {
        background-color: var(--color-background, #121214);
        color: var(--color-text, #ffffff);
        font-family: var(--font-body, 'Inter', sans-serif);
        cursor: none !important;
        overflow-x: hidden;
      }
      
      body * {
        cursor: none !important;
      }
      
      /* CURSOR NORMAL - Bolinha pequena com borda */
      #custom-cursor {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        width: 24px !important;
        height: 24px !important;
        border: 2px solid var(--color-primary, #ffffff) !important;
        border-radius: 50% !important;
        pointer-events: none !important;
        z-index: 99999999 !important;
        transform: translate(-50%, -50%) !important;
        transition: all 0.2s ease !important;
        background-color: transparent !important;
        opacity: 1 !important;
        visibility: visible !important;
        display: block !important;
      }
      
      /* CURSOR ATIVO (HOVER) - Círculo maior com borda branca e fundo transparente */
      #custom-cursor.active {
        width: 50px !important;
        height: 50px !important;
        border: 2px solid #ffffff !important;
        background-color: rgba(255, 255, 255, 0.15) !important;
        opacity: 1 !important;
      }
      
      @media (hover: none) and (pointer: coarse) {
        body, body * { cursor: auto !important; }
        #custom-cursor { display: none !important; }
      }
    </style>
    
    <slot name="head" />
  </head>
  <body>
    <div id="custom-cursor"></div>
    
    <slot />
    
    <script>
      (function() {
        'use strict';
        
        var cursor = document.getElementById('custom-cursor');
        if (!cursor) return;
        
        cursor.style.display = 'block';
        cursor.style.opacity = '1';
        cursor.style.visibility = 'visible';
        cursor.style.left = '0px';
        cursor.style.top = '0px';
        
        var posX = 0;
        var posY = 0;
        var cursorX = 0;
        var cursorY = 0;
        
        window.onmousemove = function(e) {
          posX = e.clientX;
          posY = e.clientY;
        };
        
        function moveCursor() {
          cursorX += (posX - cursorX) * 0.15;
          cursorY += (posY - cursorY) * 0.15;
          cursor.style.left = cursorX + 'px';
          cursor.style.top = cursorY + 'px';
          requestAnimationFrame(moveCursor);
        }
        moveCursor();
        
        function addHover(el) {
          if (!el) return;
          el.onmouseenter = function() { cursor.className = 'active'; };
          el.onmouseleave = function() { cursor.className = ''; };
        }
        
        var clickables = document.querySelectorAll('a, button, [onclick], .clickable, input, select, textarea');
        for (var i = 0; i < clickables.length; i++) {
          addHover(clickables[i]);
        }
        
        var observer = new MutationObserver(function(mutations) {
          mutations.forEach(function(m) {
            m.addedNodes.forEach(function(node) {
              if (node.nodeType === 1) {
                if (node.matches && node.matches('a, button, [onclick], .clickable, input, select, textarea')) {
                  addHover(node);
                }
                if (node.querySelectorAll) {
                  var newClickables = node.querySelectorAll('a, button, [onclick], .clickable, input, select, textarea');
                  for (var i = 0; i < newClickables.length; i++) {
                    addHover(newClickables[i]);
                  }
                }
              }
            });
          });
        });
        
        observer.observe(document.body, { childList: true, subtree: true });
      })();
    </script>
  </body>
</html>
