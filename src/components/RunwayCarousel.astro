---
const models = [
  { id: 1, name: "GLACIER WHITE PUFFER", price: 1299.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+1" },
  { id: 2, name: "POLAR GLOSS JACKET", price: 899.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+2" },
  { id: 3, name: "STEALTH BLACK HEAVY", price: 1199.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+3" },
  { id: 4, name: "ICEFIELD BLUE TECH", price: 999.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+4" },
  { id: 5, name: "POLAR WHITE SHELL", price: 1499.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+5" },
];

// 7 cópias para margem extra de segurança (35 itens totais)
const infiniteModels = [...models, ...models, ...models, ...models, ...models, ...models, ...models];
---

<section class="relative w-full h-[85vh] overflow-hidden flex items-center bg-woltz-bg select-none">
  
  <!-- Container que se move -->
  <div id="carousel-track" class="flex items-center absolute will-change-transform cursor-grab active:cursor-grabbing">
    
    {infiniteModels.map((model, index) => (
      <div 
        class="carousel-item relative w-[350px] h-[550px] flex-shrink-0 flex items-center justify-center transition-all duration-500 ease-out"
        data-name={model.name}
        data-price={model.price}
        data-img={model.img}
        data-index={index}
      >
        <!-- Imagem PNG sem borda -->
        <img src={model.img} alt={model.name} class="w-full h-full object-contain drop-shadow-2xl pointer-events-none" />
        
        <!-- Nome abaixo da imagem -->
        <div class="absolute -bottom-10 left-0 w-full text-center opacity-0 transition-opacity duration-300 item-label">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-woltz-muted">{model.name}</p>
        </div>
      </div>
    ))}

  </div>

  <!-- Painel Lateral (Fica fixo à direita) -->
  <div id="product-panel" class="absolute right-8 top-1/2 -translate-y-1/2 w-[320px] bg-woltz-surface/60 backdrop-blur-xl border border-woltz-border/40 rounded-xl p-6 hidden lg:block z-50 shadow-2xl">
    <div id="panel-content" class="flex flex-col gap-6">
      <div class="aspect-[3/4] w-full bg-woltz-bg/40 rounded-lg overflow-hidden flex items-center justify-center border border-woltz-border/30">
         <img id="panel-img" src={models[0].img} alt="Produto" class="w-full h-full object-contain p-6 transition-all duration-300" />
      </div>
      
      <div class="text-center space-y-2">
        <h2 id="panel-name" class="text-lg font-bold uppercase tracking-wide text-woltz-accent leading-tight min-h-[3rem] flex items-center justify-center">{models[0].name}</h2>
        <p id="panel-price" class="text-2xl font-masque text-woltz-text">${models[0].price.toFixed(2)}</p>
      </div>

      <button class="w-full bg-white text-black py-4 uppercase text-[10px] font-bold tracking-[0.25em] hover:bg-gray-200 transition-colors rounded-sm mt-2">
        Adicionar ao Carrinho
      </button>
    </div>
  </div>

</section>

<script>
  import { gsap } from 'gsap';
  import { Draggable } from 'gsap/Draggable';
  import { InertiaPlugin } from 'gsap/InertiaPlugin';

  gsap.registerPlugin(Draggable, InertiaPlugin);

  const track = document.getElementById('carousel-track');
  const items = document.querySelectorAll('.carousel-item');
  const panelImg = document.getElementById('panel-img');
  const panelName = document.getElementById('panel-name');
  const panelPrice = document.getElementById('panel-price');
  
  // Configurações Matemáticas
  const itemWidth = 350; 
  const gap = 40; 
  const totalItemWidth = itemWidth + gap; 
  
  // Temos 7 sets de 5 modelos = 35 itens totais
  // Centro seguro: índice 17 (meio exato da lista de 35)
  const SAFE_CENTER = 17; 

  // PONTO DE FOCO: 82% da tela (bem colado no painel)
  const focusPoint = window.innerWidth * 0.82; 

  // ESTADO GLOBAL: Apenas UM índice pode ser o ativo por vez
  let activeIndex = -1; 

  function updateVisuals() {
    const trackX = gsap.getProperty(track, "x");
    
    // Calcula qual índice físico está alinhado com o foco
    // Usamos Math.floor + 0.5 para criar cortes precisos entre os itens
    // Isso elimina a "zona cinzenta" onde dois itens ficam grandes
    const rawIndex = (focusPoint - trackX - (itemWidth / 2)) / totalItemWidth;
    const newActiveIndex = Math.floor(rawIndex + 0.5);
    
    // Só executa a lógica pesada se o índice ativo MUDOU
    if (newActiveIndex !== activeIndex) {
        activeIndex = newActiveIndex;
        updatePanelData(activeIndex);
    }

    items.forEach((item, index) => {
      // Lógica binária absoluta: OU é o ativo, OU não é.
      const isTheActiveOne = (index === activeIndex);
      
      const scale = isTheActiveOne ? 1.1 : 0.65;
      const blur = isTheActiveOne ? 0 : 5;
      const opacity = isTheActiveOne ? 1 : 0.4;
      const zIndex = isTheActiveOne ? 10 : 0;
      const labelOpacity = isTheActiveOne ? 1 : 0;

      gsap.to(item, {
        scale: scale,
        filter: `blur(${blur}px)`,
        opacity: opacity,
        zIndex: zIndex,
        duration: 0.4, // Um pouco mais rápido para resposta imediata
        ease: "power2.out",
        overwrite: true
      });

      gsap.to(item.querySelector('.item-label'), { opacity: labelOpacity, duration: 0.3 });
    });
  }

  function updatePanelData(physicalIndex) {
    // Proteção contra índices fora da lista (caso raro de bug extremo)
    if (physicalIndex < 0 || physicalIndex >= items.length) return;

    const item = items[physicalIndex];
    const name = item.getAttribute('data-name');
    const price = item.getAttribute('data-price');
    const img = item.getAttribute('data-img');

    // Só atualiza se o texto for diferente (evita flicker)
    if (panelName.innerText !== name) {
      gsap.to([panelImg, panelName, panelPrice], { 
        opacity: 0, y: 10, duration: 0.2, 
        onComplete: () => {
          panelImg.src = img;
          panelName.innerText = name;
          panelPrice.innerText = `$${parseFloat(price).toFixed(2)}`;
          gsap.to([panelImg, panelName, panelPrice], { opacity: 1, y: 0, duration: 0.3 });
        }
      });
    }
  }

  // Reposiciona silenciosamente para o centro seguro após parar
  function resetToCenter() {
    const currentX = gsap.getProperty(track, "x");
    const rawIndex = (focusPoint - currentX - (itemWidth / 2)) / totalItemWidth;
    const closestPhysicalIndex = Math.round(rawIndex);
    
    // Move o item atual para o SAFE_CENTER (17)
    const diff = SAFE_CENTER - closestPhysicalIndex;
    
    if (diff !== 0) {
      const newX = currentX + (diff * totalItemWidth);
      gsap.set(track, { x: newX });
      // Atualiza o activeIndex para refletir a nova posição física
      activeIndex = SAFE_CENTER;
    }
    
    updateVisuals();
  }

  // Drag SEM LIMITES RÍGIDOS, mas com snap preciso
  Draggable.create(track, {
    type: "x",
    inertia: true,
    bounds: { minX: -Infinity, maxX: Infinity }, // Liberdade total durante o arrasto
    snap: function(endValue) {
      // Snap sempre alinha perfeitamente com um item
      return Math.round(endValue / totalItemWidth) * totalItemWidth;
    },
    onRelease: function() {
      // Após soltar, espera a inércia acabar e recentraliza
      setTimeout(() => {
        resetToCenter();
      }, 600); // Tempo suficiente para a inércia parar completamente
    },
    onDrag: updateVisuals,
    onThrowUpdate: updateVisuals
  });

  function initPosition() {
      // Começa com Model 5 no SAFE_CENTER (índice 17)
      // Model 5 é índice real 4. 
      // Para ter Model 5 no índice 17, precisamos ajustar o offset inicial.
      // Mas como temos 7 cópias, o padrão se repete a cada 5 índices.
      // Índice 17 % 5 = 2 (Model 3). 
      // Queremos índice que % 5 == 4 (Model 5) e esteja perto de 17.
      // Índices possíveis: 14, 19, 24...
      // 19 é o mais próximo de 17 e tem boa margem.
      // Vamos usar 19 como ponto inicial visual, mas o resetToCenter vai mover para 17.
      // ESPERA! Se movemos para 17 (Model 3), o usuário vai ver o modelo mudar sozinho!
      // SOLUÇÃO DEFINITIVA: Mudar o SAFE_CENTER para 19 (que é Model 5).
      // 19 tem 19 itens à esquerda e 15 à direita. Margem perfeita.
      
      const TRUE_SAFE_CENTER = 19; // Model 5 no 4º set
      
      const initialX = focusPoint - (TRUE_SAFE_CENTER * totalItemWidth) - (itemWidth / 2);
      gsap.set(track, { x: initialX });
      
      // Define o estado inicial
      activeIndex = TRUE_SAFE_CENTER;
      updatePanelData(TRUE_SAFE_CENTER);
      updateVisuals();
      
      // Sobrescreve a função resetToCenter para usar TRUE_SAFE_CENTER
      // Isso garante que após qualquer arrasto, ele volte para o índice 19 (Model 5)
      // mantendo o mesmo modelo visível, apenas reposicionando a lista física.
      window.resetToCenterOverride = function() {
          const currentX = gsap.getProperty(track, "x");
          const rawIndex = (focusPoint - currentX - (itemWidth / 2)) / totalItemWidth;
          const closestPhysicalIndex = Math.round(rawIndex);
          
          // Calcula qual modelo real (0-4) está ativo agora
          const currentRealModel = ((closestPhysicalIndex % 5) + 5) % 5;
          
          // Encontra o índice físico no TRUE_SAFE_CENTER que corresponde a esse modelo
          // TRUE_SAFE_CENTER (19) é Model 5 (índice real 4).
          // Se o usuário parou no Model 2 (índice real 1), precisamos encontrar 
          // o índice físico perto de 19 que também seja Model 2.
          // Modelo 2 nos índices: 1, 6, 11, 16, 21, 26, 31...
          // O mais próximo de 19 é 16 ou 21.
          // Vamos escolher o mais próximo matematicamente.
          
          let targetPhysicalIndex = TRUE_SAFE_CENTER;
          const diffReal = currentRealModel - 4; // Diferença entre modelo atual e Model 5
          
          // Ajusta o targetPhysicalIndex para manter o mesmo modelo real
          targetPhysicalIndex = TRUE_SAFE_CENTER + diffReal;
          
          // Garante que não saímos dos limites extremos da lista de 35 itens
          if (targetPhysicalIndex < 5) targetPhysicalIndex += 5;
          if (targetPhysicalIndex > 29) targetPhysicalIndex -= 5;
          
          const diff = targetPhysicalIndex - closestPhysicalIndex;
          if (diff !== 0) {
            const newX = currentX + (diff * totalItemWidth);
            gsap.set(track, { x: newX });
            activeIndex = targetPhysicalIndex;
          }
          updateVisuals();
      };
      
      // Atualiza o onRelease para usar a nova função
      Draggable.get(track).vars.onRelease = function() {
          setTimeout(() => {
              window.resetToCenterOverride();
          }, 600);
      };
  }

  setTimeout(initPosition, 100);
  window.addEventListener('resize', updateVisuals);

</script>
