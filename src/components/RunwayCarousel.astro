---
// Lista original de modelos
const models = [
  { id: 1, name: "GLACIER WHITE PUFFER", price: 1299.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+1" },
  { id: 2, name: "POLAR GLOSS JACKET", price: 899.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+2" },
  { id: 3, name: "STEALTH BLACK HEAVY", price: 1199.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+3" },
  { id: 4, name: "ICEFIELD BLUE TECH", price: 999.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+4" },
  { id: 5, name: "POLAR WHITE SHELL", price: 1499.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+5" },
];

// Duplicamos a lista 3 vezes para criar um loop infinito visualmente perfeito
const infiniteModels = [...models, ...models, ...models];
---

<section class="relative w-full h-[80vh] overflow-hidden flex items-center justify-center bg-woltz-bg select-none">
  
  <!-- Este container vai se mover -->
  <div id="carousel-track" class="flex items-center gap-12 absolute will-change-transform cursor-grab active:cursor-grabbing">
    
    {infiniteModels.map((model) => (
      <div 
        class="carousel-item relative w-[320px] h-[500px] flex-shrink-0 transition-all duration-300"
        data-name={model.name}
        data-price={model.price}
        data-img={model.img}
      >
        <!-- Imagem sem borda, fundo transparente -->
        <img src={model.img} alt={model.name} class="w-full h-full object-contain drop-shadow-2xl pointer-events-none" />
        
        <!-- Texto pequeno embaixo da imagem (opcional, pode remover se quiser só a imagem) -->
        <div class="absolute -bottom-8 left-0 w-full text-center opacity-0 transition-opacity duration-300 item-label">
          <p class="text-xs font-bold uppercase tracking-widest text-woltz-muted">{model.name}</p>
        </div>
      </div>
    ))}

  </div>

  <!-- Painel Lateral Dinâmico -->
  <div id="product-panel" class="absolute right-8 top-1/2 -translate-y-1/2 w-[300px] bg-woltz-surface/50 backdrop-blur-xl border border-woltz-border/50 rounded-2xl p-6 hidden lg:block z-30 shadow-2xl">
    <div id="panel-content" class="flex flex-col gap-5">
      <div class="aspect-[3/4] w-full bg-woltz-bg/50 rounded-lg overflow-hidden flex items-center justify-center">
         <img id="panel-img" src={models[0].img} alt="Produto" class="w-full h-full object-contain p-4" />
      </div>
      
      <div class="text-center">
        <h2 id="panel-name" class="text-lg font-bold uppercase tracking-wide text-woltz-accent leading-tight">{models[0].name}</h2>
        <p id="panel-price" class="text-2xl font-masque mt-2 text-woltz-text">${models[0].price.toFixed(2)}</p>
      </div>

      <button class="w-full bg-white text-black py-4 uppercase text-xs font-bold tracking-[0.2em] hover:bg-gray-200 transition-colors rounded-sm">
        Adicionar ao Carrinho
      </button>
    </div>
  </div>

</section>

<script>
  import { gsap } from 'gsap';
  import { Draggable } from 'gsap/Draggable';
  import { InertiaPlugin } from 'gsap/InertiaPlugin';

  gsap.registerPlugin(Draggable, InertiaPlugin);

  const track = document.getElementById('carousel-track');
  const items = document.querySelectorAll('.carousel-item');
  const panelImg = document.getElementById('panel-img');
  const panelName = document.getElementById('panel-name');
  const panelPrice = document.getElementById('panel-price');
  
  // Configurações do Loop
  const totalItems = items.length;
  const singleSetLength = totalItems / 3; // Temos 3 sets duplicados
  const itemWidth = 320 + 48; // Largura do card (320) + gap (48)
  const setWidth = singleSetLength * itemWidth; 

  // Centraliza o track no meio do segundo set (para ter espaço para os dois lados)
  let startX = -(setWidth); 
  gsap.set(track, { x: startX });

  function updateVisuals() {
    const centerX = window.innerWidth / 2;
    
    items.forEach((item) => {
      const rect = item.getBoundingClientRect();
      const itemCenterX = rect.left + rect.width / 2;
      const distance = Math.abs(centerX - itemCenterX);
      
      // Lógica de Profundidade
      const scale = Math.max(0.5, 1 - (distance / (window.innerWidth * 0.5)));
      const blur = Math.min(8, distance / 60);
      const opacity = Math.max(0.2, 1 - (distance / (window.innerWidth * 0.4)));
      const labelOpacity = scale > 0.8 ? 1 : 0; // Mostra nome só quando está grande

      gsap.to(item, {
        scale: scale,
        filter: `blur(${blur}px)`,
        opacity: opacity,
        zIndex: Math.round(scale * 100),
        duration: 0.5,
        ease: "power2.out"
      });

      gsap.to(item.querySelector('.item-label'), { opacity: labelOpacity, duration: 0.3 });
    });

    // Atualizar Painel Lateral
    let closestItem = null;
    let minDistance = Infinity;

    items.forEach((item) => {
      const rect = item.getBoundingClientRect();
      const itemCenterX = rect.left + rect.width / 2;
      const distance = Math.abs(centerX - itemCenterX);
      if (distance < minDistance) { minDistance = distance; closestItem = item; }
    });

    if (closestItem) {
      const name = closestItem.getAttribute('data-name');
      const price = closestItem.getAttribute('data-price');
      const img = closestItem.getAttribute('data-img');

      if (panelName.innerText !== name) {
        gsap.to([panelImg, panelName, panelPrice], { 
          opacity: 0, y: 10, duration: 0.2, 
          onComplete: () => {
            panelImg.src = img;
            panelName.innerText = name;
            panelPrice.innerText = `$${parseFloat(price).toFixed(2)}`;
            gsap.to([panelImg, panelName, panelPrice], { opacity: 1, y: 0, duration: 0.3 });
          }
        });
      }
    }
  }

  // Criar o Drag Infinito
  Draggable.create(track, {
    type: "x",
    inertia: true,
    bounds: { minX: -Infinity, maxX: Infinity },
    onDrag: function() {
      updateVisuals();
      checkLoop();
    },
    onThrowUpdate: function() {
      updateVisuals();
      checkLoop();
    }
  });

  // Lógica Mágica do Loop Infinito
  function checkLoop() {
    const currentX = gsap.getProperty(track, "x");
    
    // Se foi muito para a esquerda, pulamos para o meio
    if (currentX < -(setWidth * 1.5)) {
      gsap.set(track, { x: currentX + setWidth });
    } 
    // Se foi muito para a direita, pulamos para o meio
    else if (currentX > -(setWidth * 0.5)) {
      gsap.set(track, { x: currentX - setWidth });
    }
  }

  // Inicialização
  setTimeout(() => {
    updateVisuals();
  }, 100);

</script>
