---
const models = [
  { id: 1, name: "GLACIER WHITE PUFFER", price: 1299.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+1" },
  { id: 2, name: "POLAR GLOSS JACKET", price: 899.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+2" },
  { id: 3, name: "STEALTH BLACK HEAVY", price: 1199.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+3" },
  { id: 4, name: "ICEFIELD BLUE TECH", price: 999.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+4" },
  { id: 5, name: "POLAR WHITE SHELL", price: 1499.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+5" },
];

// Usamos 5 cópias para ter margem de segurança, mas o usuário só verá 3 por vez
const infiniteModels = [...models, ...models, ...models, ...models, ...models];
---

<section class="relative w-full h-[85vh] overflow-hidden flex items-center bg-woltz-bg select-none">
  
  <!-- Container que se move -->
  <div id="carousel-track" class="flex items-center absolute will-change-transform cursor-grab active:cursor-grabbing">
    
    {infiniteModels.map((model, index) => (
      <div 
        class="carousel-item relative w-[350px] h-[550px] flex-shrink-0 flex items-center justify-center transition-all duration-500 ease-out"
        data-name={model.name}
        data-price={model.price}
        data-img={model.img}
        data-index={index}
      >
        <!-- Imagem PNG sem borda -->
        <img src={model.img} alt={model.name} class="w-full h-full object-contain drop-shadow-2xl pointer-events-none" />
        
        <!-- Nome abaixo da imagem -->
        <div class="absolute -bottom-10 left-0 w-full text-center opacity-0 transition-opacity duration-300 item-label">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-woltz-muted">{model.name}</p>
        </div>
      </div>
    ))}

  </div>

  <!-- Painel Lateral (Fica fixo à direita) -->
  <div id="product-panel" class="absolute right-8 top-1/2 -translate-y-1/2 w-[320px] bg-woltz-surface/60 backdrop-blur-xl border border-woltz-border/40 rounded-xl p-6 hidden lg:block z-50 shadow-2xl">
    <div id="panel-content" class="flex flex-col gap-6">
      <div class="aspect-[3/4] w-full bg-woltz-bg/40 rounded-lg overflow-hidden flex items-center justify-center border border-woltz-border/30">
         <img id="panel-img" src={models[0].img} alt="Produto" class="w-full h-full object-contain p-6 transition-all duration-300" />
      </div>
      
      <div class="text-center space-y-2">
        <h2 id="panel-name" class="text-lg font-bold uppercase tracking-wide text-woltz-accent leading-tight min-h-[3rem] flex items-center justify-center">{models[0].name}</h2>
        <p id="panel-price" class="text-2xl font-masque text-woltz-text">${models[0].price.toFixed(2)}</p>
      </div>

      <button class="w-full bg-white text-black py-4 uppercase text-[10px] font-bold tracking-[0.25em] hover:bg-gray-200 transition-colors rounded-sm mt-2">
        Adicionar ao Carrinho
      </button>
    </div>
  </div>

</section>

<script>
  import { gsap } from 'gsap';
  import { Draggable } from 'gsap/Draggable';
  import { InertiaPlugin } from 'gsap/InertiaPlugin';

  gsap.registerPlugin(Draggable, InertiaPlugin);

  const track = document.getElementById('carousel-track');
  const items = document.querySelectorAll('.carousel-item');
  const panelImg = document.getElementById('panel-img');
  const panelName = document.getElementById('panel-name');
  const panelPrice = document.getElementById('panel-price');
  
  // Configurações Matemáticas
  const itemWidth = 350; 
  const gap = 40; 
  const totalItemWidth = itemWidth + gap; 
  
  // Temos 5 sets de 5 modelos = 25 itens totais
  const singleSetCount = 5; 
  const setWidth = singleSetCount * totalItemWidth; 

  // PONTO DE FOCO: 82% da tela (bem colado no painel)
  const focusPoint = window.innerWidth * 0.82; 

  let currentIndex = 10; // Começamos no meio da lista (índice 10, que é o Model 5 do 3º set)

  function updateVisuals() {
    const trackX = gsap.getProperty(track, "x");
    
    items.forEach((item) => {
      const index = parseInt(item.dataset.index);
      const itemBaseX = index * totalItemWidth; 
      const itemScreenX = trackX + itemBaseX + (itemWidth / 2);
      const distance = Math.abs(focusPoint - itemScreenX);
      
      const isActive = distance < (totalItemWidth / 2);
      
      // Escala e efeitos baseados na distância do foco
      const scale = isActive ? 1.1 : Math.max(0.6, 1 - (distance / (window.innerWidth * 0.8)));
      const blur = isActive ? 0 : Math.min(6, distance / 80);
      const opacity = isActive ? 1 : Math.max(0.3, 1 - (distance / (window.innerWidth * 0.6)));
      
      // Z-INDEX CONTROLADO: Ativo=10, Inativo=0. Painel tem z-50.
      const zIndex = isActive ? 10 : 0;
      
      const labelOpacity = isActive ? 1 : 0;

      gsap.to(item, {
        scale: scale,
        filter: `blur(${blur}px)`,
        opacity: opacity,
        zIndex: zIndex,
        duration: 0.6,
        ease: "power3.out",
        overwrite: true
      });

      gsap.to(item.querySelector('.item-label'), { opacity: labelOpacity, duration: 0.4 });

      // Atualiza painel lateral apenas se for o item ativo
      if (isActive) {
        const name = item.getAttribute('data-name');
        const price = item.getAttribute('data-price');
        const img = item.getAttribute('data-img');

        if (panelName.innerText !== name) {
          gsap.to([panelImg, panelName, panelPrice], { 
            opacity: 0, y: 10, duration: 0.2, 
            onComplete: () => {
              panelImg.src = img;
              panelName.innerText = name;
              panelPrice.innerText = `$${parseFloat(price).toFixed(2)}`;
              gsap.to([panelImg, panelName, panelPrice], { opacity: 1, y: 0, duration: 0.3 });
            }
          });
        }
      }
    });
  }

  // Função para reposicionar o carrossel silenciosamente após o arrasto
  function resetToCenter() {
    // Calcula qual item está mais próximo do foco agora
    const currentX = gsap.getProperty(track, "x");
    const relativePos = -(currentX - focusPoint + (itemWidth/2));
    const newItemIndex = Math.round(relativePos / totalItemWidth);
    
    // Atualiza o índice lógico global
    currentIndex = newItemIndex;
    
    // Queremos manter o currentIndex sempre perto do meio da lista física (índice 10 a 15)
    // Se o usuário foi muito para a direita (índice > 15), movemos a lista para trás
    // Se foi muito para a esquerda (índice < 10), movemos a lista para frente
    
    let offset = 0;
    if (currentIndex > 15) {
      offset = -5; // Move 5 itens para trás
    } else if (currentIndex < 10) {
      offset = 5; // Move 5 itens para frente
    }
    
    if (offset !== 0) {
      currentIndex += offset;
      // Reposiciona o track instantaneamente para refletir o novo índice no centro
      const newX = focusPoint - (currentIndex * totalItemWidth) - (itemWidth / 2);
      gsap.set(track, { x: newX });
    }
    
    updateVisuals();
  }

  // Inicialização do Drag com LIMITES E SENSIBILIDADE
  Draggable.create(track, {
    type: "x",
    inertia: true,
    // LIMITES FÍSICOS: Permite arrastar apenas 2 itens para cada lado do centro
    // Isso impede o usuário de "se perder" ou arrastar rápido demais
    bounds: { 
      minX: focusPoint - ((currentIndex + 2) * totalItemWidth) - (itemWidth / 2),
      maxX: focusPoint - ((currentIndex - 2) * totalItemWidth) - (itemWidth / 2)
    },
    snap: function(endValue) {
      // Snap sempre para o múltiplo mais próximo de totalItemWidth
      return Math.round(endValue / totalItemWidth) * totalItemWidth;
    },
    onRelease: function() {
      // Após soltar e a inércia terminar, recentraliza a lista silenciosamente
      setTimeout(() => {
        resetToCenter();
        // Atualiza os limites para o novo centro
        this.applyBounds({ 
          minX: focusPoint - ((currentIndex + 2) * totalItemWidth) - (itemWidth / 2),
          maxX: focusPoint - ((currentIndex - 2) * totalItemWidth) - (itemWidth / 2)
        });
      }, 500); // Espera 500ms para a inércia acabar
    },
    onDrag: updateVisuals,
    onThrowUpdate: updateVisuals
  });

  function initPosition() {
      // Posição inicial baseada no currentIndex (10)
      const initialX = focusPoint - (currentIndex * totalItemWidth) - (itemWidth / 2);
      gsap.set(track, { x: initialX });
      updateVisuals();
  }

  // Inicia
  setTimeout(initPosition, 100);
  
  // Recalcula foco se redimensionar tela
  window.addEventListener('resize', () => {
      // Atualiza variável global de foco e limites
      // Nota: Em produção real, precisaríamos recalcular tudo, mas para simplificar:
      updateVisuals();
  });

</script>
