---
// src/pages/index.astro
// Nenhuma importação necessária aqui!
---

<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WOLTZ - Runway Collection</title>
    <!-- Tailwind CSS via CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      /* Estilos customizados para scrollbar e seleções */
      .custom-scrollbar::-webkit-scrollbar { width: 4px; }
      .custom-scrollbar::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.02); }
      .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 4px; }
      body { overflow: hidden; background-color: #050505; }
    </style>
  </head>
  <body class="text-white font-sans antialiased selection:bg-white selection:text-black">
    
    <!-- Header Minimalista -->
    <header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-8 py-6 pointer-events-none mix-blend-difference">
      <div class="text-xl font-bold tracking-widest uppercase">Woltz</div>
      <nav class="hidden md:flex gap-8 text-xs font-medium tracking-widest uppercase opacity-70">
        <span>Coleção</span>
        <span>Sobre Nós</span>
        <span>Contato</span>
      </nav>
      <div class="text-xs font-bold tracking-widest uppercase flex items-center gap-2">
        Carrinho <span id="header-cart-count" class="bg-white text-black rounded-full w-5 h-5 flex items-center justify-center text-[10px]">0</span>
      </div>
    </header>

    <!-- ÁREA PRINCIPAL: RUNWAY 3D -->
    <main class="relative w-full h-screen flex items-center justify-center overflow-hidden perspective-container">
      
      <!-- Container que se move horizontalmente -->
      <div id="runway-track" class="absolute flex items-center will-change-transform cursor-grab active:cursor-grabbing touch-pan-x">
        <!-- Itens gerados via JS -->
      </div>

      <!-- Overlay de gradiente lateral para suavizar a entrada/saída -->
      <div class="absolute inset-0 bg-gradient-to-r from-[#050505] via-transparent to-[#050505] pointer-events-none z-10"></div>
      
      <!-- Indicador de Look (Estilo Marc Jacobs) -->
      <div class="absolute bottom-12 left-8 z-20 pointer-events-none">
        <h2 class="text-4xl font-light uppercase tracking-tighter mb-1">Spring Summer 2026</h2>
        <p id="look-indicator" class="text-sm font-mono opacity-50 uppercase tracking-widest">Look 01</p>
      </div>

    </main>

    <!-- ÁREA LATERAL: SHOPPING PANEL -->
    <aside class="fixed right-0 top-0 h-full w-full sm:w-[380px] bg-[#0a0a0a]/95 backdrop-blur-xl border-l border-white/5 z-30 flex flex-col shadow-2xl transform transition-transform duration-500 translate-x-0">
      
      <!-- Conteúdo do Produto em Destaque -->
      <div class="p-8 border-b border-white/5 flex-shrink-0">
        <h2 class="text-[10px] font-bold tracking-[0.3em] text-gray-500 uppercase mb-6">Em Destaque</h2>
        
        <div id="active-product-display" class="group">
          <div class="aspect-[3/4] w-full bg-white/[0.02] rounded-sm overflow-hidden mb-6 relative border border-white/5">
             <img id="panel-main-img" src="" class="w-full h-full object-contain p-6 transition-transform duration-700 group-hover:scale-105" />
          </div>
          
          <div class="space-y-3 min-h-[80px]">
            <h3 id="panel-name" class="text-lg font-bold uppercase tracking-wide leading-tight transition-all duration-300">Carregando...</h3>
            <p id="panel-price" class="text-xl font-light text-gray-300 font-mono transition-all duration-300">$0.00</p>
          </div>

          <button 
            onclick="addToCart()"
            class="w-full mt-8 bg-white text-black py-4 uppercase text-[9px] font-bold tracking-[0.25em] hover:bg-gray-200 active:scale-[0.98] transition-all rounded-sm"
          >
            Adicionar à Seleção
          </button>
        </div>
      </div>

      <!-- Minha Seleção (Carrinho Persistente) -->
      <div class="flex-1 overflow-y-auto p-8 custom-scrollbar flex flex-col">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-[10px] font-bold tracking-[0.3em] text-gray-500 uppercase">Minha Seleção</h2>
          <span id="cart-count" class="text-[10px] bg-white/10 px-2 py-1 rounded-sm font-mono">0 itens</span>
        </div>

        <div id="cart-list" class="space-y-4 flex-1">
          <div id="empty-cart-msg" class="flex flex-col items-center justify-center h-32 text-gray-600 text-xs italic border border-dashed border-white/10 rounded-sm">
            <span>Sua seleção está vazia.</span>
            <span class="mt-1 opacity-50">Navegue pela passarela.</span>
          </div>
        </div>
      </div>

      <!-- Footer do Painel -->
      <div class="p-8 border-t border-white/5 bg-[#080808]">
        <div class="flex justify-between items-end mb-6">
          <span class="text-[10px] text-gray-500 uppercase tracking-widest">Total Estimado</span>
          <span id="cart-total" class="text-lg font-mono">$0.00</span>
        </div>
        <button class="w-full border border-white/20 text-white py-3 uppercase text-[9px] font-bold tracking-[0.25em] hover:bg-white hover:text-black transition-colors rounded-sm">
          Finalizar Compra
        </button>
      </div>
    </aside>

    <!-- Script Principal com Lógica de Runway 3D -->
    <script type="module">
      // Carregamento sequencial do GSAP via CDN para evitar erros de build
      const loadScript = (src) => new Promise((resolve) => {
        const s = document.createElement('script');
        s.src = src;
        s.onload = resolve;
        document.head.appendChild(s);
      });

      async function initApp() {
        await loadScript('https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js');
        await loadScript('https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/Draggable.min.js');
        await loadScript('https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/InertiaPlugin.min.js');

        const { gsap } = window;
        const { Draggable } = window;
        const { InertiaPlugin } = window;
        gsap.registerPlugin(Draggable, InertiaPlugin);

        // --- DADOS ---
        const products = [
          { id: 1, name: "GLACIER WHITE PUFFER", price: 1299.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+1" },
          { id: 2, name: "POLAR GLOSS JACKET", price: 899.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+2" },
          { id: 3, name: "STEALTH BLACK HEAVY", price: 1199.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+3" },
          { id: 4, name: "ICEFIELD BLUE TECH", price: 999.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+4" },
          { id: 5, name: "POLAR WHITE SHELL", price: 1499.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+5" },
        ];

        // Triplicar para loop infinito suave
        const runwayItems = [...products, ...products, ...products];
        const singleSetCount = products.length;
        
        // Elementos DOM
        const track = document.getElementById('runway-track');
        const panelImg = document.getElementById('panel-main-img');
        const panelName = document.getElementById('panel-name');
        const panelPrice = document.getElementById('panel-price');
        const lookIndicator = document.getElementById('look-indicator');
        const cartList = document.getElementById('cart-list');
        const cartCount = document.getElementById('cart-count');
        const headerCartCount = document.getElementById('header-cart-count');
        const cartTotal = document.getElementById('cart-total');
        const emptyMsg = document.getElementById('empty-cart-msg');

        // Gerar HTML dos itens
        runwayItems.forEach((product) => {
          const div = document.createElement('div');
          // Tamanho base do item
          div.className = 'runway-item relative w-[300px] md:w-[400px] h-[500px] md:h-[600px] flex-shrink-0 flex items-center justify-center mx-[40px]';
          div.dataset.id = product.id;
          div.dataset.name = product.name;
          div.dataset.price = product.price;
          div.dataset.img = product.img;
          
          const img = document.createElement('img');
          img.src = product.img;
          img.alt = product.name;
          img.className = 'w-full h-full object-contain drop-shadow-2xl pointer-events-none select-none';
          
          div.appendChild(img);
          track.appendChild(div);
        });

        const items = document.querySelectorAll('.runway-item');
        
        // --- ESTADO GLOBAL ---
        let cart = [];
        let isUpdating = false;
        let lastX = 0;
        
        // Configurações Matemáticas
        let itemWidth = window.innerWidth < 768 ? 300 : 400;
        const gap = 80; // Espaço maior entre itens para dar ar de editorial
        let totalItemWidth = itemWidth + gap;
        let setWidth = singleSetCount * totalItemWidth;

        // --- LÓGICA DO RUNWAY 3D (EFEITO MARC JACOBS) ---
        function updateVisuals() {
          if (isUpdating) return;
          isUpdating = true;

          const centerX = window.innerWidth / 2;
          const trackX = gsap.getProperty(track, "x");
          
          let closestItem = null;
          let smallestDistance = Infinity;

          // 1. Encontrar o item mais próximo do centro exato da tela
          items.forEach((item) => {
            const index = Array.from(items).indexOf(item);
            // Posição base do item + deslocamento do track + metade da largura do item
            const itemScreenX = trackX + (index * totalItemWidth) + (itemWidth / 2);
            const distance = Math.abs(centerX - itemScreenX);
            
            if (distance < smallestDistance) {
              smallestDistance = distance;
              closestItem = item;
            }
          });

          // 2. Aplicar transformações 3D baseadas na distância do centro
          items.forEach((item) => {
            const index = Array.from(items).indexOf(item);
            const itemScreenX = trackX + (index * totalItemWidth) + (itemWidth / 2);
            const distance = Math.abs(centerX - itemScreenX);
            const isActive = item === closestItem;
            
            // Atualizar indicador de Look
            if (isActive) {
              const originalIndex = (index % singleSetCount) + 1;
              lookIndicator.innerText = `Look ${String(originalIndex).padStart(2, '0')}`;
            }

            // Curva de profundidade: Quanto mais longe do centro, menor e mais desfocado
            // Usamos uma curva exponencial para simular perspectiva 3D
            const depthFactor = Math.max(0, 1 - (distance / (window.innerWidth * 0.6)));
            const scale = 0.4 + (0.8 * depthFactor); // Mínimo 0.4, Máximo 1.2
            const blur = (1 - depthFactor) * 12; // Máximo 12px de blur
            const opacity = 0.2 + (0.8 * depthFactor);
            const zIndex = Math.floor(depthFactor * 100);

            gsap.to(item, {
              scale: scale,
              filter: `blur(${blur}px)`,
              opacity: opacity,
              zIndex: zIndex,
              duration: 0.5,
              ease: "power2.out",
              overwrite: true
            });
          });

          // 3. Atualizar Painel Lateral se o Hero mudou
          if (closestItem) {
            const name = closestItem.dataset.name;
            const price = closestItem.dataset.price;
            const img = closestItem.dataset.img;

            if (panelName.innerText !== name) {
              animatePanelChange(img, name, price);
            }
          }

          requestAnimationFrame(() => { isUpdating = false; });
        }

        function animatePanelChange(img, name, price) {
          const elements = [panelImg, panelName, panelPrice];
          gsap.to(elements, {
            opacity: 0, y: 10, duration: 0.2,
            onComplete: () => {
              panelImg.src = img;
              panelName.innerText = name;
              panelPrice.innerText = `$${parseFloat(price).toFixed(2)}`;
              gsap.to(elements, { opacity: 1, y: 0, duration: 0.3, stagger: 0.05 });
            }
          });
        }

        // --- DRAGGABLE & LOOP INFINITO ---
        Draggable.create(track, {
          type: "x",
          inertia: true,
          bounds: { minX: -Infinity, maxX: Infinity },
          snap: (endValue) => Math.round(endValue / totalItemWidth) * totalItemWidth,
          
          onPress: function() { lastX = this.x; },
          
          onDrag: function() {
            // Permite arrastar livremente (esquerda/direita) para navegação natural
            lastX = this.x;
            checkLoop();
            updateVisuals();
          },
          
          onThrowUpdate: function() {
            lastX = this.x;
            checkLoop();
            updateVisuals();
          },
          
          onRelease: function() {
            updateVisuals();
          }
        });

        function checkLoop() {
          let currentX = gsap.getProperty(track, "x");
          
          // Se foi muito para a esquerda, teleporta para direita
          if (currentX <= -setWidth * 1.5) {
            currentX += setWidth;
            gsap.set(track, { x: currentX });
          }
          // Se foi muito para a direita, teleporta para esquerda
          else if (currentX >= -setWidth * 0.5) {
            currentX -= setWidth;
            gsap.set(track, { x: currentX });
          }
        }

        // Ticker para manter o loop fluido
        gsap.ticker.add(checkLoop);

        // Inicialização
        setTimeout(() => {
          const centerX = window.innerWidth / 2;
          // Começa no meio do array triplicado
          const startItemIndex = singleSetCount + 2; 
          const initialX = centerX - (startItemIndex * totalItemWidth) - (itemWidth / 2);
          const snappedX = Math.round(initialX / totalItemWidth) * totalItemWidth;
          
          gsap.set(track, { x: snappedX });
          lastX = snappedX;
          updateVisuals();
        }, 100);

        window.addEventListener('resize', () => {
          itemWidth = window.innerWidth < 768 ? 300 : 400;
          totalItemWidth = itemWidth + gap;
          setWidth = singleSetCount * totalItemWidth;
          updateVisuals();
        });

        // --- LÓGICA DO CARRINHO ---
        window.addToCart = function() {
          const name = panelName.innerText;
          const price = parseFloat(panelPrice.innerText.replace('$', ''));
          const img = panelImg.src;
          const existingItem = cart.find(item => item.name === name);
          
          if (existingItem) { existingItem.qty++; } 
          else { cart.push({ id: Date.now(), name, price, img, qty: 1 }); }
          
          renderCart();
          
          // Feedback visual no botão
          const btn = document.querySelector('button[onclick="addToCart()"]');
          if(btn) {
            const originalText = btn.innerText;
            btn.innerText = "ADICIONADO!";
            btn.classList.add('bg-green-500', 'text-white');
            setTimeout(() => { btn.innerText = originalText; btn.classList.remove('bg-green-500', 'text-white'); }, 1000);
          }
        };

        window.removeFromCart = function(id) {
          cart = cart.filter(item => item.id !== id);
          renderCart();
        };

        function renderCart() {
          cartList.innerHTML = '';
          const totalQty = cart.reduce((acc, item) => acc + item.qty, 0);
          
          // Atualiza contadores
          cartCount.innerText = `${totalQty} item${totalQty !== 1 ? 's' : ''}`;
          headerCartCount.innerText = totalQty;

          if (cart.length === 0) {
            cartList.appendChild(emptyMsg);
            emptyMsg.style.display = 'flex';
            cartTotal.innerText = '$0.00';
            return;
          }
          
          emptyMsg.style.display = 'none';
          let total = 0;

          cart.forEach(item => {
            total += item.price * item.qty;
            const itemEl = document.createElement('div');
            itemEl.className = 'flex items-center gap-4 bg-white/[0.02] p-3 rounded-sm border border-white/5 group hover:border-white/10 transition-colors';
            itemEl.innerHTML = `
              <img src="${item.img}" class="w-14 h-14 object-contain bg-white/[0.02] rounded-sm" />
              <div class="flex-1 min-w-0">
                <h4 class="text-[10px] font-bold uppercase truncate text-gray-200 mb-1">${item.name}</h4>
                <p class="text-[10px] text-gray-500 font-mono">$${item.price.toFixed(2)} <span class="opacity-50">x</span> ${item.qty}</p>
              </div>
              <button onclick="removeFromCart(${item.id})" class="text-gray-600 hover:text-red-400 transition-colors p-2 opacity-0 group-hover:opacity-100">✕</button>
            `;
            cartList.appendChild(itemEl);
          });

          cartTotal.innerText = `$${total.toFixed(2)}`;
        }
      }

      // Inicia o app
      initApp();
    </script>
  </body>
</html>
