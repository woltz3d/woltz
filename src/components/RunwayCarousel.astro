---
const models = [
  { id: 1, name: "GLACIER WHITE PUFFER", price: 1299.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+1" },
  { id: 2, name: "POLAR GLOSS JACKET", price: 899.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+2" },
  { id: 3, name: "STEALTH BLACK HEAVY", price: 1199.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+3" },
  { id: 4, name: "ICEFIELD BLUE TECH", price: 999.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+4" },
  { id: 5, name: "POLAR WHITE SHELL", price: 1499.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+5" },
];
---

<section class="relative w-full h-[85vh] overflow-hidden flex items-center bg-woltz-bg select-none">
  
  <!-- Container que se move -->
  <div id="carousel-track" class="flex items-center absolute will-change-transform cursor-grab active:cursor-grabbing">
    <!-- Os itens serão injetados via JavaScript para controle total do loop -->
  </div>

  <!-- Painel Lateral (Fica fixo à direita) -->
  <div id="product-panel" class="absolute right-8 top-1/2 -translate-y-1/2 w-[320px] bg-woltz-surface/60 backdrop-blur-xl border border-woltz-border/40 rounded-xl p-6 hidden lg:block z-30 shadow-2xl">
    <div id="panel-content" class="flex flex-col gap-6">
      <div class="aspect-[3/4] w-full bg-woltz-bg/40 rounded-lg overflow-hidden flex items-center justify-center border border-woltz-border/30">
         <img id="panel-img" src="" alt="Produto" class="w-full h-full object-contain p-6 transition-all duration-300" />
      </div>
      
      <div class="text-center space-y-2">
        <h2 id="panel-name" class="text-lg font-bold uppercase tracking-wide text-woltz-accent leading-tight min-h-[3rem] flex items-center justify-center"></h2>
        <p id="panel-price" class="text-2xl font-masque text-woltz-text"></p>
      </div>

      <button class="w-full bg-white text-black py-4 uppercase text-[10px] font-bold tracking-[0.25em] hover:bg-gray-200 transition-colors rounded-sm mt-2">
        Adicionar ao Carrinho
      </button>
    </div>
  </div>

</section>

<script>
  import { gsap } from 'gsap';
  import { Draggable } from 'gsap/Draggable';
  import { InertiaPlugin } from 'gsap/InertiaPlugin';

  gsap.registerPlugin(Draggable, InertiaPlugin);

  const models = [
    { id: 1, name: "GLACIER WHITE PUFFER", price: 1299.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+1" },
    { id: 2, name: "POLAR GLOSS JACKET", price: 899.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+2" },
    { id: 3, name: "STEALTH BLACK HEAVY", price: 1199.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+3" },
    { id: 4, name: "ICEFIELD BLUE TECH", price: 999.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+4" },
    { id: 5, name: "POLAR WHITE SHELL", price: 1499.99, img: "https://placehold.co/400x600/transparent/e1e1e6?text=Model+5" },
  ];

  const track = document.getElementById('carousel-track');
  const panelImg = document.getElementById('panel-img');
  const panelName = document.getElementById('panel-name');
  const panelPrice = document.getElementById('panel-price');
  
  // Configurações
  const itemWidth = 350; 
  const gap = 40; 
  const totalItemWidth = itemWidth + gap; 
  
  // Estado do Loop
  let currentIndex = 0; // Índice lógico (pode ser negativo ou maior que length)
  let isDragging = false;

  // Função para criar o HTML de um item
  function createItemHTML(model, index) {
    const div = document.createElement('div');
    div.className = "carousel-item relative w-[350px] h-[550px] flex-shrink-0 flex items-center justify-center transition-all duration-500 ease-out";
    div.dataset.index = index; // Índice lógico real
    div.dataset.name = model.name;
    div.dataset.price = model.price;
    div.dataset.img = model.img;
    
    div.innerHTML = `
      <img src="${model.img}" alt="${model.name}" class="w-full h-full object-contain drop-shadow-2xl pointer-events-none" />
      <div class="absolute -bottom-10 left-0 w-full text-center opacity-0 transition-opacity duration-300 item-label">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-woltz-muted">${model.name}</p>
      </div>
    `;
    return div;
  }

  // Renderiza apenas os itens visíveis + buffer de segurança
  function renderItems() {
    track.innerHTML = '';
    // Renderizamos um range grande ao redor do índice atual para garantir que nunca falte item
    // Range de -10 a +10 itens ao redor do atual é mais que suficiente para qualquer inércia
    const range = 12; 
    
    for (let i = currentIndex - range; i <= currentIndex + range; i++) {
      // Lógica de módulo para loop infinito nos dados
      const modelIndex = ((i % models.length) + models.length) % models.length;
      const model = models[modelIndex];
      const item = createItemHTML(model, i);
      track.appendChild(item);
    }
    
    updatePositions();
    updateVisuals();
  }

  // Posiciona os itens baseados no índice lógico
  function updatePositions() {
    const items = document.querySelectorAll('.carousel-item');
    items.forEach(item => {
      const idx = parseInt(item.dataset.index);
      // Posição X = (índice - índiceAtual) * larguraTotal
      // Isso mantém o item "currentIndex" sempre na posição 0 do track
      const x = (idx - currentIndex) * totalItemWidth;
      gsap.set(item, { x: x });
    });
  }

  // Atualiza escala, blur e painel
  function updateVisuals() {
    const focusPoint = window.innerWidth * 0.65; // Ponto de foco à direita
    const trackRect = track.getBoundingClientRect();
    // O track está posicionado tal que o item currentIndex está em trackRect.left + offset
    // Mas como movemos o track inteiro, precisamos calcular a posição global
    
    // Simplificação: O item com dataset.index === currentIndex deve estar no focusPoint
    // Vamos calcular o deslocamento necessário para alinhar o currentIndex ao focusPoint
    // Na verdade, o Draggable move o track. Vamos ler a posição do track.
    
    const trackX = gsap.getProperty(track, "x");
    
    const items = document.querySelectorAll('.carousel-item');
    let activeItemFound = false;

    items.forEach((item) => {
      const idx = parseInt(item.dataset.index);
      // Posição absoluta do item na tela
      // Posição base do item no track (relativa ao centro do track) + posição do track na tela + metade da largura
      // Como resetamos as posições em updatePositions, o item currentIndex está em x=0 dentro do track
      // Então a posição dele na tela é: trackX + (offset inicial do track) + itemWidth/2
      
      // Para simplificar drasticamente: 
      // Sabemos que o item 'currentIndex' deveria estar alinhado ao foco.
      // A distância de qualquer outro item é (idx - currentIndex) * totalItemWidth
      
      const distanceFromCenter = (idx - currentIndex) * totalItemWidth;
      
      // Se o track estivesse perfeitamente alinhado, a distância seria essa.
      // Mas o track pode estar no meio de um arrasto.
      // Vamos usar a posição real na tela para precisão visual
      
      const rect = item.getBoundingClientRect();
      const itemCenter = rect.left + rect.width / 2;
      const distToFocus = Math.abs(focusPoint - itemCenter);
      
      const isActive = distToFocus < (totalItemWidth / 2);
      
      if (isActive && !activeItemFound) {
         // Atualiza painel apenas uma vez por frame
         updatePanel(item);
         activeItemFound = true;
      }

      // Efeitos visuais baseados na distância do foco
      const scale = isActive ? 1.1 : Math.max(0.6, 1 - (distToFocus / (window.innerWidth * 0.8)));
      const blur = isActive ? 0 : Math.min(6, distToFocus / 80);
      const opacity = isActive ? 1 : Math.max(0.3, 1 - (distToFocus / (window.innerWidth * 0.6)));
      const zIndex = isActive ? 10 : 1;
      const labelOpacity = isActive ? 1 : 0;

      gsap.to(item, {
        scale: scale,
        filter: `blur(${blur}px)`,
        opacity: opacity,
        zIndex: zIndex,
        duration: 0.4,
        overwrite: true // Importante para sobrescrever animações anteriores durante drag rápido
      });

      gsap.to(item.querySelector('.item-label'), { opacity: labelOpacity, duration: 0.3 });
    });
  }

  function updatePanel(item) {
    const name = item.dataset.name;
    const price = item.dataset.price;
    const img = item.dataset.img;

    if (panelName.innerText !== name) {
      gsap.to([panelImg, panelName, panelPrice], { 
        opacity: 0, y: 10, duration: 0.2, 
        onComplete: () => {
          panelImg.src = img;
          panelName.innerText = name;
          panelPrice.innerText = `$${parseFloat(price).toFixed(2)}`;
          gsap.to([panelImg, panelName, panelPrice], { opacity: 1, y: 0, duration: 0.3 });
        }
      });
    }
  }

  // Inicialização
  function init() {
    renderItems();
    
    // Centraliza o track inicialmente para que o item 0 fique no ponto de foco
    const focusPoint = window.innerWidth * 0.65;
    // Queremos que o item 0 (que está em x=0 dentro do track) fique em focusPoint
    // O track começa em 0. Precisamos mover o track para que seu "centro relativo" alinhe
    // Na verdade, o item 0 está em x=0 DENTRO do track. 
    // Se o track estiver em x=0 na tela, o item 0 começa na esquerda da tela.
    // Precisamos deslocar o track para a direita.
    
    // Posição inicial do track:
    // trackX + 0 (posição do item 0) + itemWidth/2 = focusPoint
    // trackX = focusPoint - itemWidth/2
    const initialTrackX = focusPoint - (itemWidth / 2);
    gsap.set(track, { x: initialTrackX });
    
    setupDraggable(initialTrackX);
  }

  function setupDraggable(initialX) {
    Draggable.create(track, {
      type: "x",
      inertia: true,
      bounds: { minX: -Infinity, maxX: Infinity },
      snap: function(endValue) {
        // Snap para múltiplos de totalItemWidth
        // Mas precisamos considerar o offset inicial
        // O valor endValue é a posição X absoluta do track
        
        // Quantos itens foram percorridos desde o início?
        // (endValue - initialX) / totalItemWidth
        const itemsMoved = Math.round((endValue - initialX) / totalItemWidth);
        
        // Novo índice lógico
        currentIndex = -itemsMoved; // Negativo porque ao mover track pra direita (x positivo), vamos pra itens anteriores (índices negativos)
        
        // Recalcula a posição exata de snap
        return initialX + (itemsMoved * totalItemWidth);
      },
      onDrag: function() {
        updateVisuals();
        checkAndRefill();
      },
      onThrowUpdate: function() {
        updateVisuals();
        checkAndRefill();
      },
      onRelease: function() {
        setTimeout(() => {
            updateVisuals();
            // Após o snap, re-renderizamos para manter o DOM limpo e centrado no novo índice
            renderItems();
            // Reajusta a posição do track para corresponder ao novo render
            const focusPoint = window.innerWidth * 0.65;
            const newTrackX = focusPoint - (itemWidth / 2);
            gsap.set(track, { x: newTrackX });
        }, 50);
      }
    });
  }

  // Verifica se precisamos adicionar mais itens nas bordas (segurança extra)
  function checkAndRefill() {
    // Com a lógica de renderizar +/- 12 itens, isso raramente será acionado,
    // mas serve como rede de segurança se a inércia for absurda
    const items = document.querySelectorAll('.carousel-item');
    if (items.length === 0) return;
    
    const firstIdx = parseInt(items[0].dataset.index);
    const lastIdx = parseInt(items[items.length - 1].dataset.index);
    
    // Se o currentIndex chegou perto das bordas do range renderizado
    if (currentIndex - firstIdx < 4 || lastIdx - currentIndex < 4) {
      renderItems();
    }
  }

  // Inicia
  setTimeout(init, 100);
  
  window.addEventListener('resize', () => {
      // Re-centraliza
      const focusPoint = window.innerWidth * 0.65;
      const newTrackX = focusPoint - (itemWidth / 2);
      gsap.set(track, { x: newTrackX });
      updateVisuals();
  });

</script>
