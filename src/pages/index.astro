---
import Layout from '../layouts/Layout.astro';
---

<Layout title="WOLTZ | NOCTIS VOL. I">
  
  <!-- CURSOR PERSONALIZADO (O JS vai preencher isso) -->
  <div id="cursor-container"></div>

  <!-- HEADER -->
  <header id="main-header" class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 md:px-12 py-6 transition-all duration-700">
    <div class="text-2xl font-bold tracking-[0.3em] text-white z-50">WOLTZ</div>
    
    <nav class="hidden md:flex gap-10 text-[11px] font-light tracking-[0.2em] text-white/70 uppercase">
      <a href="#" class="hover:text-white transition-colors duration-300 relative group py-1">
        Catalog
        <span class="absolute bottom-0 left-0 w-0 h-[1px] bg-white transition-all duration-500 group-hover:w-full"></span>
      </a>
      <a href="#" class="hover:text-white transition-colors duration-300 relative group py-1">
        Collections
        <span class="absolute bottom-0 left-0 w-0 h-[1px] bg-white transition-all duration-500 group-hover:w-full"></span>
      </a>
      <a href="#" class="hover:text-white transition-colors duration-300 relative group py-1">
        About Us
        <span class="absolute bottom-0 left-0 w-0 h-[1px] bg-white transition-all duration-500 group-hover:w-full"></span>
      </a>
      <a href="#" class="hover:text-white transition-colors duration-300 relative group py-1">
        Contact
        <span class="absolute bottom-0 left-0 w-0 h-[1px] bg-white transition-all duration-500 group-hover:w-full"></span>
      </a>
    </nav>

    <div class="flex gap-6 text-white/70 z-50">
      <button class="hover:text-white transition-colors clickable">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </button>
      <button class="hover:text-white transition-colors clickable">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      </button>
    </div>
  </header>

  <!-- HERO SECTION -->
  <main class="relative w-full h-screen overflow-hidden bg-black">
    
    <!-- Imagem Principal de Fundo -->
    <div class="absolute inset-0 z-0">
      <img 
        id="hero-main-img" 
        src="https://images.unsplash.com/photo-1552374196-c4e7ffc6e126?q=80&w=2574&auto=format&fit=crop" 
        alt="WOLTZ Collection Main" 
        class="w-full h-full object-cover transition-all duration-1000 ease-out"
      />
      <!-- Overlay sutil para garantir leitura do texto -->
      <div class="absolute inset-0 bg-gradient-to-r from-black/60 via-black/20 to-transparent"></div>
    </div>

    <!-- Conteúdo Sobreposto -->
    <div class="relative z-10 w-full h-full flex flex-col justify-between p-6 md:p-16 text-white">

      <!-- Lado Esquerdo: Títulos e Botões -->
      <div class="mt-24 md:mt-32 max-w-3xl fade-in-up">
        <h2 class="text-[10px] md:text-xs tracking-[0.4em] text-white/60 mb-4 uppercase">Collection 2026</h2>
        <h1 class="font-['Anton'] text-7xl md:text-[10rem] leading-[0.85] tracking-tight mb-6 uppercase">
          Noctis<br/>Vol. I
        </h1>
        <p class="font-light text-sm md:text-base tracking-widest text-white/70 mb-10 max-w-md leading-relaxed">
          Winter Collection.<br/>
          Designed for movement.<br/>
          Built for extremes.
        </p>

        <div class="flex flex-col md:flex-row gap-8 items-start md:items-center">
          <!-- Botão Geométrico Principal -->
          <button class="group relative w-20 h-20 rounded-full border border-white/30 flex items-center justify-center hover:scale-110 hover:border-white transition-all duration-700 clickable">
            <span class="text-[10px] tracking-widest group-hover:opacity-0 transition-opacity duration-500">EXPLORE</span>
            <svg class="absolute opacity-0 group-hover:opacity-100 transition-opacity duration-500 w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg>
          </button>
          
          <!-- Botão Editorial Secundário -->
          <a href="#" class="text-xs tracking-[0.2em] uppercase border-b border-transparent hover:border-white pb-1 transition-all duration-500 group flex items-center gap-2 clickable">
            View Full Collection 
            <span class="inline-block transition-transform duration-500 group-hover:translate-x-2">→</span>
          </a>
        </div>
      </div>

      <!-- Lado Direito: Miniaturas e Indicadores -->
      <div class="absolute right-6 md:right-16 top-1/2 -translate-y-1/2 flex flex-col items-end gap-6 fade-in-up delay-300">
        <div class="flex flex-col gap-4">
          <!-- Thumbnail 1 (Ativa) -->
          <img 
            src="https://images.unsplash.com/photo-1552374196-c4e7ffc6e126?q=80&w=2574&auto=format&fit=crop" 
            onclick="changeHeroImage(this.src, 0)"
            class="w-12 h-16 md:w-16 md:h-24 object-cover opacity-100 border border-white cursor-pointer transition-all duration-500 clickable" 
          />
          <!-- Thumbnail 2 -->
          <img 
            src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=2000&auto=format&fit=crop" 
            onclick="changeHeroImage(this.src, 1)"
            class="w-12 h-16 md:w-16 md:h-24 object-cover opacity-40 hover:opacity-100 border border-transparent hover:border-white cursor-pointer transition-all duration-500 clickable" 
          />
          <!-- Thumbnail 3 -->
          <img 
            src="https://images.unsplash.com/photo-1529139574466-a303027c1d8b?q=80&w=2000&auto=format&fit=crop" 
            onclick="changeHeroImage(this.src, 2)"
            class="w-12 h-16 md:w-16 md:h-24 object-cover opacity-40 hover:opacity-100 border border-transparent hover:border-white cursor-pointer transition-all duration-500 clickable" 
          />
        </div>

        <!-- Indicadores -->
        <div class="flex flex-col gap-2 text-[10px] font-light tracking-widest">
          <span class="indicator text-white opacity-100 transition-all duration-500">01</span>
          <span class="indicator text-white/30 opacity-50 transition-all duration-500">02</span>
          <span class="indicator text-white/30 opacity-50 transition-all duration-500">03</span>
        </div>
      </div>

      <!-- Rodapé Direito: Redes Sociais -->
      <div class="absolute bottom-6 right-6 md:bottom-16 md:right-16 flex gap-6 text-white/50 fade-in-up delay-500">
        <a href="#" class="hover:text-white transition-colors duration-300 clickable">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        </a>
        <a href="#" class="hover:text-white transition-colors duration-300 clickable">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
        </a>
        <a href="#" class="hover:text-white transition-colors duration-300 clickable">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>
        </a>
      </div>

    </div>
  </main>

</Layout>
