---
import Layout from '../layouts/Layout.astro';

// Busca dados da API interna
let homeData = { featuredCollection: null, recentItems: [] };
try {
  const res = await fetch('http://localhost:4321/api/home'); // URL local para build
  // Em produção, use a URL absoluta ou relative path se configurado
  // Para garantir funcionamento em dev e prod, vamos usar fetch relativo se possível, 
  // mas Astro SSG precisa de URL absoluta ou server-side fetch direto ao DB.
  // Vamos fazer fetch direto ao DB via lib/supabase para ser mais seguro no SSG:
  
  import { supabase } from '../lib/supabase';
  
  // 1. Coleção Destaque
  const { data: col } = await supabase.from('collections').select('*').eq('status', 'published').order('created_at', { ascending: false }).limit(1).single();
  
  let packBrl = 0, packUsd = 0, count = 0;
  if (col) {
    const { data: prods } = await supabase.from('products').select('price_brl, price_usd').eq('collection_id', col.id).eq('status', 'published');
    count = prods?.length || 0;
    const tBrl = prods?.reduce((s, p) => s + (parseFloat(p.price_brl)||0), 0) || 0;
    const tUsd = prods?.reduce((s, p) => s + (parseFloat(p.price_usd)||0), 0) || 0;
    packBrl = tBrl * 0.85;
    packUsd = tUsd * 0.85;
  }

  // 2. Recentes
  const { data: recents } = await supabase.from('products').select('*, collections(name)').eq('status', 'published').not('thumbnail_url', 'is', null).order('created_at', { ascending: false }).limit(6);

  homeData = {
    featuredCollection: col ? { ...col, pack_price_brl: packBrl.toFixed(2), pack_price_usd: packUsd.toFixed(2), product_count: count } : null,
    recentItems: recents || []
  };

} catch(e) { console.error("Home fetch error", e); }

const featured = homeData.featuredCollection;
const recents = homeData.recentItems;

// Helper para imagem otimizada
const imgUrl = (url, w=800) => url ? `${url}?width=${w}&quality=80` : '/placeholder.jpg';
---

<Layout title="WOLTZ | Premium Digital Fashion">
  
  <!-- HERO SECTION: Coleção Destaque -->
  <section class="relative h-screen w-full overflow-hidden bg-[#111]">
    {featured ? (
      <>
        <!-- Imagem Grande de Fundo -->
        <div class="absolute inset-0 z-0">
          <img src={imgUrl(featured.image_url, 1920)} alt={featured.name} class="w-full h-full object-cover opacity-80" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#111] via-transparent to-black/30"></div>
        </div>

        <!-- Conteúdo Hero -->
        <div class="relative z-10 h-full flex flex-col justify-end pb-24 px-8 md:px-16 max-w-7xl mx-auto">
          <span class="text-white/60 text-sm tracking-[0.3em] uppercase mb-4">New Collection</span>
          <h1 class="text-6xl md:text-8xl font-bold text-white leading-none mb-6 uppercase">{featured.name}</h1>
          
          <div class="flex flex-wrap gap-8 items-end border-t border-white/20 pt-6">
            <div>
              <p class="text-white/50 text-xs uppercase tracking-widest mb-1">Sets Included</p>
              <p class="text-white text-xl font-mono">{featured.product_count} Sets</p>
            </div>
            <div>
              <p class="text-white/50 text-xs uppercase tracking-widest mb-1">Collection Price</p>
              <p class="text-white text-xl font-mono">$ {Number(featured.pack_price_usd).toFixed(2)}</p>
            </div>
            <div class="hidden md:block">
              <p class="text-white/50 text-xs uppercase tracking-widest mb-1">Description</p>
              <p class="text-white/80 text-sm max-w-md line-clamp-2">{featured.description || 'Premium digital fashion collection.'}</p>
            </div>
          </div>
        </div>

        <!-- Sidebar Lateral (3 Últimos Lançamentos) -->
        <div class="absolute right-0 top-1/2 -translate-y-1/2 hidden lg:flex flex-col gap-4 pr-8 z-20">
          {recents.slice(0, 3).map((item, i) => (
            <a href={`/products/${item.slug}`} class="group relative w-32 h-32 overflow-hidden rounded-lg border border-white/10 hover:border-white transition-all">
              <img src={imgUrl(item.thumbnail_url, 200)} alt={item.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
              <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                <span class="text-white text-xs font-bold uppercase tracking-wider">View</span>
              </div>
            </a>
          ))}
        </div>
      </>
    ) : (
      <div class="h-full flex items-center justify-center text-white/40">No collections available yet.</div>
    )}
  </section>

  <!-- GRID DE PRODUTOS RECENTES -->
  <section class="py-24 px-8 max-w-7xl mx-auto">
    <div class="flex items-baseline justify-between mb-12 border-b border-white/10 pb-4">
      <h2 class="text-3xl font-bold text-white uppercase tracking-tight">Latest Drops</h2>
      <a href="/catalog" class="text-white/50 hover:text-white text-sm uppercase tracking-widest transition-colors">View All</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {recents.map((product) => (
        <article class="group cursor-pointer">
          <div class="relative aspect-[3/4] overflow-hidden rounded-xl bg-white/5 mb-4">
            <img src={imgUrl(product.thumbnail_url, 600)} alt={product.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" />
            
            {/* Badge de Cores */}
            {product.colors && Array.isArray(product.colors) && product.colors.length > 0 && (
              <div class="absolute bottom-4 left-4 flex gap-1">
                {product.colors.slice(0, 4).map(c => (
                  c.type === 'pattern' && c.url ? 
                    `<div class="w-4 h-4 rounded-full border border-white/50 overflow-hidden"><img src="${c.url}?width=20" /></div>` :
                    `<div class="w-4 h-4 rounded-full border border-white/50" style="background:${c.hex}"></div>`
                )).join('')}
                {product.colors.length > 4 && `<span class="text-[10px] text-white bg-black/50 px-1 rounded">+${product.colors.length - 4}</span>`}
              </div>
            )}
          </div>
          
          <div class="flex justify-between items-start">
            <div>
              <h3 class="text-white font-medium text-lg group-hover:text-white/80 transition-colors">{product.name}</h3>
              <p class="text-white/40 text-xs uppercase tracking-wider mt-1">{product.collections?.name || 'Individual Set'}</p>
            </div>
            <span class="text-white font-mono">$ {Number(product.price_usd || 0).toFixed(2)}</span>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- FOOTER SIMPLIFICADO -->
  <footer class="border-t border-white/10 py-12 px-8 text-center text-white/30 text-sm">
    <p>&copy; 2026 WOLTZ. All rights reserved.</p>
  </footer>

</Layout>
