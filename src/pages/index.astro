---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="WOLTZ | NOCTIS VOL. I">

  <!-- ========================================== -->
  <!-- SEÇÃO 1: HERO BANNER (INALTERADA)          -->
  <!-- ========================================== -->
  <main class="relative w-full h-screen overflow-hidden bg-[#121214]">
    <div class="absolute inset-0 z-0">
      <img id="hero-main-img" src="https://images.unsplash.com/photo-1551488831-00ddcb6c6bd3?q=80&w=2400&auto=format&fit=crop" alt="WOLTZ Collection" class="w-full h-full object-cover transition-all duration-1000 ease-out" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#121214]/90 via-[#121214]/60 to-transparent"></div>
    </div>

    <header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-8 md:px-16 py-8">
      <div class="text-lg font-light tracking-[0.5em] text-white">WOLTZ</div>
      <nav class="hidden md:flex gap-10 text-[10px] tracking-[0.3em] text-white/60 uppercase font-light">
        <a href="#" class="hover:text-white transition-colors duration-500 clickable">[ Catalog ]</a>
        <a href="#" class="hover:text-white transition-colors duration-500 clickable">[ Puffers ]</a>
        <a href="#" class="hover:text-white transition-colors duration-500 clickable">[ Boots ]</a>
        <a href="#" class="hover:text-white transition-colors duration-500 clickable">[ Collections ]</a>
      </nav>
      <div class="flex gap-5 text-white/60">
        <button class="hover:text-white transition-colors duration-500 clickable"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></button>
        <button class="hover:text-white transition-colors duration-500 clickable"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg></button>
      </div>
    </header>

    <div class="relative z-10 w-full h-full flex items-center px-8 md:px-16 lg:px-24">
      <div class="max-w-2xl fade-in-up">
        <div id="collection-series" class="text-[10px] tracking-[0.4em] text-white/40 mb-8 uppercase font-light transition-opacity duration-500">[ Series: Noctis Vol. I ] &nbsp;·&nbsp; [ Series ]</div>
        <h1 id="collection-title" class="font-['Anton'] text-7xl md:text-8xl lg:text-9xl leading-[0.88] tracking-tight mb-10 uppercase text-white transition-opacity duration-500">Collection<br/>Artic 01<span class="text-white/60 text-5xl md:text-6xl align-top">™</span></h1>
        <div class="flex items-center gap-8 mb-5">
          <span class="text-[10px] tracking-[0.3em] text-white/40 uppercase w-20 font-light">Size</span>
          <div class="flex gap-6 text-xs tracking-[0.2em] font-light">
            <span class="text-white/30 hover:text-white transition-colors duration-300 cursor-pointer clickable">S</span>
            <span class="text-white/30 hover:text-white transition-colors duration-300 cursor-pointer clickable">M</span>
            <span class="text-white cursor-pointer clickable">L</span>
            <span class="text-white/30 hover:text-white transition-colors duration-300 cursor-pointer clickable">XL</span>
          </div>
        </div>
        <div class="flex items-center gap-8 mb-12">
          <span class="text-[10px] tracking-[0.3em] text-white/40 uppercase w-20 font-light">Colour</span>
          <div id="collection-colors" class="flex gap-6 text-xs tracking-[0.2em] font-light transition-opacity duration-500">
            <span class="text-white cursor-pointer clickable">White</span>
            <span class="text-white/30 hover:text-white transition-colors duration-300 cursor-pointer clickable">Silver</span>
          </div>
        </div>
        <div class="flex items-center gap-8">
          <button class="group relative w-24 h-24 flex items-center justify-center clickable">
            <svg viewBox="0 0 100 100" class="absolute inset-0 w-full h-full"><polygon points="30,5 70,5 95,30 95,70 70,95 30,95 5,70 5,30" fill="none" stroke="rgba(168,181,196,0.4)" stroke-width="1" class="transition-all duration-700 group-hover:stroke-white group-hover:stroke-[1.5]"/></svg>
            <svg class="w-6 h-6 text-white/70 group-hover:text-white transition-all duration-500 group-hover:translate-x-1 group-hover:-translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7V17"/></svg>
          </button>
          <div>
            <div class="text-[10px] tracking-[0.3em] text-white/40 uppercase mb-2 font-light">Add to Cart</div>
            <div id="collection-price" class="text-3xl font-extralight text-white tracking-tight transition-opacity duration-500">$899.99</div>
          </div>
        </div>
      </div>

      <!-- Miniaturas Horizontais Empilhadas (Posição Ajustada) -->
      <div class="absolute right-8 md:right-16 lg:right-24 top-[25%] flex flex-col items-end gap-4 fade-in-up delay-300 w-[280px] md:w-[320px]">
        <div class="flex flex-col gap-4 w-full">
          <div class="thumbnail-wrapper relative group clickable cursor-pointer transition-all duration-500 opacity-100" onclick="switchCollection(0)">
            <img src="https://images.unsplash.com/photo-1551488831-00ddcb6c6bd3?q=80&w=600&auto=format&fit=crop" class="w-full h-32 md:h-40 object-cover border border-white/80 transition-all duration-500" alt="Artic 01" />
            <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>
          <div class="thumbnail-wrapper relative group clickable cursor-pointer transition-all duration-500 opacity-60 hover:opacity-90 grayscale hover:grayscale-0" onclick="switchCollection(1)">
            <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=600&auto=format&fit=crop" class="w-full h-32 md:h-40 object-cover border border-transparent transition-all duration-500" alt="Noctis Vol. II" />
            <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>
          <div class="thumbnail-wrapper relative group clickable cursor-pointer transition-all duration-500 opacity-60 hover:opacity-90 grayscale hover:grayscale-0" onclick="switchCollection(2)">
            <img src="https://images.unsplash.com/photo-1591047139829-d91aecb6caea?q=80&w=600&auto=format&fit=crop" class="w-full h-32 md:h-40 object-cover border border-transparent transition-all duration-500" alt="Urban Shell" />
            <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>
        </div>
        <div class="text-[10px] tracking-[0.3em] text-white/60 text-right font-light mt-2 w-full flex justify-end" id="image-indicator">01 — 03</div>
      </div>

      <div class="absolute bottom-8 right-8 md:bottom-12 md:right-16 lg:right-24 flex gap-5 fade-in-up delay-500">
        <a href="#" class="text-white/50 hover:text-white transition-colors duration-500 clickable"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg></a>
        <a href="#" class="text-white/50 hover:text-white transition-colors duration-500 clickable"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>
        <a href="#" class="text-white/50 hover:text-white transition-colors duration-500 clickable"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg></a>
      </div>
    </div>
  </main>

  <!-- ========================================== -->
  <!-- SEÇÃO 2: EDITORIAL HORIZONTAL SHOWCASE     -->
  <!-- Scroll + Drag | Foco Único | Espaçamento   -->
  <!-- ========================================== -->
  <section id="showcase-section" class="relative w-full bg-[#121214] min-h-screen flex flex-col justify-center overflow-hidden py-24">
    
    <!-- Título da Seção -->
    <div class="absolute top-12 left-8 md:left-16 z-20 pointer-events-none select-none">
      <h2 class="font-['Anton'] text-5xl md:text-7xl uppercase text-white/10 tracking-tight">THE LOOKBOOK</h2>
      <p class="text-white/30 text-xs tracking-[0.3em] mt-2 font-light">DRAG OR SCROLL TO EXPLORE</p>
    </div>

    <!-- Container da Faixa Horizontal -->
    <div class="showcase-container w-full h-[70vh] flex items-center overflow-visible cursor-grab active:cursor-grabbing touch-pan-x">
      
      <!-- A Faixa que se move -->
      <div class="showcase-track flex items-center gap-[15vw] md:gap-[20vw] pl-[50vw] pr-[50vw] will-change-transform">
        
        <!-- Produto 1 -->
        <div class="showcase-item relative w-[70vw] md:w-[60vw] max-w-[500px] aspect-[3/4] flex-shrink-0 origin-center transition-shadow duration-500">
          <div class="w-full h-full overflow-hidden bg-[#1c1c1f] shadow-2xl shadow-black/50 rounded-sm">
            <img src="https://images.unsplash.com/photo-1551488831-00ddcb6c6bd3?q=80&w=1000&auto=format&fit=crop" alt="Look 01" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="absolute -bottom-12 left-0 w-full text-center item-info opacity-0 transition-opacity duration-500">
            <h3 class="text-white text-2xl font-light tracking-wide">Puffer Jacket</h3>
            <p class="text-white/40 text-xs tracking-[0.2em] mt-1">OUTERWEAR • $899</p>
          </div>
        </div>

        <!-- Produto 2 -->
        <div class="showcase-item relative w-[70vw] md:w-[60vw] max-w-[500px] aspect-[3/4] flex-shrink-0 origin-center transition-shadow duration-500">
          <div class="w-full h-full overflow-hidden bg-[#1c1c1f] shadow-2xl shadow-black/50 rounded-sm">
            <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=1000&auto=format&fit=crop" alt="Look 02" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="absolute -bottom-12 left-0 w-full text-center item-info opacity-0 transition-opacity duration-500">
            <h3 class="text-white text-2xl font-light tracking-wide">Knit Sweater</h3>
            <p class="text-white/40 text-xs tracking-[0.2em] mt-1">KNITWEAR • $450</p>
          </div>
        </div>

        <!-- Produto 3 -->
        <div class="showcase-item relative w-[70vw] md:w-[60vw] max-w-[500px] aspect-[3/4] flex-shrink-0 origin-center transition-shadow duration-500">
          <div class="w-full h-full overflow-hidden bg-[#1c1c1f] shadow-2xl shadow-black/50 rounded-sm">
            <img src="https://images.unsplash.com/photo-1591047139829-d91aecb6caea?q=80&w=1000&auto=format&fit=crop" alt="Look 03" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="absolute -bottom-12 left-0 w-full text-center item-info opacity-0 transition-opacity duration-500">
            <h3 class="text-white text-2xl font-light tracking-wide">Bomber Shell</h3>
            <p class="text-white/40 text-xs tracking-[0.2em] mt-1">JACKETS • $749</p>
          </div>
        </div>

        <!-- Produto 4 -->
        <div class="showcase-item relative w-[70vw] md:w-[60vw] max-w-[500px] aspect-[3/4] flex-shrink-0 origin-center transition-shadow duration-500">
          <div class="w-full h-full overflow-hidden bg-[#1c1c1f] shadow-2xl shadow-black/50 rounded-sm">
            <img src="https://images.unsplash.com/photo-1552374196-c4e7ffc6e126?q=80&w=1000&auto=format&fit=crop" alt="Look 04" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="absolute -bottom-12 left-0 w-full text-center item-info opacity-0 transition-opacity duration-500">
            <h3 class="text-white text-2xl font-light tracking-wide">Cargo Pants</h3>
            <p class="text-white/40 text-xs tracking-[0.2em] mt-1">BOTTOMS • $320</p>
          </div>
        </div>

         <!-- Produto 5 -->
         <div class="showcase-item relative w-[70vw] md:w-[60vw] max-w-[500px] aspect-[3/4] flex-shrink-0 origin-center transition-shadow duration-500">
          <div class="w-full h-full overflow-hidden bg-[#1c1c1f] shadow-2xl shadow-black/50 rounded-sm">
            <img src="https://images.unsplash.com/photo-1544923246-77307dd270b1?q=80&w=1000&auto=format&fit=crop" alt="Look 05" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="absolute -bottom-12 left-0 w-full text-center item-info opacity-0 transition-opacity duration-500">
            <h3 class="text-white text-2xl font-light tracking-wide">Tech Vest</h3>
            <p class="text-white/40 text-xs tracking-[0.2em] mt-1">ACCESSORIES • $280</p>
          </div>
        </div>

      </div>
    </div>

  </section>

  <!-- Scripts Globais e de Animação -->
  <script is:inline>
    import gsap from 'https://cdn.skypack.dev/gsap@3.12.5';
    import ScrollTrigger from 'https://cdn.skypack.dev/gsap@3.12.5/ScrollTrigger';
    import Draggable from 'https://cdn.skypack.dev/gsap@3.12.5/Draggable';
    import InertiaPlugin from 'https://cdn.skypack.dev/gsap@3.12.5/InertiaPlugin';

    gsap.registerPlugin(ScrollTrigger, Draggable, InertiaPlugin);

    document.addEventListener('DOMContentLoaded', () => {
      
      // ==========================================
      // LÓGICA DO EDITORIAL SHOWCASE (SCROLL + DRAG)
      // ==========================================
      
      const track = document.querySelector('.showcase-track');
      const items = gsap.utils.toArray('.showcase-item');
      const container = document.querySelector('.showcase-container');

      // 1. Configurar Draggable (Arrastar) com Inércia
      Draggable.create(track, {
        type: "x",
        inertia: true,
        bounds: { minX: -(track.scrollWidth - window.innerWidth), maxX: 0 },
        edgeResistance: 0.65,
        dragClickables: false, // Permite clicar em links dentro dos itens
        onDrag: updateShowcase, // Atualiza escala durante o arrasto
        onThrowUpdate: updateShowcase // Atualiza escala durante a inércia
      });

      // 2. Conectar Scroll Vertical ao Movimento Horizontal (Parallax Runway)
      // Isso faz com que rolar a página também mova os produtos lateralmente
      gsap.to(track, {
        x: () => -(track.scrollWidth - window.innerWidth),
        ease: "none",
        scrollTrigger: {
          trigger: "#showcase-section",
          start: "top bottom",
          end: "bottom top",
          scrub: 1,
          invalidateOnRefresh: true,
          onUpdate: self => {
            // Sincroniza a posição do draggable com o scroll
            gsap.set(track, { x: gsap.getProperty(track, "x") }); 
            updateShowcase();
          }
        }
      });

      // 3. Função Central: Atualizar Escala e Opacidade baseado na posição
      function updateShowcase() {
        const centerX = window.innerWidth / 2;
        
        items.forEach(item => {
          // Pega a posição atual do item na tela
          const rect = item.getBoundingClientRect();
          const itemCenterX = rect.left + rect.width / 2;
          
          // Calcula a distância do centro da tela
          const distanceFromCenter = Math.abs(centerX - itemCenterX);
          
          // Define thresholds para o efeito "Runway"
          // Quanto menor o threshold, mais rápido ele diminui ao sair do centro
          const maxDistance = window.innerWidth * 0.6; 
          
          // Normaliza a distância (0 = centro, 1 = longe)
          let progress = Math.min(distanceFromCenter / maxDistance, 1);
          
          // Aplica easing para suavizar a transição de escala
          // No centro (progress 0) -> scale 1.1
          // Nas bordas (progress 1) -> scale 0.75
          const scale = gsap.utils.interpolate(1.1, 0.75, progress);
          const opacity = gsap.utils.interpolate(1, 0.3, progress);
          const blur = gsap.utils.interpolate(0, 4, progress); // Leve desfoque nas bordas
          const zIndex = Math.round((1 - progress) * 10);

          // Aplica as transformações
          gsap.set(item, {
            scale: scale,
            opacity: opacity,
            filter: `blur(${blur}px)`,
            zIndex: zIndex
          });

          // Controla a visibilidade das informações (texto)
          const info = item.querySelector('.item-info');
          if (info) {
            gsap.set(info, { opacity: progress < 0.3 ? 1 : 0 });
          }
        });
      }

      // Inicializa o estado visual
      updateShowcase();
      
      // Atualiza no resize da janela
      window.addEventListener('resize', () => {
        ScrollTrigger.refresh();
        updateShowcase();
      });


      // ==========================================
      // SCRIPT ORIGINAL DA HERO SECTION
      // ==========================================
      window.switchCollection = function(index) {
        const collections = [
          {
            image: 'https://images.unsplash.com/photo-1551488831-00ddcb6c6bd3?q=80&w=2400&auto=format&fit=crop',
            series: '[ Series: Noctis Vol. I ] · [ Series ]',
            title: 'Collection<br/>Artic 01<span class="text-white/60 text-5xl md:text-6xl align-top">™</span>',
            colors: '<span class="text-white cursor-pointer clickable">White</span><span class="text-white/30 hover:text-white transition-colors duration-300 cursor-pointer clickable ml-6">Silver</span>',
            price: '$899.99'
          },
          {
            image: 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=2400&auto=format&fit=crop',
            series: '[ Series: Noctis Vol. II ] · [ Series ]',
            title: 'Collection<br/>Noctis 02<span class="text-white/60 text-5xl md:text-6xl align-top">™</span>',
            colors: '<span class="text-white cursor-pointer clickable">Black</span><span class="text-white/30 hover:text-white transition-colors duration-300 cursor-pointer clickable ml-6">Navy</span>',
            price: '$1,249.00'
          },
          {
            image: 'https://images.unsplash.com/photo-1591047139829-d91aecb6caea?q=80&w=2400&auto=format&fit=crop',
            series: '[ Series: Urban Shell ] · [ Series ]',
            title: 'Collection<br/>Shell 03<span class="text-white/60 text-5xl md:text-6xl align-top">™</span>',
            colors: '<span class="text-white cursor-pointer clickable">Olive</span><span class="text-white/30 hover:text-white transition-colors duration-300 cursor-pointer clickable ml-6">Sand</span>',
            price: '$749.50'
          }
        ];

        const data = collections[index];
        const mainImg = document.getElementById('hero-main-img');
        const seriesEl = document.getElementById('collection-series');
        const titleEl = document.getElementById('collection-title');
        const colorsEl = document.getElementById('collection-colors');
        const priceEl = document.getElementById('collection-price');
        const indicator = document.getElementById('image-indicator');
        const wrappers = document.querySelectorAll('.thumbnail-wrapper');

        [seriesEl, titleEl, colorsEl, priceEl].forEach(el => el.style.opacity = '0');
        mainImg.style.opacity = '0';
        mainImg.style.filter = 'blur(15px) scale(1.05)';

        setTimeout(() => {
          mainImg.src = data.image;
          seriesEl.innerHTML = data.series;
          titleEl.innerHTML = data.title;
          colorsEl.innerHTML = data.colors;
          priceEl.textContent = data.price;

          mainImg.onload = () => {
            mainImg.style.opacity = '1';
            mainImg.style.filter = 'blur(0px) scale(1)';
          };
          setTimeout(() => {
            mainImg.style.opacity = '1';
            mainImg.style.filter = 'blur(0px) scale(1)';
          }, 600);

          [seriesEl, titleEl, colorsEl, priceEl].forEach(el => el.style.opacity = '1');

          wrappers.forEach((w, i) => {
            const img = w.querySelector('img');
            if (i === index) {
              w.classList.remove('opacity-60', 'grayscale');
              w.classList.add('opacity-100');
              img.classList.remove('border-transparent');
              img.classList.add('border-white/80');
            } else {
              w.classList.remove('opacity-100');
              w.classList.add('opacity-60', 'grayscale');
              img.classList.remove('border-white/80');
              img.classList.add('border-transparent');
            }
          });

          if (indicator) indicator.textContent = `0${index + 1} — 0${collections.length}`;
        }, 500);
      };
    });
  </script>

</Layout>
