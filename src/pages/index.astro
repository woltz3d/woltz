  <!-- SCRIPT PARA INTERATIVIDADE DO HERO -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // Dados das coleções injetados pelo Astro
      const collectionsData = [
        {
          image: document.getElementById('hero-main-img')?.src,
          series: document.getElementById('collection-series')?.innerText,
          title: document.getElementById('collection-title')?.innerText,
          sets: document.getElementById('collection-sets')?.innerText,
          price: document.getElementById('collection-price')?.innerText
        },
        ...Array.from(document.querySelectorAll('.thumb-item')).slice(1).map((thumb, i) => {
          const img = thumb.querySelector('img');
          // Aqui você poderia injetar dados reais via data-attributes se necessário
          // Por enquanto, vamos apenas trocar a imagem visualmente
          return { image: img?.src };
        })
      ];

      const thumbs = document.querySelectorAll('.thumb-item');
      const mainImg = document.getElementById('hero-main-img');
      const seriesEl = document.getElementById('collection-series');
      const titleEl = document.getElementById('collection-title');
      const setsEl = document.getElementById('collection-sets');
      const priceEl = document.getElementById('collection-price');
      const indicator = document.getElementById('image-indicator');

      function updateHero(index) {
        // Atualiza classes visuais das thumbnails
        thumbs.forEach((t, i) => {
          const img = t.querySelector('img');
          if (i === index) {
            t.classList.remove('opacity-60', 'grayscale');
            t.classList.add('opacity-100');
            img?.classList.remove('border-transparent');
            img?.classList.add('border-white/80');
          } else {
            t.classList.remove('opacity-100');
            t.classList.add('opacity-60', 'grayscale');
            img?.classList.remove('border-white/80');
            img?.classList.add('border-transparent');
          }
        });

        // Animação de transição
        [seriesEl, titleEl, setsEl, priceEl].forEach(el => el && (el.style.opacity = '0'));
        if(mainImg) {
            mainImg.style.opacity = '0';
            mainImg.style.filter = 'blur(15px) scale(1.05)';
        }

        setTimeout(() => {
          // Atualiza conteúdo (apenas imagem por enquanto, dados textuais viriam de um objeto completo)
          if(mainImg && collectionsData[index]?.image) mainImg.src = collectionsData[index].image;
          
          // Simulação de atualização de texto (em produção, use data attributes nas thumbs)
          if(seriesEl && collectionsData[index]?.series) seriesEl.innerText = collectionsData[index].series;
          if(titleEl && collectionsData[index]?.title) titleEl.innerText = collectionsData[index].title;
          if(setsEl && collectionsData[index]?.sets) setsEl.innerText = collectionsData[index].sets;
          if(priceEl && collectionsData[index]?.price) priceEl.innerText = collectionsData[index].price;

          if(mainImg) {
              mainImg.onload = () => {
                mainImg.style.opacity = '1';
                mainImg.style.filter = 'blur(0px) scale(1)';
              };
              setTimeout(() => {
                mainImg.style.opacity = '1';
                mainImg.style.filter = 'blur(0px) scale(1)';
              }, 600);
          }

          [seriesEl, titleEl, setsEl, priceEl].forEach(el => el && (el.style.opacity = '1'));
          
          if (indicator) indicator.textContent = `0${index + 1} — 0${thumbs.length}`;
        }, 500);
      }

      thumbs.forEach((thumb, i) => {
        thumb.addEventListener('click', () => updateHero(i));
      });
    });
  </script>

