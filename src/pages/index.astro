        </svg>
        
        <div class="font-vcr text-[10px] tracking-[0.15em] text-white/80 uppercase leading-relaxed">
          <p>©2026 WOLTZ WEAR</p>
          <p>ALL RIGHTS RESERVED</p>
        </div>

        <div class="font-vcr text-[10px] tracking-[0.15em] text-white/60 uppercase leading-relaxed">
          <p>WAREHOUSE ZONE / INDUSTRIAL</p>
          <p>PIER / COLD STORAGE DISTRICT</p>
