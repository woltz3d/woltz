---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';
import '../styles/global.css';

// --- BUSCA DE DADOS DINÂMICOS ---
let featuredCollection = null;
let sidebarCollections = [];
let gridProducts = [];

try {
  // 1. Busca TODAS as coleções published ordenadas por data
  const { data: allCols } = await supabase
    .from('collections')
    .select('*')
    .eq('status', 'published')
    .order('created_at', { ascending: false });

  if (allCols && allCols.length > 0) {
    // A primeira é a destaque principal
    const mainCol = allCols[0];
    
    // Calcula preço do pack e contagem para a coleção destaque
    const { data: prods } = await supabase
      .from('products')
      .select('price_brl, price_usd')
      .eq('collection_id', mainCol.id)
      .eq('status', 'published');
    
    const count = prods?.length || 0;
    const totalBrl = prods?.reduce((s, p) => s + (parseFloat(p.price_brl)||0), 0) || 0;
    const totalUsd = prods?.reduce((s, p) => s + (parseFloat(p.price_usd)||0), 0) || 0;
    
    featuredCollection = {
      ...mainCol,
      product_count: count,
      pack_price_brl: (totalBrl * 0.85).toFixed(2),
      pack_price_usd: (totalUsd * 0.85).toFixed(2)
    };

    // As próximas 2 vão para a sidebar lateral
    sidebarCollections = allCols.slice(1, 3);
  }

  // 2. Busca os Produtos Recentes para a GRADE EDITORIAL
  // Usa distinct on name para evitar duplicatas se houver variantes
  const { data: recentProds } = await supabase
    .from('products')
    .select('*, collections(name)')
    .eq('status', 'published')
    .not('thumbnail_url', 'is', null)
    .order('created_at', { ascending: false })
    .limit(9);
  
  // Filtra duplicatas manualmente no JS para garantir
  const seenNames = new Set();
  gridProducts = (recentProds || []).filter(p => {
    if (seenNames.has(p.name)) return false;
    seenNames.add(p.name);
    return true;
  }).slice(0, 9);

} catch(e) {
  console.error("Erro ao carregar home:", e);
}

// Helper para imagens otimizadas
const imgUrl = (url, w=800) => url ? `${url}?width=${w}&quality=80` : '';

// Helper para renderizar cores corretamente (HTML string seguro)
const renderColors = (colors) => {
  if (!colors || !Array.isArray(colors) || colors.length === 0) return '';
  
  let html = '<div class="flex items-center gap-1.5">';
  const displayColors = colors.slice(0, 4);
  
  displayColors.forEach(c => {
    if (c.type === 'pattern' && c.url) {
      html += `<span class="w-2 h-2 rounded-full overflow-hidden border border-white/50 inline-block"><img src="${c.url}?width=10" class="w-full h-full object-cover" /></span>`;
    } else {
      html += `<span class="w-2 h-2 rounded-full shadow-sm inline-block" style="background:${c.hex || '#ccc'}"></span>`;
    }
  });
  
  if (colors.length > 4) {
    html += `<span class="text-[9px] text-white/70 font-vcr ml-1">+${colors.length - 4}</span>`;
  }
  
  html += '</div>';
  return html;
};
---

<Layout title="WOLTZ | NOCTIS VOL. I">

  <!-- ========================================== -->
  <!-- SEÇÃO 1: HERO BANNER INTERATIVO            -->
