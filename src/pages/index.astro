---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="WOLTZ | NOCTIS VOL. I">

  <!-- ========================================== -->
  <!-- SEÇÃO 1: HERO BANNER (ORIGINAL COMPLETO)  -->
  <!-- ========================================== -->
  <main class="relative w-full h-screen overflow-hidden bg-[#121214]">
    <div class="absolute inset-0 z-0">
      <img id="hero-main-img" src="https://images.unsplash.com/photo-1551488831-00ddcb6c6bd3?q=80&w=2400&auto=format&fit=crop" alt="WOLTZ Collection" class="w-full h-full object-cover transition-all duration-1000 ease-out" />
      <div class="absolute inset-0 bg-gradient-to-br from-[#121214]/90 via-[#121214]/60 to-transparent"></div>
    </div>

    <header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-8 md:px-16 py-8">
      <div class="text-lg font-light tracking-[0.5em] text-white">WOLTZ</div>
      <nav class="hidden md:flex gap-10 text-[10px] tracking-[0.3em] text-white/60 uppercase font-light">
        <a href="#" class="hover:text-white transition-colors duration-500 clickable">[ Catalog ]</a>
        <a href="#" class="hover:text-white transition-colors duration-500 clickable">[ Puffers ]</a>
        <a href="#" class="hover:text-white transition-colors duration-500 clickable">[ Boots ]</a>
        <a href="#" class="hover:text-white transition-colors duration-500 clickable">[ Collections ]</a>
      </nav>
      <div class="flex gap-5 text-white/60">
        <button class="hover:text-white transition-colors duration-500 clickable"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg></button>
        <button class="hover:text-white transition-colors duration-500 clickable"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg></button>
      </div>
    </header>

    <div class="relative z-10 w-full h-full flex items-center px-8 md:px-16 lg:px-24">
      <div class="max-w-2xl fade-in-up">
        <div id="collection-series" class="text-[10px] tracking-[0.4em] text-white/40 mb-8 uppercase font-light transition-opacity duration-500">[ Series: Noctis Vol. I ] &nbsp;·&nbsp; [ Series ]</div>
        <h1 id="collection-title" class="font-['Anton'] text-7xl md:text-8xl lg:text-9xl leading-[0.88] tracking-tight mb-10 uppercase text-white transition-opacity duration-500">Collection<br/>Artic 01<span class="text-white/60 text-5xl md:text-6xl align-top">™</span></h1>
        <div class="flex items-center gap-8 mb-5">
          <span class="text-[10px] tracking-[0.3em] text-white/40 uppercase w-20 font-light">Size</span>
          <div class="flex gap-6 text-xs tracking-[0.2em] font-light">
            <span class="text-white/30 hover:text-white transition-colors duration-300 cursor-pointer clickable">S</span>
            <span class="text-white/30 hover:text-white transition-colors duration-300 cursor-pointer clickable">M</span>
            <span class="text-white cursor-pointer clickable">L</span>
            <span class="text-white/30 hover:text-white transition-colors duration-300 cursor-pointer clickable">XL</span>
          </div>
        </div>
        <div class="flex items-center gap-8 mb-12">
          <span class="text-[10px] tracking-[0.3em] text-white/40 uppercase w-20 font-light">Colour</span>
          <div id="collection-colors" class="flex gap-6 text-xs tracking-[0.2em] font-light transition-opacity duration-500">
            <span class="text-white cursor-pointer clickable">White</span>
            <span class="text-white/30 hover:text-white transition-colors duration-300 cursor-pointer clickable">Silver</span>
          </div>
        </div>
        <div class="flex items-center gap-8">
          <button class="group relative w-24 h-24 flex items-center justify-center clickable">
            <svg viewBox="0 0 100 100" class="absolute inset-0 w-full h-full"><polygon points="30,5 70,5 95,30 95,70 70,95 30,95 5,70 5,30" fill="none" stroke="rgba(168,181,196,0.4)" stroke-width="1" class="transition-all duration-700 group-hover:stroke-white group-hover:stroke-[1.5]"/></svg>
            <svg class="w-6 h-6 text-white/70 group-hover:text-white transition-all duration-500 group-hover:translate-x-1 group-hover:-translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7V17"/></svg>
          </button>
          <div>
            <div class="text-[10px] tracking-[0.3em] text-white/40 uppercase mb-2 font-light">Add to Cart</div>
            <div id="collection-price" class="text-3xl font-extralight text-white tracking-tight transition-opacity duration-500">$899.99</div>
          </div>
        </div>
      </div>

      <!-- Miniaturas Horizontais Empilhadas -->
      <div class="absolute right-8 md:right-16 lg:right-24 top-[25%] flex flex-col items-end gap-4 fade-in-up delay-300 w-[280px] md:w-[320px]">
        <div class="flex flex-col gap-4 w-full">
          <div id="thumb-0" class="thumbnail-wrapper relative group clickable cursor-pointer transition-all duration-500 opacity-100">
            <img src="https://images.unsplash.com/photo-1551488831-00ddcb6c6bd3?q=80&w=600&auto=format&fit=crop" class="w-full h-32 md:h-40 object-cover border border-white/80 transition-all duration-500 pointer-events-none" alt="Artic 01" />
            <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>
          <div id="thumb-1" class="thumbnail-wrapper relative group clickable cursor-pointer transition-all duration-500 opacity-60 hover:opacity-90 grayscale hover:grayscale-0">
            <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=600&auto=format&fit=crop" class="w-full h-32 md:h-40 object-cover border border-transparent transition-all duration-500 pointer-events-none" alt="Noctis Vol. II" />
            <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>
          <div id="thumb-2" class="thumbnail-wrapper relative group clickable cursor-pointer transition-all duration-500 opacity-60 hover:opacity-90 grayscale hover:grayscale-0">
            <img src="https://images.unsplash.com/photo-1591047139829-d91aecb6caea?q=80&w=600&auto=format&fit=crop" class="w-full h-32 md:h-40 object-cover border border-transparent transition-all duration-500 pointer-events-none" alt="Urban Shell" />
            <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>
        </div>
        <div class="text-[10px] tracking-[0.3em] text-white/60 text-right font-light mt-2 w-full flex justify-end" id="image-indicator">01 — 03</div>
      </div>

      <div class="absolute bottom-8 right-8 md:bottom-12 md:right-16 lg:right-24 flex gap-5 fade-in-up delay-500">
        <a href="#" class="text-white/50 hover:text-white transition-colors duration-500 clickable"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg></a>
        <a href="#" class="text-white/50 hover:text-white transition-colors duration-500 clickable"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>
        <a href="#" class="text-white/50 hover:text-white transition-colors duration-500 clickable"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg></a>
      </div>
    </div>
  </main>

  <!-- ========================================== -->
  <!-- SEÇÃO 2: GRADE EDITORIAL (ALTURA UNIFORME) -->
  <!-- ========================================== -->
  <section class="relative w-full bg-[#6b7c93] py-24 px-6 md:px-12 lg:px-20 min-h-screen">
    
    <!-- Cabeçalho da Seção -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-8">
      <div class="flex-1">
        <h2 class="font-['Anton'] text-6xl md:text-8xl uppercase text-white tracking-tight mb-6">NEW COLLECTION</h2>
        <div class="flex flex-wrap gap-x-16 gap-y-4 text-[10px] tracking-[0.2em] text-white/70 uppercase font-vcr">
          <div class="flex flex-col gap-1">
            <span>[ NEW COLLECTION ]</span>
            <span>[ SERIES_01 ]</span>
            <span>[ PUFFERS ]</span>
          </div>
          <div class="flex flex-col gap-1">
            <span>PUFFER JACKETS</span>
            <span>METAL EDITION</span>
            <span>GLOSS SERIES</span>
          </div>
          <div class="flex flex-col gap-1">
            <span>EXTREME COLD LINE</span>
            <span>TECH FABRIC</span>
            <span>WINTER 2026</span>
          </div>
        </div>
      </div>
      
      <button class="border border-white/30 px-6 py-2 text-[10px] tracking-[0.2em] text-white hover:bg-white hover:text-[#6b7c93] transition-all duration-300 uppercase backdrop-blur-sm font-vcr tech-button">
        Filters
      </button>
    </div>

    <!-- PRIMEIRA FILEIRA: Card Aurora (mais largo) + 3 Cards Verticais -->
    <!-- Todos com altura fixa de 450px -->
    <div class="grid grid-cols-4 gap-4 md:gap-6 mb-16 md:mb-24">
      
      <!-- CARD AURORA - MAIS LARGO (col-span-2) mas mesma altura -->
      <div class="col-span-2 relative group clickable h-[450px]">
        <div class="relative w-full h-full overflow-hidden tech-card-asymmetric bg-[#5f7085]">
          <img src="https://images.unsplash.com/photo-1551488831-00ddcb6c6bd3?q=80&w=1200&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" alt="Aurora" />
          
          <div class="absolute bottom-6 right-6 z-10 text-right">
            <h3 class="font-['Anton'] text-3xl md:text-4xl uppercase text-white tracking-tight leading-none mb-1 drop-shadow-md">AURORA™</h3>
            <p class="text-[9px] tracking-[0.2em] text-white/90 uppercase font-medium drop-shadow-sm mb-3 font-vcr">REFLECTIVE SHELL JACKET</p>
            
            <div class="flex items-center justify-end gap-3">
               <div class="text-right hidden md:block">
                  <p class="text-[9px] tracking-widest text-white/60 uppercase mb-0.5 font-vcr">Add to Cart</p>
                  <p class="text-lg font-light text-white drop-shadow-sm">$1,999</p>
               </div>
               <button class="w-10 h-10 rounded-full border border-white/50 flex items-center justify-center hover:bg-white hover:text-[#6b7c93] transition-all backdrop-blur-md group-hover:border-white">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7V17"/></svg>
               </button>
            </div>
          </div>
        </div>
      </div>

      <!-- PRODUTO 2 - Mesma altura (450px) -->
      <div class="col-span-1 relative group clickable flex flex-col h-[450px]">
        <div class="relative w-full flex-1 overflow-hidden mb-3 tech-card-asymmetric bg-[#5f7085]">
          <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=600&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="Aurora Silver" />
        </div>
        <div class="mt-auto">
          <h4 class="font-['Anton'] text-sm tracking-wide uppercase mb-0.5 text-white">AURORA SILVER</h4>
          <p class="text-white/60 text-[9px] tracking-wider uppercase mb-2 font-vcr">REFLECTIVE PUFFER JACKET</p>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-white shadow-sm"></span>
              <span class="text-[9px] text-white/70 font-vcr">WHITE</span>
              <span class="w-2 h-2 rounded-full bg-blue-400 shadow-sm ml-2"></span>
              <span class="text-[9px] text-white/70 font-vcr">BLUE</span>
            </div>
            <p class="text-white text-xs font-light font-vcr">$999.99</p>
          </div>
        </div>
      </div>

      <!-- PRODUTO 3 - Mesma altura (450px) -->
      <div class="col-span-1 relative group clickable flex flex-col h-[450px]">
        <div class="relative w-full flex-1 overflow-hidden mb-3 tech-card-asymmetric bg-[#5f7085]">
          <img src="https://images.unsplash.com/photo-1591047139829-d91aecb6caea?q=80&w=600&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="Orbit Silver" />
        </div>
        <div class="mt-auto">
          <h4 class="font-['Anton'] text-sm tracking-wide uppercase mb-0.5 text-white">ORBIT SILVER</h4>
          <p class="text-white/60 text-[9px] tracking-wider uppercase mb-2 font-vcr">HIGH-GLOSS PUFFER</p>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-gray-300 shadow-sm"></span>
              <span class="text-[9px] text-white/70 font-vcr">SILVER</span>
            </div>
            <p class="text-white text-xs font-light font-vcr">$1,299.99</p>
          </div>
        </div>
      </div>

      <!-- PRODUTO 4 - Mesma altura (450px) -->
      <div class="col-span-1 relative group clickable flex flex-col h-[450px]">
        <div class="relative w-full flex-1 overflow-hidden mb-3 tech-card-asymmetric bg-[#5f7085]">
          <img src="https://images.unsplash.com/photo-1552374196-c4e7ffc6e126?q=80&w=600&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="Stealth Black" />
        </div>
        <div class="mt-auto">
          <h4 class="font-['Anton'] text-sm tracking-wide uppercase mb-0.5 text-white">STEALTH BLACK</h4>
          <p class="text-white/60 text-[9px] tracking-wider uppercase mb-2 font-vcr">HEAVY SHIELD PUFFER</p>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-black border border-white/30 shadow-sm"></span>
              <span class="text-[9px] text-white/70 font-vcr">BLACK</span>
              <span class="w-2 h-2 rounded-full bg-white shadow-sm ml-2"></span>
              <span class="text-[9px] text-white/70 font-vcr">WHITE</span>
            </div>
            <p class="text-white text-xs font-light font-vcr">$1,199.99</p>
          </div>
        </div>
      </div>

    </div>

    <!-- SEGUNDA FILEIRA: 5 Cards Verticais - Mesma altura (450px) -->
    <div class="grid grid-cols-5 gap-4 md:gap-6">
      
      <!-- PRODUTO 5 -->
      <div class="col-span-1 relative group clickable flex flex-col h-[450px]">
        <div class="relative w-full flex-1 overflow-hidden mb-3 tech-card-asymmetric bg-[#5f7085]">
          <img src="https://images.unsplash.com/photo-1544923246-77307dd270b1?q=80&w=600&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="Glacier White" />
        </div>
        <div class="mt-auto">
          <h4 class="font-['Anton'] text-sm tracking-wide uppercase mb-0.5 text-white">GLACIER WHITE</h4>
          <p class="text-white/60 text-[9px] tracking-wider uppercase mb-2 font-vcr">INSULATED PUFFER JACKET</p>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-gray-400 shadow-sm"></span>
              <span class="text-[9px] text-white/70 font-vcr">GREY</span>
            </div>
            <p class="text-white text-xs font-light font-vcr">$1,299.99</p>
          </div>
        </div>
      </div>

      <!-- PRODUTO 6 -->
      <div class="col-span-1 relative group clickable flex flex-col h-[450px]">
        <div class="relative w-full flex-1 overflow-hidden mb-3 tech-card-asymmetric bg-[#5f7085]">
          <img src="https://images.unsplash.com/photo-1550928431-ee0ec6db30d3?q=80&w=600&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="Polar Gloss" />
        </div>
        <div class="mt-auto">
          <h4 class="font-['Anton'] text-sm tracking-wide uppercase mb-0.5 text-white">POLAR GLOSS</h4>
          <p class="text-white/60 text-[9px] tracking-wider uppercase mb-2 font-vcr">BLUE PUFFER JACKET</p>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-blue-300 shadow-sm"></span>
              <span class="text-[9px] text-white/70 font-vcr">BLUE GLOSS</span>
            </div>
            <p class="text-white text-xs font-light font-vcr">$899.99</p>
          </div>
        </div>
      </div>

      <!-- PRODUTO 7 -->
      <div class="col-span-1 relative group clickable flex flex-col h-[450px]">
        <div class="relative w-full flex-1 overflow-hidden mb-3 tech-card-asymmetric bg-[#5f7085]">
          <img src="https://images.unsplash.com/photo-1591047139829-d91aecb6caea?q=80&w=600&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="Stealth Heavy" />
        </div>
        <div class="mt-auto">
          <h4 class="font-['Anton'] text-sm tracking-wide uppercase mb-0.5 text-white">STEALTH BLACK</h4>
          <p class="text-white/60 text-[9px] tracking-wider uppercase mb-2 font-vcr">HEAVY PUFFER JACKET</p>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-blue-900 shadow-sm"></span>
              <span class="text-[9px] text-white/70 font-vcr">NAVY BLUE</span>
              <span class="w-2 h-2 rounded-full bg-black border border-white/30 shadow-sm ml-2"></span>
              <span class="text-[9px] text-white/70 font-vcr">BLACK</span>
            </div>
            <p class="text-white text-xs font-light font-vcr">$1,199.99</p>
          </div>
        </div>
      </div>

      <!-- PRODUTO 8 -->
      <div class="col-span-1 relative group clickable flex flex-col h-[450px]">
        <div class="relative w-full flex-1 overflow-hidden mb-3 tech-card-asymmetric bg-[#5f7085]">
          <img src="https://images.unsplash.com/photo-1551488831-00ddcb6c6bd3?q=80&w=600&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="Icefield Blue" />
        </div>
        <div class="mt-auto">
          <h4 class="font-['Anton'] text-sm tracking-wide uppercase mb-0.5 text-white">ICEFIELD BLUE</h4>
          <p class="text-white/60 text-[9px] tracking-wider uppercase mb-2 font-vcr">TECH PUFFER JACKET</p>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-blue-400 shadow-sm"></span>
              <span class="text-[9px] text-white/70 font-vcr">BLUE</span>
            </div>
            <p class="text-white text-xs font-light font-vcr">$999.99</p>
          </div>
        </div>
      </div>

      <!-- PRODUTO 9 -->
      <div class="col-span-1 relative group clickable flex flex-col h-[450px]">
        <div class="relative w-full flex-1 overflow-hidden mb-3 tech-card-asymmetric bg-[#5f7085]">
          <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=600&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="Polar White" />
        </div>
        <div class="mt-auto">
          <h4 class="font-['Anton'] text-sm tracking-wide uppercase mb-0.5 text-white">POLAR WHITE</h4>
          <p class="text-white/60 text-[9px] tracking-wider uppercase mb-2 font-vcr">SHELL PUFFER JACKET</p>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-white shadow-sm"></span>
              <span class="text-[9px] text-white/70 font-vcr">WHITE</span>
            </div>
            <p class="text-white text-xs font-light font-vcr">$1,499.99</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Scripts Globais e de Animação -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      
      // ==========================================
      // LÓGICA DA HERO SECTION
      // ==========================================
      const collections = [
        {
          image: 'https://images.unsplash.com/photo-1551488831-00ddcb6c6bd3?q=80&w=2400&auto=format&fit=crop',
          series: '[ Series: Noctis Vol. I ] · [ Series ]',
          title: 'Collection<br/>Artic 01<span class="text-white/60 text-5xl md:text-6xl align-top">™</span>',
          colors: '<span class="text-white cursor-pointer clickable">White</span><span class="text-white/30 hover:text-white transition-colors duration-300 cursor-pointer clickable ml-6">Silver</span>',
          price: '$899.99'
        },
        {
          image: 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=2400&auto=format&fit=crop',
          series: '[ Series: Noctis Vol. II ] · [ Series ]',
          title: 'Collection<br/>Noctis 02<span class="text-white/60 text-5xl md:text-6xl align-top">™</span>',
          colors: '<span class="text-white cursor-pointer clickable">Black</span><span class="text-white/30 hover:text-white transition-colors duration-300 cursor-pointer clickable ml-6">Navy</span>',
          price: '$1,249.00'
        },
        {
          image: 'https://images.unsplash.com/photo-1591047139829-d91aecb6caea?q=80&w=2400&auto=format&fit=crop',
          series: '[ Series: Urban Shell ] · [ Series ]',
          title: 'Collection<br/>Shell 03<span class="text-white/60 text-5xl md:text-6xl align-top">™</span>',
          colors: '<span class="text-white cursor-pointer clickable">Olive</span><span class="text-white/30 hover:text-white transition-colors duration-300 cursor-pointer clickable ml-6">Sand</span>',
          price: '$749.50'
        }
      ];

      function updateHero(index) {
        const data = collections[index];
        const mainImg = document.getElementById('hero-main-img');
        const seriesEl = document.getElementById('collection-series');
        const titleEl = document.getElementById('collection-title');
        const colorsEl = document.getElementById('collection-colors');
        const priceEl = document.getElementById('collection-price');
        const indicator = document.getElementById('image-indicator');
        const wrappers = document.querySelectorAll('.thumbnail-wrapper');

        [seriesEl, titleEl, colorsEl, priceEl].forEach(el => el.style.opacity = '0');
        if(mainImg) {
            mainImg.style.opacity = '0';
            mainImg.style.filter = 'blur(15px) scale(1.05)';
        }

        setTimeout(() => {
          if(mainImg) mainImg.src = data.image;
          if(seriesEl) seriesEl.innerHTML = data.series;
          if(titleEl) titleEl.innerHTML = data.title;
          if(colorsEl) colorsEl.innerHTML = data.colors;
          if(priceEl) priceEl.textContent = data.price;

          if(mainImg) {
              mainImg.onload = () => {
                mainImg.style.opacity = '1';
                mainImg.style.filter = 'blur(0px) scale(1)';
              };
              setTimeout(() => {
                mainImg.style.opacity = '1';
                mainImg.style.filter = 'blur(0px) scale(1)';
              }, 600);
          }

          [seriesEl, titleEl, colorsEl, priceEl].forEach(el => el.style.opacity = '1');

          wrappers.forEach((w, i) => {
            const img = w.querySelector('img');
            if (i === index) {
              w.classList.remove('opacity-60', 'grayscale');
              w.classList.add('opacity-100');
              if(img) {
                  img.classList.remove('border-transparent');
                  img.classList.add('border-white/80');
              }
            } else {
              w.classList.remove('opacity-100');
              w.classList.add('opacity-60', 'grayscale');
              if(img) {
                  img.classList.remove('border-white/80');
                  img.classList.add('border-transparent');
              }
            }
          });

          if (indicator) indicator.textContent = `0${index + 1} — 0${collections.length}`;
        }, 500);
      }

      const thumb0 = document.getElementById('thumb-0');
      const thumb1 = document.getElementById('thumb-1');
      const thumb2 = document.getElementById('thumb-2');

      if(thumb0) thumb0.addEventListener('click', () => updateHero(0));
      if(thumb1) thumb1.addEventListener('click', () => updateHero(1));
      if(thumb2) thumb2.addEventListener('click', () => updateHero(2));

    });
  </script>

  <!-- Estilo Global para Fonte VCR e Clip-Path Assimétrico -->
  <style is:global>
    @import url('https://fonts.cdnfonts.com/css/vcr-osd-mono');

    .font-vcr {
      font-family: 'VCR OSD Mono', monospace;
    }

    /* Recorte assimétrico: Superior Esquerdo e Inferior Direito */
    .tech-card-asymmetric {
      clip-path: polygon(
        12px 0,       /* Corte superior esquerdo */
        100% 0,       /* Topo direito reto */
        100% calc(100% - 12px), /* Lado direito descendo até o corte */
        calc(100% - 12px) 100%, /* Corte inferior direito */
        0 100%,       /* Base esquerda reta */
        0 12px        /* Lado esquerdo subindo até o corte */
      );
      background-color: #5f7085;
    }
  </style>

</Layout>
