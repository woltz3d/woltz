---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Analytics" activePage="analytics">
  
  <!-- Top Bar -->
  <header class="bg-[#111113] border-b border-white/5 px-8 py-4 flex items-center justify-between sticky top-0 z-10">
    <div>
      <h1 class="text-2xl font-semibold text-white">Analytics</h1>
      <p class="text-sm text-white/40 mt-1">Track your store performance</p>
    </div>
    <div class="flex items-center gap-3">
      <select class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-sm text-white focus:outline-none">
        <option>Last 30 days</option>
        <option>Last 7 days</option>
        <option>Last 90 days</option>
        <option>This Year</option>
      </select>
    </div>
  </header>

  <!-- Content -->
  <div class="p-8">
    
    <!-- Stats Grid -->
    <div class="grid grid-cols-4 gap-6 mb-8">
      <div class="bg-[#111113] border border-white/5 rounded-xl p-6">
        <div class="flex items-center justify-between mb-4">
          <div class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center">
            <svg class="w-5 h-5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
          </div>
          <span class="text-xs text-green-400 flex items-center gap-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
            23.6%
          </span>
        </div>
        <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Total Revenue</p>
        <p class="text-2xl font-semibold text-white">$24,780.50</p>
      </div>

      <div class="bg-[#111113] border border-white/5 rounded-xl p-6">
        <div class="flex items-center justify-between mb-4">
          <div class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center">
            <svg class="w-5 h-5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <span class="text-xs text-green-400 flex items-center gap-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
            8.7%
          </span>
        </div>
        <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Conversion Rate</p>
        <p class="text-2xl font-semibold text-white">3.92%</p>
      </div>

      <div class="bg-[#111113] border border-white/5 rounded-xl p-6">
        <div class="flex items-center justify-between mb-4">
          <div class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center">
            <svg class="w-5 h-5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
          </div>
          <span class="text-xs text-green-400 flex items-center gap-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
            11.2%
          </span>
        </div>
        <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Avg. Ticket</p>
        <p class="text-2xl font-semibold text-white">$72.46</p>
      </div>

      <div class="bg-[#111113] border border-white/5 rounded-xl p-6">
        <div class="flex items-center justify-between mb-4">
          <div class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center">
            <svg class="w-5 h-5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
          <span class="text-xs text-green-400 flex items-center gap-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.293 9.707a1 1 0 010-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 01-1.414 1.414L11 7.414V15a1 1 0 11-2 0V7.414L6.707 9.707a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
            18.4%
          </span>
        </div>
        <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Total Orders</p>
        <p class="text-2xl font-semibold text-white">342</p>
      </div>
    </div>

    <!-- Charts Row -->
    <div class="grid grid-cols-3 gap-6 mb-8">
      
      <!-- Revenue Chart -->
      <div class="col-span-2 bg-[#111113] border border-white/5 rounded-xl p-6">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h3 class="text-lg font-semibold text-white">Revenue</h3>
            <p class="text-sm text-white/40 mt-1">Daily revenue over time</p>
          </div>
          <div class="flex items-center gap-4">
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-white"></div>
              <span class="text-xs text-white/60">This Period</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-white/20"></div>
              <span class="text-xs text-white/60">Previous</span>
            </div>
          </div>
        </div>
        
        <div class="h-64 relative">
          <svg class="w-full h-full" viewBox="0 0 800 250" preserveAspectRatio="none">
            <defs>
              <linearGradient id="chartGradient" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="white" stop-opacity="0.2"/>
                <stop offset="100%" stop-color="white" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <!-- Previous Period -->
            <path d="M 0 180 Q 50 170 100 160 T 200 150 T 300 140 T 400 130 T 500 120 T 600 110 T 700 100 T 800 90 L 800 250 L 0 250 Z" fill="url(#chartGradient)" opacity="0.3"/>
            <path d="M 0 180 Q 50 170 100 160 T 200 150 T 300 140 T 400 130 T 500 120 T 600 110 T 700 100 T 800 90" fill="none" stroke="white" stroke-width="1" opacity="0.3"/>
            <!-- Current Period -->
            <path d="M 0 200 Q 50 180 100 160 T 200 140 T 300 120 T 400 100 T 500 80 T 600 60 T 700 40 T 800 20 L 800 250 L 0 250 Z" fill="url(#chartGradient)"/>
            <path d="M 0 200 Q 50 180 100 160 T 200 140 T 300 120 T 400 100 T 500 80 T 600 60 T 700 40 T 800 20" fill="none" stroke="white" stroke-width="2"/>
          </svg>
          <div class="absolute bottom-0 left-0 right-0 flex justify-between text-xs text-white/40 px-2">
            <span>30 May</span>
            <span>06 Jun</span>
            <span>13 Jun</span>
            <span>20 Jun</span>
            <span>27 Jun</span>
          </div>
        </div>
      </div>

      <!-- Conversion by Device -->
      <div class="bg-[#111113] border border-white/5 rounded-xl p-6">
        <h3 class="text-lg font-semibold text-white mb-6">Conversion by Device</h3>
        
        <div class="space-y-6">
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm text-white/60">Desktop</span>
              <span class="text-sm font-medium text-white">62.1%</span>
            </div>
            <div class="w-full h-2 bg-white/5 rounded-full overflow-hidden">
              <div class="h-full bg-white rounded-full" style="width: 62.1%"></div>
            </div>
          </div>
          
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm text-white/60">Mobile</span>
              <span class="text-sm font-medium text-white">32.7%</span>
            </div>
            <div class="w-full h-2 bg-white/5 rounded-full overflow-hidden">
              <div class="h-full bg-white/60 rounded-full" style="width: 32.7%"></div>
            </div>
          </div>
          
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm text-white/60">Tablet</span>
              <span class="text-sm font-medium text-white">5.2%</span>
            </div>
            <div class="w-full h-2 bg-white/5 rounded-full overflow-hidden">
              <div class="h-full bg-white/30 rounded-full" style="width: 5.2%"></div>
            </div>
          </div>
        </div>

        <div class="mt-8 pt-6 border-t border-white/5">
          <div class="text-center">
            <p class="text-3xl font-semibold text-white mb-1">3.92%</p>
            <p class="text-xs text-white/40 uppercase tracking-wider">Overall Conversion</p>
          </div>
        </div>
      </div>

    </div>

    <!-- Top Products & Collections -->
    <div class="grid grid-cols-2 gap-6">
      
      <!-- Top Products -->
      <div class="bg-[#111113] border border-white/5 rounded-xl p-6">
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-lg font-semibold text-white">Top Products</h3>
          <button class="text-xs text-white/60 hover:text-white">View all</button>
        </div>
        
        <div class="space-y-4">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center text-sm font-medium text-white/60">1</div>
            <div class="flex-1">
              <p class="text-sm font-medium text-white">Artic 01 - Full Pack</p>
              <p class="text-xs text-white/40">1,256 sales</p>
            </div>
            <p class="text-sm font-medium text-white">$86,664</p>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center text-sm font-medium text-white/60">2</div>
            <div class="flex-1">
              <p class="text-sm font-medium text-white">Noctis Vol. 1 - Set 02</p>
              <p class="text-xs text-white/40">982 sales</p>
            </div>
            <p class="text-sm font-medium text-white">$87,398</p>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center text-sm font-medium text-white/60">3</div>
            <div class="flex-1">
              <p class="text-sm font-medium text-white">Puffer Series - Set 01</p>
              <p class="text-xs text-white/40">756 sales</p>
            </div>
            <p class="text-sm font-medium text-white">$21,924</p>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center text-sm font-medium text-white/60">4</div>
            <div class="flex-1">
              <p class="text-sm font-medium text-white">Shadow Line - Full Pack</p>
              <p class="text-xs text-white/40">623 sales</p>
            </div>
            <p class="text-sm font-medium text-white">$80,367</p>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center text-sm font-medium text-white/60">5</div>
            <div class="flex-1">
              <p class="text-sm font-medium text-white">Tech Edition - Set 03</p>
              <p class="text-xs text-white/40">531 sales</p>
            </div>
            <p class="text-sm font-medium text-white">$20,709</p>
          </div>
        </div>
      </div>

      <!-- Top Collections -->
      <div class="bg-[#111113] border border-white/5 rounded-xl p-6">
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-lg font-semibold text-white">Top Collections</h3>
          <button class="text-xs text-white/60 hover:text-white">View all</button>
        </div>
        
        <div class="space-y-4">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center text-sm font-medium text-white/60">1</div>
            <div class="flex-1">
              <p class="text-sm font-medium text-white">Artic 01</p>
              <p class="text-xs text-white/40">36% of total sales</p>
            </div>
            <p class="text-sm font-medium text-white">$89,210</p>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center text-sm font-medium text-white/60">2</div>
            <div class="flex-1">
              <p class="text-sm font-medium text-white">Noctis Vol. 1</p>
              <p class="text-xs text-white/40">26% of total sales</p>
            </div>
            <p class="text-sm font-medium text-white">$64,429</p>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center text-sm font-medium text-white/60">3</div>
            <div class="flex-1">
              <p class="text-sm font-medium text-white">Puffer Series</p>
              <p class="text-xs text-white/40">17% of total sales</p>
            </div>
            <p class="text-sm font-medium text-white">$42,127</p>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center text-sm font-medium text-white/60">4</div>
            <div class="flex-1">
              <p class="text-sm font-medium text-white">Shadow Line</p>
              <p class="text-xs text-white/40">12% of total sales</p>
            </div>
            <p class="text-sm font-medium text-white">$29,736</p>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center text-sm font-medium text-white/60">5</div>
            <div class="flex-1">
              <p class="text-sm font-medium text-white">Tech Edition</p>
              <p class="text-xs text-white/40">9% of total sales</p>
            </div>
            <p class="text-sm font-medium text-white">$22,303</p>
          </div>
        </div>
      </div>

    </div>

  </div>

</AdminLayout>
