---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Coupons" activePage="coupons">
  
  <!-- Top Bar -->
  <header class="bg-[#111113] border-b border-white/5 px-8 py-4 flex items-center justify-between sticky top-0 z-10">
    <div>
      <h1 class="text-2xl font-semibold text-white">Coupons</h1>
      <p class="text-sm text-white/40 mt-1">Manage discount codes</p>
    </div>
    <button onclick="document.getElementById('newCouponDrawer').classList.remove('translate-x-full')" class="bg-white text-black px-4 py-2 rounded-lg text-sm font-medium hover:bg-white/90 transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Coupon
    </button>
  </header>

  <!-- Content -->
  <div class="p-8">
    
    <!-- Filters -->
    <div class="bg-[#111113] border border-white/5 rounded-xl p-4 mb-6 flex items-center justify-between flex-wrap gap-4">
      <div class="flex items-center gap-4 flex-wrap">
        <div class="relative">
          <input type="text" placeholder="Search coupons..." class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 pl-10 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30 w-64">
          <svg class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
        
        <select class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-sm text-white focus:outline-none">
          <option>All Status</option>
          <option>Active</option>
          <option>Expired</option>
          <option>Disabled</option>
        </select>
      </div>
    </div>

    <!-- Coupons Table -->
    <div class="bg-[#111113] border border-white/5 rounded-xl overflow-hidden">
      <table class="w-full">
        <thead class="bg-white/5">
          <tr>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Code</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Discount</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Type</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Usage</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Valid Until</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Status</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          <tr class="hover:bg-white/5 transition-colors">
            <td class="py-4 px-6">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center">
                  <svg class="w-5 h-5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-mono font-medium text-white">WELCOME10</p>
                  <p class="text-xs text-white/40">New customers only</p>
                </div>
              </div>
            </td>
            <td class="py-4 px-6 text-sm font-medium text-white">10%</td>
            <td class="py-4 px-6"><span class="px-2 py-1 rounded-full bg-white/5 text-white/60 text-xs">Percentage</span></td>
            <td class="py-4 px-6 text-sm text-white/60">247 uses</td>
            <td class="py-4 px-6 text-sm text-white/60">31 Dec, 2026</td>
            <td class="py-4 px-6">
              <span class="px-3 py-1 rounded-full bg-green-500/10 text-green-400 text-xs font-medium">Active</span>
            </td>
            <td class="py-4 px-6">
              <button class="text-white/40 hover:text-white">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/></svg>
              </button>
            </td>
          </tr>

          <tr class="hover:bg-white/5 transition-colors">
            <td class="py-4 px-6">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center">
                  <svg class="w-5 h-5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-mono font-medium text-white">SUMMER20</p>
                  <p class="text-xs text-white/40">Summer collection</p>
                </div>
              </div>
            </td>
            <td class="py-4 px-6 text-sm font-medium text-white">$20.00</td>
            <td class="py-4 px-6"><span class="px-2 py-1 rounded-full bg-white/5 text-white/60 text-xs">Fixed Amount</span></td>
            <td class="py-4 px-6 text-sm text-white/60">89 uses</td>
            <td class="py-4 px-6 text-sm text-white/60">31 Mar, 2026</td>
            <td class="py-4 px-6">
              <span class="px-3 py-1 rounded-full bg-red-500/10 text-red-400 text-xs font-medium">Expired</span>
            </td>
            <td class="py-4 px-6">
              <button class="text-white/40 hover:text-white">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/></svg>
              </button>
            </td>
          </tr>

          <tr class="hover:bg-white/5 transition-colors">
            <td class="py-4 px-6">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center">
                  <svg class="w-5 h-5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                </div>
                <div>
                  <p class="text-sm font-mono font-medium text-white">VIP15</p>
                  <p class="text-xs text-white/40">VIP members</p>
                </div>
              </div>
            </td>
            <td class="py-4 px-6 text-sm font-medium text-white">15%</td>
            <td class="py-4 px-6"><span class="px-2 py-1 rounded-full bg-white/5 text-white/60 text-xs">Percentage</span></td>
            <td class="py-4 px-6 text-sm text-white/60">412 uses</td>
            <td class="py-4 px-6 text-sm text-white/60">No expiry</td>
            <td class="py-4 px-6">
              <span class="px-3 py-1 rounded-full bg-green-500/10 text-green-400 text-xs font-medium">Active</span>
            </td>
            <td class="py-4 px-6">
              <button class="text-white/40 hover:text-white">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/></svg>
              </button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

  </div>

  <!-- New Coupon Drawer -->
  <div id="newCouponDrawer" class="fixed inset-0 z-50 translate-x-full transition-transform duration-300">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="document.getElementById('newCouponDrawer').classList.add('translate-x-full')"></div>
    <div class="absolute right-0 top-0 h-full w-[500px] bg-[#111113] border-l border-white/5 overflow-y-auto">
      
      <div class="sticky top-0 bg-[#111113] border-b border-white/5 px-6 py-4 flex items-center justify-between z-10">
        <div>
          <h2 class="text-xl font-semibold text-white">New Coupon</h2>
          <p class="text-sm text-white/40 mt-1">Create a discount code</p>
        </div>
        <button onclick="document.getElementById('newCouponDrawer').classList.add('translate-x-full')" class="text-white/40 hover:text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <div class="p-6 space-y-6">
        <div>
          <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Coupon Code</label>
          <input type="text" placeholder="e.g., SUMMER25" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30 font-mono uppercase">
        </div>

        <div>
          <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Discount Type</label>
          <select class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:outline-none">
            <option>Percentage</option>
            <option>Fixed Amount</option>
            <option>Free Shipping</option>
          </select>
        </div>

        <div>
          <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Discount Value</label>
          <input type="number" placeholder="10" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30">
        </div>

        <div>
          <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Valid Until (Optional)</label>
          <input type="date" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:outline-none focus:border-white/30">
        </div>

        <div>
          <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Usage Limit (Optional)</label>
          <input type="number" placeholder="Unlimited" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30">
        </div>

        <div>
          <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Description</label>
          <textarea rows="3" placeholder="Describe this coupon..." class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30 resize-none"></textarea>
        </div>
      </div>

      <div class="sticky bottom-0 bg-[#111113] border-t border-white/5 px-6 py-4 flex items-center justify-between">
        <button class="text-sm text-white/60 hover:text-white">Save as Draft</button>
        <button class="bg-white text-black px-6 py-2 rounded-lg text-sm font-medium hover:bg-white/90 transition-colors">Create Coupon</button>
      </div>

    </div>
  </div>

</AdminLayout>
