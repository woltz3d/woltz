---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Customers" activePage="customers">
  
  <!-- Top Bar -->
  <header class="bg-[#111113] border-b border-white/5 px-8 py-4 flex items-center justify-between sticky top-0 z-10">
    <div>
      <h1 class="text-2xl font-semibold text-white">Customers</h1>
      <p class="text-sm text-white/40 mt-1">Manage your customer base</p>
    </div>
    <button class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm text-white hover:bg-white/10 transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
      Export
    </button>
  </header>

  <!-- Content -->
  <div class="p-8">
    
    <!-- Filters -->
    <div class="bg-[#111113] border border-white/5 rounded-xl p-4 mb-6 flex items-center justify-between flex-wrap gap-4">
      <div class="flex items-center gap-4 flex-wrap">
        <div class="relative">
          <input type="text" placeholder="Search customers..." class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 pl-10 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30 w-64">
          <svg class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
        
        <select class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-sm text-white focus:outline-none">
          <option>All Customers</option>
          <option>Active</option>
          <option>Inactive</option>
        </select>

        <select class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-sm text-white focus:outline-none">
          <option>Sort by: Total Spent</option>
          <option>Sort by: Name</option>
          <option>Sort by: Last Purchase</option>
        </select>
      </div>
    </div>

    <!-- Customers Table -->
    <div class="bg-[#111113] border border-white/5 rounded-xl overflow-hidden">
      <table class="w-full">
        <thead class="bg-white/5">
          <tr>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Customer</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Email</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Total Spent</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Orders</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Last Purchase</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Downloads</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          <tr class="hover:bg-white/5 transition-colors cursor-pointer" onclick="document.getElementById('customerDrawer').classList.remove('translate-x-full')">
            <td class="py-4 px-6">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center text-sm font-medium text-white">
                  JS
                </div>
                <div>
                  <p class="text-sm font-medium text-white">João Silva</p>
                  <p class="text-xs text-white/40">Since May 2026</p>
                </div>
              </div>
            </td>
            <td class="py-4 px-6 text-sm text-white/60">joao.silva@email.com</td>
            <td class="py-4 px-6 text-sm font-medium text-white">$247.00</td>
            <td class="py-4 px-6 text-sm text-white/60">4</td>
            <td class="py-4 px-6 text-sm text-white/60">30 Jun, 2026</td>
            <td class="py-4 px-6 text-sm text-white/60">12</td>
            <td class="py-4 px-6">
              <button class="text-white/40 hover:text-white">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/></svg>
              </button>
            </td>
          </tr>

          <tr class="hover:bg-white/5 transition-colors cursor-pointer" onclick="document.getElementById('customerDrawer').classList.remove('translate-x-full')">
            <td class="py-4 px-6">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-pink-500 to-rose-500 flex items-center justify-center text-sm font-medium text-white">
                  ML
                </div>
                <div>
                  <p class="text-sm font-medium text-white">Marina Lima</p>
                  <p class="text-xs text-white/40">Since May 2026</p>
                </div>
              </div>
            </td>
            <td class="py-4 px-6 text-sm text-white/60">marina.lima@email.com</td>
            <td class="py-4 px-6 text-sm font-medium text-white">R$ 458.00</td>
            <td class="py-4 px-6 text-sm text-white/60">6</td>
            <td class="py-4 px-6 text-sm text-white/60">30 Jun, 2026</td>
            <td class="py-4 px-6 text-sm text-white/60">18</td>
            <td class="py-4 px-6">
              <button class="text-white/40 hover:text-white">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/></svg>
              </button>
            </td>
          </tr>

          <tr class="hover:bg-white/5 transition-colors cursor-pointer" onclick="document.getElementById('customerDrawer').classList.remove('translate-x-full')">
            <td class="py-4 px-6">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-green-500 to-emerald-500 flex items-center justify-center text-sm font-medium text-white">
                  LS
                </div>
                <div>
                  <p class="text-sm font-medium text-white">Lucas Santos</p>
                  <p class="text-xs text-white/40">Since Jun 2026</p>
                </div>
              </div>
            </td>
            <td class="py-4 px-6 text-sm text-white/60">lucas@outlook.com</td>
            <td class="py-4 px-6 text-sm font-medium text-white">$89.00</td>
            <td class="py-4 px-6 text-sm text-white/60">2</td>
            <td class="py-4 px-6 text-sm text-white/60">29 Jun, 2026</td>
            <td class="py-4 px-6 text-sm text-white/60">5</td>
            <td class="py-4 px-6">
              <button class="text-white/40 hover:text-white">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/></svg>
              </button>
            </td>
          </tr>

          <tr class="hover:bg-white/5 transition-colors cursor-pointer" onclick="document.getElementById('customerDrawer').classList.remove('translate-x-full')">
            <td class="py-4 px-6">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-orange-500 to-amber-500 flex items-center justify-center text-sm font-medium text-white">
                  GC
                </div>
                <div>
                  <p class="text-sm font-medium text-white">Gabriel Costa</p>
                  <p class="text-xs text-white/40">Since May 2026</p>
                </div>
              </div>
            </td>
            <td class="py-4 px-6 text-sm text-white/60">gabriel@protonmail.com</td>
            <td class="py-4 px-6 text-sm font-medium text-white">R$ 312.00</td>
            <td class="py-4 px-6 text-sm text-white/60">5</td>
            <td class="py-4 px-6 text-sm text-white/60">29 Jun, 2026</td>
            <td class="py-4 px-6 text-sm text-white/60">14</td>
            <td class="py-4 px-6">
              <button class="text-white/40 hover:text-white">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/></svg>
              </button>
            </td>
          </tr>

          <tr class="hover:bg-white/5 transition-colors cursor-pointer" onclick="document.getElementById('customerDrawer').classList.remove('translate-x-full')">
            <td class="py-4 px-6">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-indigo-500 to-blue-500 flex items-center justify-center text-sm font-medium text-white">
                  AC
                </div>
                <div>
                  <p class="text-sm font-medium text-white">Ana Carolina</p>
                  <p class="text-xs text-white/40">Since Jun 2026</p>
                </div>
              </div>
            </td>
            <td class="py-4 px-6 text-sm text-white/60">ana.carol@icloud.com</td>
            <td class="py-4 px-6 text-sm font-medium text-white">$127.00</td>
            <td class="py-4 px-6 text-sm text-white/60">3</td>
            <td class="py-4 px-6 text-sm text-white/60">29 Jun, 2026</td>
            <td class="py-4 px-6 text-sm text-white/60">8</td>
            <td class="py-4 px-6">
              <button class="text-white/40 hover:text-white">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/></svg>
              </button>
            </td>
          </tr>
        </tbody>
      </table>

      <!-- Pagination -->
      <div class="px-6 py-4 border-t border-white/5 flex items-center justify-between">
        <p class="text-sm text-white/40">Showing 1 to 5 of 156 customers</p>
        <div class="flex items-center gap-2">
          <button class="px-3 py-1.5 rounded-lg bg-white/5 text-white/60 text-sm hover:bg-white/10 transition-colors">Previous</button>
          <button class="px-3 py-1.5 rounded-lg bg-white text-black text-sm font-medium">1</button>
          <button class="px-3 py-1.5 rounded-lg bg-white/5 text-white/60 text-sm hover:bg-white/10 transition-colors">2</button>
          <button class="px-3 py-1.5 rounded-lg bg-white/5 text-white/60 text-sm hover:bg-white/10 transition-colors">3</button>
          <span class="text-white/40">...</span>
          <button class="px-3 py-1.5 rounded-lg bg-white/5 text-white/60 text-sm hover:bg-white/10 transition-colors">32</button>
          <button class="px-3 py-1.5 rounded-lg bg-white/5 text-white/60 text-sm hover:bg-white/10 transition-colors">Next</button>
        </div>
      </div>
    </div>

  </div>

  <!-- Customer Details Drawer -->
  <div id="customerDrawer" class="fixed inset-0 z-50 translate-x-full transition-transform duration-300">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="document.getElementById('customerDrawer').classList.add('translate-x-full')"></div>
    <div class="absolute right-0 top-0 h-full w-[600px] bg-[#111113] border-l border-white/5 overflow-y-auto">
      
      <!-- Drawer Header -->
      <div class="sticky top-0 bg-[#111113] border-b border-white/5 px-6 py-4 flex items-center justify-between z-10">
        <div>
          <h2 class="text-xl font-semibold text-white">Customer Details</h2>
          <p class="text-sm text-white/40 mt-1">View complete customer information</p>
        </div>
        <button onclick="document.getElementById('customerDrawer').classList.add('translate-x-full')" class="text-white/40 hover:text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Drawer Content -->
      <div class="p-6 space-y-6">
        
        <!-- Customer Profile -->
        <div class="bg-white/5 rounded-xl p-6 border border-white/5">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-16 h-16 rounded-full bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center text-xl font-medium text-white">
              JS
            </div>
            <div>
              <h3 class="text-lg font-semibold text-white">João Silva</h3>
              <p class="text-sm text-white/40">Customer since May 2026</p>
            </div>
          </div>
          
          <div class="grid grid-cols-2 gap-4">
            <div>
              <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Email</p>
              <p class="text-sm text-white">joao.silva@email.com</p>
            </div>
            <div>
              <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Phone</p>
              <p class="text-sm text-white">+55 11 99999-9999</p>
            </div>
            <div>
              <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Total Spent</p>
              <p class="text-sm font-medium text-white">$247.00</p>
            </div>
            <div>
              <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Total Orders</p>
              <p class="text-sm font-medium text-white">4</p>
            </div>
          </div>
        </div>

        <!-- Purchase History -->
        <div class="bg-white/5 rounded-xl p-6 border border-white/5">
          <h3 class="text-sm font-medium text-white mb-4">Purchase History</h3>
          <div class="space-y-4">
            <div class="flex items-center justify-between p-3 bg-white/5 rounded-lg">
              <div>
                <p class="text-sm text-white">Artic 01 - Full Pack</p>
                <p class="text-xs text-white/40">30 Jun, 2026</p>
              </div>
              <div class="text-right">
                <p class="text-sm font-medium text-white">$69.00</p>
                <span class="px-2 py-1 rounded-full bg-green-500/10 text-green-400 text-xs">Paid</span>
              </div>
            </div>
            <div class="flex items-center justify-between p-3 bg-white/5 rounded-lg">
              <div>
                <p class="text-sm text-white">Noctis Vol. 1 - Set 01</p>
                <p class="text-xs text-white/40">15 Jun, 2026</p>
              </div>
              <div class="text-right">
                <p class="text-sm font-medium text-white">$89.00</p>
                <span class="px-2 py-1 rounded-full bg-green-500/10 text-green-400 text-xs">Paid</span>
              </div>
            </div>
            <div class="flex items-center justify-between p-3 bg-white/5 rounded-lg">
              <div>
                <p class="text-sm text-white">Puffer Series - Set 02</p>
                <p class="text-xs text-white/40">02 Jun, 2026</p>
              </div>
              <div class="text-right">
                <p class="text-sm font-medium text-white">$45.00</p>
                <span class="px-2 py-1 rounded-full bg-green-500/10 text-green-400 text-xs">Paid</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Downloads -->
        <div class="bg-white/5 rounded-xl p-6 border border-white/5">
          <h3 class="text-sm font-medium text-white mb-4">Downloads</h3>
          <div class="space-y-3">
            <div class="flex items-center justify-between p-3 bg-white/5 rounded-lg">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                <div>
                  <p class="text-sm text-white">Artic_01_Full_Pack.zip</p>
                  <p class="text-xs text-white/40">Downloaded 3 times</p>
                </div>
              </div>
              <button class="px-3 py-1.5 bg-white/10 rounded-lg text-xs text-white hover:bg-white/20 transition-colors">View</button>
            </div>
          </div>
        </div>

      </div>

      <!-- Drawer Footer -->
      <div class="sticky bottom-0 bg-[#111113] border-t border-white/5 px-6 py-4 flex items-center justify-between">
        <button class="text-sm text-red-400 hover:text-red-300 transition-colors">Block Customer</button>
        <button class="px-4 py-2 bg-white text-black rounded-lg text-sm font-medium hover:bg-white/90 transition-colors">Send Email</button>
      </div>

    </div>
  </div>

</AdminLayout>
