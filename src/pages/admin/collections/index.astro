---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Collections" activePage="collections">
  
  <!-- CSS Global para Selects Escuros -->
  <style is:global>
    select, option {
      background-color: rgba(255, 255, 255, 0.05) !important;
      color: white !important;
      border: 1px solid rgba(255, 255, 255, 0.1) !important;
    }
    select:focus, option:focus {
      border-color: rgba(255, 255, 255, 0.3) !important;
      outline: none !important;
    }
    /* Força options a terem fundo escuro no dropdown */
    select option {
      background-color: #111113 !important;
      color: white !important;
    }
  </style>

  <header class="bg-[#111113] border-b border-white/5 px-8 py-4 flex items-center justify-between sticky top-0 z-10">
    <div>
      <h1 class="text-2xl font-semibold text-white">Collections</h1>
      <p class="text-sm text-white/40 mt-1">Manage all your collections</p>
    </div>
    <button onclick="openDrawer()" class="bg-white text-black px-4 py-2 rounded-lg text-sm font-medium hover:bg-white/90 transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Collection
    </button>
  </header>

  <div class="p-8">
    <!-- Search -->
    <div class="bg-[#111113] border border-white/5 rounded-xl p-4 mb-6">
      <input type="text" id="searchInput" placeholder="Search collections..." class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 w-full text-sm text-white focus:outline-none focus:border-white/30">
    </div>

    <!-- Table -->
    <div class="bg-[#111113] border border-white/5 rounded-xl overflow-hidden min-h-[200px]" id="tableContainer">
      <p class="py-12 text-center text-white/40 animate-pulse">Loading collections...</p>
    </div>
  </div>

  <!-- DRAWER -->
  <div id="collectionDrawer" class="fixed inset-0 z-50 translate-x-full transition-transform duration-300">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeDrawer()"></div>
    <div class="absolute right-0 top-0 h-full w-[600px] bg-[#111113] border-l border-white/5 overflow-y-auto">
      
      <div class="sticky top-0 bg-[#111113] border-b border-white/5 px-6 py-4 flex items-center justify-between z-10">
        <h2 class="text-xl font-semibold text-white" id="drawerTitle">New Collection</h2>
        <button onclick="closeDrawer()" class="text-white/40 hover:text-white"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
      </div>

      <form id="collectionForm" class="p-6 space-y-8">
        <input type="hidden" name="id" id="collectionId">

        <!-- Info -->
        <div class="space-y-4">
          <h3 class="text-sm font-medium text-white border-b border-white/10 pb-2">Information</h3>
          <div>
            <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Collection Name *</label>
            <input type="text" name="name" required class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none">
          </div>
          <div>
            <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Slug *</label>
            <input type="text" name="slug" required class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none">
          </div>
          <div>
            <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Description</label>
            <textarea name="description" rows="3" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none resize-none"></textarea>
          </div>
          
          <!-- Category with Delete Button -->
          <div>
            <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Category</label>
            <div class="flex gap-2 items-center">
              <select name="category" id="categorySelect" class="flex-1 bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none appearance-none">
                <option value="">Select a category</option>
              </select>
              <button type="button" id="deleteCategoryBtn" class="hidden p-3 bg-red-500/10 text-red-400 rounded-lg hover:bg-red-500/20 transition-colors" title="Delete this category">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
              <button type="button" id="newCategoryToggle" class="px-3 py-3 bg-white/10 rounded-lg text-xs text-white hover:bg-white/20 whitespace-nowrap">+ New</button>
            </div>
            
            <!-- Input para nova categoria (oculto inicialmente) -->
            <div id="newCategoryWrapper" class="hidden mt-2 flex gap-2">
              <input type="text" id="newCategoryInput" placeholder="Type new category name..." class="flex-1 bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-sm text-white focus:border-white/30 focus:outline-none">
              <button type="button" id="saveNewCategoryBtn" class="px-3 py-2 bg-green-500/20 text-green-400 rounded-lg text-xs hover:bg-green-500/30">Save</button>
              <button type="button" id="cancelNewCategoryBtn" class="px-3 py-2 bg-white/10 text-white/60 rounded-lg text-xs hover:bg-white/20">Cancel</button>
            </div>
            <p class="text-[10px] text-white/40 mt-1">Categories are saved locally for this browser.</p>
          </div>
        </div>

        <!-- Media -->
        <div class="space-y-4">
          <h3 class="text-sm font-medium text-white border-b border-white/10 pb-2">Media</h3>
          <div>
            <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Featured Image URL</label>
            <input type="url" name="image_url" placeholder="https://..." class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none">
          </div>
          <div>
            <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Banner URL</label>
            <input type="url" name="banner_url" placeholder="https://..." class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none">
          </div>
        </div>

        <!-- Status -->
        <div class="space-y-4">
           <h3 class="text-sm font-medium text-white border-b border-white/10 pb-2">Status</h3>
           <select name="status" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none">
            <option value="draft">Draft</option>
            <option value="published">Published</option>
          </select>
        </div>

      </form>

      <div class="sticky bottom-0 bg-[#111113] border-t border-white/5 px-6 py-4 flex items-center justify-between">
        <button type="button" onclick="closeDrawer()" class="text-sm text-white/60 hover:text-white">Cancel</button>
        <button type="submit" form="collectionForm" id="submitBtn" class="bg-white text-black px-6 py-2 rounded-lg text-sm font-medium hover:bg-white/90">Save Collection</button>
      </div>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', async function() {
      const tableContainer = document.getElementById('tableContainer');
      const drawer = document.getElementById('collectionDrawer');
      const form = document.getElementById('collectionForm');
      const submitBtn = document.getElementById('submitBtn');
      const categorySelect = document.getElementById('categorySelect');
      const deleteCatBtn = document.getElementById('deleteCategoryBtn');
      const newCatToggle = document.getElementById('newCategoryToggle');
      const newCatWrapper = document.getElementById('newCategoryWrapper');
      const newCatInput = document.getElementById('newCategoryInput');
      const saveNewCatBtn = document.getElementById('saveNewCategoryBtn');
      const cancelNewCatBtn = document.getElementById('cancelNewCategoryBtn');
      
      let currentMode = 'create';
      let categoriesList = [];

      // --- GERENCIAMENTO DE CATEGORIAS ---
      function loadCategories() {
        const stored = localStorage.getItem('woltz_categories');
        categoriesList = stored ? JSON.parse(stored) : ['Winter', 'Summer', 'Limited'];
        renderCategoryOptions();
      }

      function renderCategoryOptions() {
        const currentVal = categorySelect.value;
        categorySelect.innerHTML = '<option value="">Select a category</option>';
        categoriesList.forEach(cat => {
          const opt = document.createElement('option');
          opt.value = cat;
          opt.innerText = cat;
          categorySelect.appendChild(opt);
        });
        // Restaura seleção se ainda existir
        if(categoriesList.includes(currentVal)) categorySelect.value = currentVal;
        
        // Mostra/esconde botão de deletar
        if(categorySelect.value) {
          deleteCatBtn.classList.remove('hidden');
        } else {
          deleteCatBtn.classList.add('hidden');
        }
      }

      // Toggle input de nova categoria
      newCatToggle.addEventListener('click', () => {
        newCatWrapper.classList.remove('hidden');
        newCatToggle.classList.add('hidden');
        categorySelect.classList.add('hidden');
        deleteCatBtn.classList.add('hidden');
        newCatInput.focus();
      });

      cancelNewCatBtn.addEventListener('click', () => {
        newCatWrapper.classList.add('hidden');
        newCatToggle.classList.remove('hidden');
        categorySelect.classList.remove('hidden');
        newCatInput.value = '';
        renderCategoryOptions(); // restaura visibilidade do delete btn
      });

      saveNewCatBtn.addEventListener('click', () => {
        const val = newCatInput.value.trim();
        if(val && !categoriesList.includes(val)) {
          categoriesList.push(val);
          localStorage.setItem('woltz_categories', JSON.stringify(categoriesList));
          renderCategoryOptions();
          categorySelect.value = val;
          deleteCatBtn.classList.remove('hidden');
        }
        // Reset UI
        newCatWrapper.classList.add('hidden');
        newCatToggle.classList.remove('hidden');
        categorySelect.classList.remove('hidden');
        newCatInput.value = '';
      });

      // Ao mudar seleção, mostra/esconde botão de deletar
      categorySelect.addEventListener('change', () => {
        if(categorySelect.value) {
          deleteCatBtn.classList.remove('hidden');
        } else {
          deleteCatBtn.classList.add('hidden');
        }
      });

      // Deletar categoria selecionada
      deleteCatBtn.addEventListener('click', () => {
        const val = categorySelect.value;
        if(!val) return;
        if(confirm(`Delete category "${val}"? This will remove it from future selections.`)) {
          categoriesList = categoriesList.filter(c => c !== val);
          localStorage.setItem('woltz_categories', JSON.stringify(categoriesList));
          categorySelect.value = "";
          renderCategoryOptions();
        }
      });

      // --- CRUD COLLECTIONS ---
      async function loadCollections() {
        try {
          const res = await fetch('/api/collections');
          if(!res.ok) throw new Error('Failed to load');
          const result = await res.json();
          const collections = result.data || [];

          if(collections.length === 0) {
            tableContainer.innerHTML = `<div class="py-12 text-center text-white/40">No collections found. Create your first!</div>`;
            return;
          }

          let html = `<table class="w-full"><thead class="bg-white/5"><tr>
            <th class="text-left text-xs text-white/40 uppercase py-4 px-6">Collection</th>
            <th class="text-left text-xs text-white/40 uppercase py-4 px-6">Category</th>
            <th class="text-left text-xs text-white/40 uppercase py-4 px-6">Status</th>
            <th class="text-right text-xs text-white/40 uppercase py-4 px-6">Actions</th>
          </tr></thead><tbody class="divide-y divide-white/5">`;

          collections.forEach(c => {
            const statusClass = c.status === 'published' ? 'text-green-400' : 'text-yellow-400';
            const imgUrl = c.image_url 
              ? `<img src="${c.image_url}" class="w-10 h-10 rounded object-cover bg-white/5">`
              : `<div class="w-10 h-10 rounded bg-white/5 flex items-center justify-center"><svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg></div>`;

            const safeJson = JSON.stringify(c).replace(/'/g, "&#39;");

            html += `<tr class="hover:bg-white/5 transition-colors">
              <td class="py-4 px-6"><div class="flex items-center gap-3">${imgUrl}<div><p class="text-sm font-medium text-white">${c.name}</p><p class="text-xs text-white/40">${c.description ? c.description.substring(0,30)+'...' : ''}</p></div></div></td>
              <td class="py-4 px-6 text-sm text-white/60">${c.category || '-'}</td>
              <td class="py-4 px-6 text-sm capitalize ${statusClass}">${c.status}</td>
              <td class="py-4 px-6 text-right">
                <button onclick='window.editCollection(${safeJson})' class="p-2 text-white/40 hover:text-blue-400 inline-block" title="Edit"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg></button>
                <button onclick="window.deleteCollection('${c.id}', '${c.name}')" class="p-2 text-white/40 hover:text-red-400 inline-block" title="Delete"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg></button>
              </td>
            </tr>`;
          });
          html += `</tbody></table>`;
          tableContainer.innerHTML = html;

        } catch(err) {
          console.error(err);
          tableContainer.innerHTML = `<div class="p-8 text-red-400">Error loading collections. Check API and Console.</div>`;
        }
      }

      // --- AÇÕES GLOBAIS ---
      window.openDrawer = () => {
        currentMode = 'create';
        document.getElementById('drawerTitle').innerText = 'New Collection';
        document.getElementById('submitBtn').innerText = 'Create Collection';
        form.reset();
        document.getElementById('collectionId').value = '';
        deleteCatBtn.classList.add('hidden');
        drawer.classList.remove('translate-x-full');
      };

      window.closeDrawer = () => {
        drawer.classList.add('translate-x-full');
        newCatWrapper.classList.add('hidden');
        newCatToggle.classList.remove('hidden');
        categorySelect.classList.remove('hidden');
      };

      window.editCollection = (c) => {
        currentMode = 'edit';
        document.getElementById('drawerTitle').innerText = 'Edit Collection';
        document.getElementById('submitBtn').innerText = 'Save Changes';
        
        document.getElementById('collectionId').value = c.id;
        form.name.value = c.name;
        form.slug.value = c.slug;
        form.description.value = c.description || '';
        form.category.value = c.category || '';
        form.image_url.value = c.image_url || '';
        form.banner_url.value = c.banner_url || '';
        form.status.value = c.status;
        
        // Atualiza visibilidade do botão de deletar categoria
        if(c.category) deleteCatBtn.classList.remove('hidden');
        else deleteCatBtn.classList.add('hidden');
        
        drawer.classList.remove('translate-x-full');
      };

      window.deleteCollection = async (id, name) => {
        if(!confirm(`Are you sure you want to delete "${name}"? This cannot be undone.`)) return;
        try {
          const res = await fetch(`/api/collections?id=${id}`, { method: 'DELETE' });
          if(!res.ok) {
             const errData = await res.json();
             throw new Error(errData.error || 'Delete failed');
          }
          alert('Collection deleted!');
          loadCollections();
        } catch(e) { 
          console.error(e);
          alert('Error deleting: ' + e.message); 
        }
      };

      // --- SUBMIT FORM ---
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const originalText = submitBtn.innerText;
        submitBtn.innerText = 'Saving...';
        submitBtn.disabled = true;

        const fd = new FormData(form);
        const data = {};
        fd.forEach((v,k) => data[k] = v);
        
        // Se houver valor no input de nova categoria (caso usuário tenha digitado e clicado em Save mas não selecionou no dropdown)
        // Na verdade, nosso fluxo salva no array e seleciona no dropdown, então data.category já estará correto.
        // Mas vamos garantir:
        if (!data.category && newCatInput.value.trim()) {
             data.category = newCatInput.value.trim();
        }

        const id = document.getElementById('collectionId').value;
        const method = id ? 'PUT' : 'POST';
        const url = id ? `/api/collections?id=${id}` : '/api/collections';

        try {
          const res = await fetch(url, { 
            method, 
            headers: {'Content-Type':'application/json'}, 
            body: JSON.stringify(data) 
          });
          
          const result = await res.json();
          
          if(res.ok) {
            alert(id ? 'Collection updated!' : 'Collection created!');
            closeDrawer();
            loadCollections();
          } else {
            alert('Error: ' + (result.error || 'Unknown error'));
          }
        } catch(err) { 
          console.error(err);
          alert('Connection error. Check console.'); 
        }
        finally {
          submitBtn.innerText = originalText;
          submitBtn.disabled = false;
        }
      });

      // Inicialização
      loadCategories();
      loadCollections();
      
      // Busca visual
      document.getElementById('searchInput')?.addEventListener('input', (e) => {
        const term = e.target.value.toLowerCase();
        document.querySelectorAll('tbody tr').forEach(row => {
          row.style.display = row.textContent.toLowerCase().includes(term) ? '' : 'none';
        });
      });
    });
  </script>
</AdminLayout>
