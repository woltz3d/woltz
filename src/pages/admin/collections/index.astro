---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';

const SUPABASE_URL = import.meta.env.SUPABASE_URL;
const SUPABASE_ANON_KEY = import.meta.env.SUPABASE_ANON_KEY;
---

<AdminLayout title="Collections" activePage="collections">
  
  <style is:global>
    select, option { background-color: #111113 !important; color: white !important; border: 1px solid rgba(255,255,255,0.1) !important; }
    select:focus { border-color: rgba(255,255,255,0.3) !important; outline: none !important; }
    .file-upload-zone { border: 2px dashed rgba(255,255,255,0.2); transition: all 0.3s ease; cursor: pointer; }
    .file-upload-zone:hover { border-color: white; background-color: rgba(255,255,255,0.05); }
    .upload-progress { height: 3px; background: linear-gradient(90deg, #3b82f6, #8b5cf6); transition: width 0.3s ease; }
  </style>

  <div id="app-config" data-supabase-url={SUPABASE_URL} data-supabase-key={SUPABASE_ANON_KEY} style="display:none;"></div>

  <header class="bg-[#111113] border-b border-white/5 px-8 py-4 flex items-center justify-between sticky top-0 z-10">
    <div>
      <h1 class="text-2xl font-semibold text-white">Collections</h1>
      <p class="text-sm text-white/40 mt-1">Manage collections and view pack pricing</p>
    </div>
    <button onclick="window.openDrawer()" class="bg-white text-black px-4 py-2 rounded-lg text-sm font-medium hover:bg-white/90 transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Collection
    </button>
  </header>

  <div class="p-8">
    <div class="bg-[#111113] border border-white/5 rounded-xl p-4 mb-6">
      <input type="text" id="searchInput" placeholder="Search collections..." class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 w-full text-sm text-white focus:outline-none focus:border-white/30">
    </div>

    <div class="bg-[#111113] border border-white/5 rounded-xl overflow-hidden min-h-[200px]" id="tableContainer">
      <p class="py-12 text-center text-white/40 animate-pulse">Loading collections...</p>
    </div>
  </div>

  <!-- DRAWER DE CRIAÇÃO/EDIÇÃO (Mantido igual ao anterior) -->
  <div id="collectionDrawer" class="fixed inset-0 z-50 translate-x-full transition-transform duration-300">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="window.closeDrawer()"></div>
    <div class="absolute right-0 top-0 h-full w-[600px] bg-[#111113] border-l border-white/5 overflow-y-auto">
      <div class="sticky top-0 bg-[#111113] border-b border-white/5 px-6 py-4 flex items-center justify-between z-10">
        <h2 class="text-xl font-semibold text-white" id="drawerTitle">New Collection</h2>
        <button onclick="window.closeDrawer()" class="text-white/40 hover:text-white"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
      </div>

      <form id="collectionForm" class="p-6 space-y-8">
        <input type="hidden" name="id" id="collectionId">
        
        <div class="space-y-4">
          <h3 class="text-sm font-medium text-white border-b border-white/10 pb-2">Information</h3>
          <div><label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Collection Name *</label><input type="text" name="name" required class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none"></div>
          <div><label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Slug *</label><input type="text" name="slug" required class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none"></div>
          <div><label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Description</label><textarea name="description" rows="3" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none resize-none"></textarea></div>
          
          <div>
            <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Category</label>
            <div class="flex gap-2 items-center">
              <select name="category" id="categorySelect" class="flex-1 bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none"><option value="">Select a category</option></select>
              <button type="button" id="deleteCategoryBtn" class="hidden p-3 bg-red-500/10 text-red-400 rounded-lg hover:bg-red-500/20" title="Delete category"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
              <button type="button" id="newCategoryToggle" class="px-3 py-3 bg-white/10 rounded-lg text-xs text-white hover:bg-white/20">+ New</button>
            </div>
            <div id="newCategoryWrapper" class="hidden mt-2 flex gap-2">
              <input type="text" id="newCategoryInput" placeholder="New category name..." class="flex-1 bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-sm text-white focus:border-white/30 focus:outline-none">
              <button type="button" id="saveNewCategoryBtn" class="px-3 py-2 bg-green-500/20 text-green-400 rounded-lg text-xs">Save</button>
              <button type="button" id="cancelNewCategoryBtn" class="px-3 py-2 bg-white/10 text-white/60 rounded-lg text-xs">Cancel</button>
            </div>
          </div>
        </div>

        <div class="space-y-6">
          <h3 class="text-sm font-medium text-white border-b border-white/10 pb-2">Media</h3>
          <div>
            <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Featured Image</label>
            <div class="file-upload-zone rounded-lg p-6 text-center relative h-32 flex flex-col items-center justify-center" id="featuredDropZone">
              <input type="file" id="featuredFileInput" accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer">
              <div id="featuredPreview" class="hidden absolute inset-0 p-2"><img src="" class="w-full h-full object-cover rounded"></div>
              <div id="featuredPlaceholder" class="text-center pointer-events-none">
                <svg class="w-8 h-8 text-white/40 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                <p class="text-xs text-white/50">Click to upload featured image</p>
              </div>
            </div>
            <input type="hidden" name="image_url" id="featuredUrlInput">
          </div>
          <div>
            <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Banner Image</label>
            <div class="file-upload-zone rounded-lg p-6 text-center relative h-32 flex flex-col items-center justify-center" id="bannerDropZone">
              <input type="file" id="bannerFileInput" accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer">
              <div id="bannerPreview" class="hidden absolute inset-0 p-2"><img src="" class="w-full h-full object-cover rounded"></div>
              <div id="bannerPlaceholder" class="text-center pointer-events-none">
                <svg class="w-8 h-8 text-white/40 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                <p class="text-xs text-white/50">Click to upload banner image</p>
              </div>
            </div>
            <input type="hidden" name="banner_url" id="bannerUrlInput">
          </div>
        </div>

        <div class="space-y-4">
           <h3 class="text-sm font-medium text-white border-b border-white/10 pb-2">Status</h3>
           <select name="status" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none">
            <option value="draft">Draft</option>
            <option value="published">Published</option>
          </select>
        </div>
      </form>

      <div class="sticky bottom-0 bg-[#111113] border-t border-white/5 px-6 py-4 flex items-center justify-between">
        <button type="button" onclick="window.closeDrawer()" class="text-sm text-white/60 hover:text-white">Cancel</button>
        <button type="submit" form="collectionForm" id="submitBtn" class="bg-white text-black px-6 py-2 rounded-lg text-sm font-medium hover:bg-white/90">Save Collection</button>
      </div>
    </div>
  </div>

  <script type="module">
    import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';

    const configEl = document.getElementById('app-config');
    const supabase = createClient(configEl?.dataset.supabaseUrl, configEl?.dataset.supabaseKey);

    const tableContainer = document.getElementById('tableContainer');
    const drawer = document.getElementById('collectionDrawer');
    const form = document.getElementById('collectionForm');
    const submitBtn = document.getElementById('submitBtn');
    const categorySelect = document.getElementById('categorySelect');
    const deleteCatBtn = document.getElementById('deleteCategoryBtn');
    const newCatToggle = document.getElementById('newCategoryToggle');
    const newCatWrapper = document.getElementById('newCategoryWrapper');
    const newCatInput = document.getElementById('newCategoryInput');
    
    let currentMode = 'create';
    let categoriesList = [];
    let uploadingFeatured = false;
    let uploadingBanner = false;

    // --- CATEGORIAS (LocalStorage) ---
    function loadCategories() {
      const stored = localStorage.getItem('woltz_categories');
      categoriesList = stored ? JSON.parse(stored) : ['Winter', 'Summer', 'Limited'];
      renderCategoryOptions();
    }

    function renderCategoryOptions() {
      const currentVal = categorySelect.value;
      categorySelect.innerHTML = '<option value="">Select a category</option>';
      categoriesList.forEach(cat => {
        const opt = document.createElement('option');
        opt.value = cat; opt.innerText = cat;
        categorySelect.appendChild(opt);
      });
      if(categoriesList.includes(currentVal)) categorySelect.value = currentVal;
      deleteCatBtn.classList.toggle('hidden', !categorySelect.value);
    }

    newCatToggle.addEventListener('click', () => {
      newCatWrapper.classList.remove('hidden'); newCatToggle.classList.add('hidden');
      categorySelect.classList.add('hidden'); deleteCatBtn.classList.add('hidden');
      newCatInput.focus();
    });

    document.getElementById('cancelNewCategoryBtn')?.addEventListener('click', () => {
      newCatWrapper.classList.add('hidden'); newCatToggle.classList.remove('hidden');
      categorySelect.classList.remove('hidden'); newCatInput.value = '';
      renderCategoryOptions();
    });

    document.getElementById('saveNewCategoryBtn')?.addEventListener('click', () => {
      const val = newCatInput.value.trim();
      if(val && !categoriesList.includes(val)) {
        categoriesList.push(val);
        localStorage.setItem('woltz_categories', JSON.stringify(categoriesList));
        renderCategoryOptions();
        categorySelect.value = val;
        deleteCatBtn.classList.remove('hidden');
      }
      newCatWrapper.classList.add('hidden'); newCatToggle.classList.remove('hidden');
      categorySelect.classList.remove('hidden'); newCatInput.value = '';
    });

    categorySelect.addEventListener('change', () => deleteCatBtn.classList.toggle('hidden', !categorySelect.value));
    
    deleteCatBtn.addEventListener('click', () => {
      const val = categorySelect.value;
      if(!val || !confirm(`Delete "${val}"?`)) return;
      categoriesList = categoriesList.filter(c => c !== val);
      localStorage.setItem('woltz_categories', JSON.stringify(categoriesList));
      categorySelect.value = "";
      renderCategoryOptions();
    });

    // --- UPLOADS ---
    async function uploadToSupabase(file, bucket = 'woltz-images') {
      const fileName = `${Date.now()}-${file.name.replace(/[^a-zA-Z0-9.-]/g, '-')}`;
      const { error } = await supabase.storage.from(bucket).upload(fileName, file, { cacheControl: '3600' });
      if (error) throw error;
      const { data } = supabase.storage.from(bucket).getPublicUrl(fileName);
      return data.publicUrl;
    }

    function setupUpload(inputId, dropZoneId, previewId, placeholderId, urlInputId, setUploadingFlag) {
      const input = document.getElementById(inputId);
      const dropZone = document.getElementById(dropZoneId);
      const preview = document.getElementById(previewId);
      const placeholder = document.getElementById(placeholderId);
      const urlInput = document.getElementById(urlInputId);

      input?.addEventListener('change', async (e) => {
        const file = e.target.files?.[0];
        if (!file) return;
        
        const reader = new FileReader();
        reader.onload = (ev) => {
          preview.querySelector('img').src = ev.target.result;
          preview.classList.remove('hidden');
          placeholder.classList.add('hidden');
        };
        reader.readAsDataURL(file);

        try {
          setUploadingFlag(true);
          const url = await uploadToSupabase(file);
          urlInput.value = url;
        } catch(err) { alert('Upload failed: ' + err.message); }
        finally { setUploadingFlag(false); }
      });
    }

    setupUpload('featuredFileInput', 'featuredDropZone', 'featuredPreview', 'featuredPlaceholder', 'featuredUrlInput', (v) => uploadingFeatured = v);
    setupUpload('bannerFileInput', 'bannerDropZone', 'bannerPreview', 'bannerPlaceholder', 'bannerUrlInput', (v) => uploadingBanner = v);

    // --- CRUD COLLECTIONS COM CÁLCULOS EM TEMPO REAL ---
    async function loadCollections() {
      try {
        // Busca coleções básicas
        const res = await fetch('/api/collections');
        if(!res.ok) throw new Error('Failed');
        const result = await res.json();
        const collections = result.data || [];

        if(collections.length === 0) {
          tableContainer.innerHTML = `<div class="py-12 text-center text-white/40">No collections found.</div>`;
          return;
        }

        // Para cada coleção, busca produtos para calcular totais
        const enrichedCollections = await Promise.all(collections.map(async (col) => {
          const { data: products } = await supabase
            .from('products')
            .select('price_brl, price_usd, net_brl')
            .eq('collection_id', col.id)
            .eq('status', 'published');

          const count = products?.length || 0;
          const totalBrl = products?.reduce((sum, p) => sum + (parseFloat(p.price_brl) || 0), 0) || 0;
          const totalUsd = products?.reduce((sum, p) => sum + (parseFloat(p.price_usd) || 0), 0) || 0;
          const estNet = products?.reduce((sum, p) => sum + (parseFloat(p.net_brl) || 0), 0) || 0;

          return {
            ...col,
            product_count: count,
            pack_price_brl: (totalBrl * 0.85).toFixed(2),
            pack_price_usd: (totalUsd * 0.85).toFixed(2),
            estimated_net_brl: estNet.toFixed(2)
          };
        }));

        let html = `<table class="w-full"><thead class="bg-white/5"><tr>
          <th class="text-left text-xs text-white/40 uppercase py-4 px-6">Collection</th>
          <th class="text-center text-xs text-white/40 uppercase py-4 px-6">Products</th>
          <th class="text-left text-xs text-white/40 uppercase py-4 px-6">Pack Price</th>
          <th class="text-left text-xs text-white/40 uppercase py-4 px-6">Est. Net (BRL)</th>
          <th class="text-left text-xs text-white/40 uppercase py-4 px-6">Status</th>
          <th class="text-right text-xs text-white/40 uppercase py-4 px-6">Actions</th>
        </tr></thead><tbody class="divide-y divide-white/5">`;

        enrichedCollections.forEach(c => {
          const statusClass = c.status === 'published' ? 'text-green-400' : 'text-yellow-400';
          const imgUrl = c.image_url 
            ? `<img src="${c.image_url}?width=100&quality=80" class="w-10 h-10 rounded object-cover bg-white/5">`
            : `<div class="w-10 h-10 rounded bg-white/5 flex items-center justify-center"><svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg></div>`;

          const safeJson = JSON.stringify(c).replace(/'/g, "&#39;");

          html += `<tr class="hover:bg-white/5 transition-colors">
            <td class="py-4 px-6"><div class="flex items-center gap-3">${imgUrl}<div><p class="text-sm font-medium text-white">${c.name}</p><p class="text-xs text-white/40">${c.category || 'No category'}</p></div></div></td>
            <td class="py-4 px-6 text-center"><span class="px-2 py-1 rounded-full bg-white/10 text-xs text-white">${c.product_count || 0}</span></td>
            <td class="py-4 px-6">
              <div class="text-sm text-white font-mono">R$ ${Number(c.pack_price_brl || 0).toFixed(2).replace('.', ',')}</div>
              <div class="text-xs text-white/40 font-mono">$ ${Number(c.pack_price_usd || 0).toFixed(2)}</div>
            </td>
            <td class="py-4 px-6 text-sm text-green-400 font-mono">R$ ${Number(c.estimated_net_brl || 0).toFixed(2).replace('.', ',')}</td>
            <td class="py-4 px-6 text-sm capitalize ${statusClass}">${c.status}</td>
            <td class="py-4 px-6 text-right space-x-1">
              <button onclick="window.viewProducts('${c.id}', '${c.name}')" class="p-2 text-blue-400 hover:text-blue-300 inline-block" title="View Products">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
              </button>
              <button onclick='window.editCollection(${safeJson})' class="p-2 text-white/40 hover:text-blue-400 inline-block" title="Edit"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg></button>
              <button onclick="window.deleteCollection('${c.id}', '${c.name}')" class="p-2 text-white/40 hover:text-red-400 inline-block" title="Delete"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg></button>
            </td>
          </tr>`;
        });
        html += `</tbody></table>`;
        tableContainer.innerHTML = html;

      } catch(err) {
        console.error(err);
        tableContainer.innerHTML = `<div class="p-8 text-red-400">Error loading collections.</div>`;
      }
    }

    window.openDrawer = () => {
      currentMode = 'create';
      document.getElementById('drawerTitle').innerText = 'New Collection';
      document.getElementById('submitBtn').innerText = 'Create Collection';
      form.reset();
      document.getElementById('collectionId').value = '';
      featuredPreview.classList.add('hidden'); featuredPlaceholder.classList.remove('hidden'); featuredUrlInput.value = '';
      bannerPreview.classList.add('hidden'); bannerPlaceholder.classList.remove('hidden'); bannerUrlInput.value = '';
      deleteCatBtn.classList.add('hidden');
      drawer.classList.remove('translate-x-full');
    };

    window.closeDrawer = () => {
      drawer.classList.add('translate-x-full');
      newCatWrapper.classList.add('hidden'); newCatToggle.classList.remove('hidden'); categorySelect.classList.remove('hidden');
    };

    window.editCollection = (c) => {
      currentMode = 'edit';
      document.getElementById('drawerTitle').innerText = 'Edit Collection';
      document.getElementById('submitBtn').innerText = 'Save Changes';
      
      document.getElementById('collectionId').value = c.id;
      form.name.value = c.name; form.slug.value = c.slug; form.description.value = c.description || '';
      form.category.value = c.category || ''; form.status.value = c.status;
      
      if(c.image_url) {
        featuredUrlInput.value = c.image_url;
        featuredPreview.querySelector('img').src = c.image_url;
        featuredPreview.classList.remove('hidden'); featuredPlaceholder.classList.add('hidden');
      } else {
        featuredUrlInput.value = '';
        featuredPreview.classList.add('hidden'); featuredPlaceholder.classList.remove('hidden');
      }
      
      if(c.banner_url) {
        bannerUrlInput.value = c.banner_url;
        bannerPreview.querySelector('img').src = c.banner_url;
        bannerPreview.classList.remove('hidden'); bannerPlaceholder.classList.add('hidden');
      } else {
        bannerUrlInput.value = '';
        bannerPreview.classList.add('hidden'); bannerPlaceholder.classList.remove('hidden');
      }
      
      deleteCatBtn.classList.toggle('hidden', !c.category);
      drawer.classList.remove('translate-x-full');
    };

    window.deleteCollection = async (id, name) => {
      if(!confirm(`Delete "${name}"?`)) return;
      try {
        const res = await fetch(`/api/collections?id=${id}`, { method: 'DELETE' });
        if(!res.ok) throw new Error('Delete failed');
        alert('Deleted!'); loadCollections();
      } catch(e) { alert('Error: ' + e.message); }
    };

    window.viewProducts = (collectionId, collectionName) => {
      window.location.href = `/admin/products/?collection=${collectionId}&name=${encodeURIComponent(collectionName)}`;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if(uploadingFeatured || uploadingBanner) { alert('Please wait for uploads!'); return; }
      
      const originalText = submitBtn.innerText;
      submitBtn.innerText = 'Saving...'; submitBtn.disabled = true;

      const fd = new FormData(form);
      const data = {};
      fd.forEach((v,k) => data[k] = v);
      Object.keys(data).forEach(key => { if(data[key] === "") data[key] = null; });

      const id = document.getElementById('collectionId').value;
      const method = id ? 'PUT' : 'POST';
      const url = id ? `/api/collections?id=${id}` : '/api/collections';

      try {
        const res = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify(data) });
        const result = await res.json();
        if(res.ok) {
          alert(id ? 'Updated!' : 'Created!');
          closeDrawer();
          loadCollections();
        } else {
          alert('Error: ' + (result.error || 'Unknown'));
        }
      } catch(err) { alert('Connection error'); }
      finally {
        submitBtn.innerText = originalText; submitBtn.disabled = false;
      }
    });

    loadCategories();
    loadCollections();
    
    document.getElementById('searchInput')?.addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      document.querySelectorAll('tbody tr').forEach(row => row.style.display = row.textContent.toLowerCase().includes(term) ? '' : 'none');
    });
  </script>
</AdminLayout>
