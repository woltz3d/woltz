---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Orders" activePage="orders">
  
  <!-- Top Bar -->
  <header class="bg-[#111113] border-b border-white/5 px-8 py-4 flex items-center justify-between sticky top-0 z-10">
    <div>
      <h1 class="text-2xl font-semibold text-white">Orders</h1>
      <p class="text-sm text-white/40 mt-1">Manage all customer orders</p>
    </div>
    <div class="flex items-center gap-3">
      <button class="px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-sm text-white hover:bg-white/10 transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Export
      </button>
    </div>
  </header>

  <!-- Content -->
  <div class="p-8">
    
    <!-- Filters -->
    <div class="bg-[#111113] border border-white/5 rounded-xl p-4 mb-6 flex items-center justify-between flex-wrap gap-4">
      <div class="flex items-center gap-4 flex-wrap">
        <div class="relative">
          <input type="text" placeholder="Search orders..." class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 pl-10 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30 w-64">
          <svg class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
        
        <!-- Time Filter -->
        <select class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-sm text-white focus:outline-none">
          <option>All Time</option>
          <option>Today</option>
          <option>This Week</option>
          <option>This Month</option>
          <option>This Year</option>
        </select>

        <!-- Status Filter -->
        <select class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-sm text-white focus:outline-none">
          <option>All Status</option>
          <option>Paid</option>
          <option>Pending</option>
          <option>Refunded</option>
          <option>Failed</option>
        </select>

        <!-- Currency Filter -->
        <select class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-sm text-white focus:outline-none">
          <option>All Currencies</option>
          <option>BRL</option>
          <option>USD</option>
        </select>
      </div>
      
      <div class="flex items-center gap-2">
        <button class="px-4 py-2 text-sm text-white/60 hover:text-white transition-colors">Filter</button>
        <button class="px-4 py-2 text-sm text-white/60 hover:text-white transition-colors">Sort</button>
      </div>
    </div>

    <!-- Orders Table -->
    <div class="bg-[#111113] border border-white/5 rounded-xl overflow-hidden">
      <table class="w-full">
        <thead class="bg-white/5">
          <tr>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Order ID</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Customer</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Products</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Collection</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Value</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Currency</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Status</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Date</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          <tr class="hover:bg-white/5 transition-colors cursor-pointer" onclick="document.getElementById('orderDrawer').classList.remove('translate-x-full')">
            <td class="py-4 px-6">
              <span class="text-sm font-mono text-white">#10234</span>
            </td>
            <td class="py-4 px-6">
              <div>
                <p class="text-sm text-white">João Silva</p>
                <p class="text-xs text-white/40">joao.silva@email.com</p>
              </div>
            </td>
            <td class="py-4 px-6 text-sm text-white/60">Artic 01 - Full Pack</td>
            <td class="py-4 px-6 text-sm text-white/60">Artic 01</td>
            <td class="py-4 px-6 text-sm font-medium text-white">$69.00</td>
            <td class="py-4 px-6">
              <span class="px-2 py-1 rounded bg-white/5 text-xs text-white/60">USD</span>
            </td>
            <td class="py-4 px-6">
              <span class="px-3 py-1 rounded-full bg-green-500/10 text-green-400 text-xs font-medium">Paid</span>
            </td>
            <td class="py-4 px-6 text-sm text-white/60">30 Jun, 2026</td>
            <td class="py-4 px-6">
              <button class="text-white/40 hover:text-white">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/></svg>
              </button>
            </td>
          </tr>

          <tr class="hover:bg-white/5 transition-colors cursor-pointer" onclick="document.getElementById('orderDrawer').classList.remove('translate-x-full')">
            <td class="py-4 px-6">
