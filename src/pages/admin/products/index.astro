---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Products" activePage="products">
  
  <!-- Top Bar -->
  <header class="bg-[#111113] border-b border-white/5 px-8 py-4 flex items-center justify-between sticky top-0 z-10">
    <div>
      <h1 class="text-2xl font-semibold text-white">Products</h1>
      <p class="text-sm text-white/40 mt-1">Manage your products and sets</p>
    </div>
    <button onclick="document.getElementById('newProductDrawer').classList.remove('translate-x-full')" class="bg-white text-black px-4 py-2 rounded-lg text-sm font-medium hover:bg-white/90 transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Product
    </button>
  </header>

  <!-- Content -->
  <div class="p-8">
    
    <!-- Filters -->
    <div class="bg-[#111113] border border-white/5 rounded-xl p-4 mb-6 flex items-center justify-between">
      <div class="flex items-center gap-4">
        <div class="relative">
          <input type="text" placeholder="Search products..." class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 pl-10 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30 w-64">
          <svg class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
        <select class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-sm text-white focus:outline-none">
          <option>All Collections</option>
          <option>Artic 01</option>
          <option>Noctis Vol. 1</option>
          <option>Puffer Series</option>
        </select>
      </div>
      <div class="flex items-center gap-2">
        <button class="px-4 py-2 text-sm text-white/60 hover:text-white transition-colors">Filter</button>
        <button class="px-4 py-2 text-sm text-white/60 hover:text-white transition-colors">Sort</button>
      </div>
    </div>

    <!-- Products Table -->
    <div class="bg-[#111113] border border-white/5 rounded-xl overflow-hidden">
      <table class="w-full">
        <thead class="bg-white/5">
          <tr>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Product</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Collection</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Type</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Price (BRL)</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Price (USD)</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Sales</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Status</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Date</th>
            <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          <tr class="hover:bg-white/5 transition-colors">
            <td class="py-4 px-6">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center">
                  <svg class="w-6 h-6 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-white">Set 01 - Arctic</p>
                  <p class="text-xs text-white/40">Pants, Shirt, Bag, Shoes</p>
                </div>
              </div>
            </td>
            <td class="py-4 px-6 text-sm text-white/60">Artic 01</td>
            <td class="py-4 px-6"><span class="px-2 py-1 rounded-full bg-white/5 text-white/60 text-xs">Set</span></td>
            <td class="py-4 px-6 text-sm text-white">R$ 89,90</td>
            <td class="py-4 px-6 text-sm text-white">$ 17,90</td>
            <td class="py-4 px-6 text-sm text-white/60">456</td>
            <td class="py-4 px-6"><span class="px-2 py-1 rounded-full bg-green-500/10 text-green-400 text-xs">Published</span></td>
            <td class="py-4 px-6 text-sm text-white/60">28/05/2026</td>
            <td class="py-4 px-6">
              <button class="text-white/40 hover:text-white">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/></svg>
              </button>
            </td>
          </tr>
          <tr class="hover:bg-white/5 transition-colors">
            <td class="py-4 px-6">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center">
                  <svg class="w-6 h-6 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-white">Set 02 - Arctic</p>
                  <p class="text-xs text-white/40">Dress, Earring, Sneakers</p>
                </div>
              </div>
            </td>
            <td class="py-4 px-6 text-sm text-white/60">Artic 01</td>
            <td class="py-4 px-6"><span class="px-2 py-1 rounded-full bg-white/5 text-white/60 text-xs">Set</span></td>
            <td class="py-4 px-6 text-sm text-white">R$ 89,90</td>
            <td class="py-4 px-6 text-sm text-white">$ 17,90</td>
            <td class="py-4 px-6 text-sm text-white/60">412</td>
            <td class="py-4 px-6"><span class="px-2 py-1 rounded-full bg-green-500/10 text-green-400 text-xs">Published</span></td>
            <td class="py-4 px-6 text-sm text-white/60">28/05/2026</td>
            <td class="py-4 px-6">
              <button class="text-white/40 hover:text-white">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/></svg>
              </button>
            </td>
          </tr>
          <tr class="hover:bg-white/5 transition-colors">
            <td class="py-4 px-6">
              <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center">
                  <svg class="w-6 h-6 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-white">Puffer Jacket 3D</p>
                  <p class="text-xs text-white/40">Puffer Jacket</p>
                </div>
              </div>
            </td>
            <td class="py-4 px-6 text-sm text-white/60">Puffer Series</td>
            <td class="py-4 px-6"><span class="px-2 py-1 rounded-full bg-white/5 text-white/60 text-xs">Item</span></td>
            <td class="py-4 px-6 text-sm text-white">R$ 79,90</td>
            <td class="py-4 px-6 text-sm text-white">$ 15,90</td>
            <td class="py-4 px-6 text-sm text-white/60">623</td>
            <td class="py-4 px-6"><span class="px-2 py-1 rounded-full bg-green-500/10 text-green-400 text-xs">Published</span></td>
            <td class="py-4 px-6 text-sm text-white/60">12/05/2026</td>
            <td class="py-4 px-6">
              <button class="text-white/40 hover:text-white">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/></svg>
              </button>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

  </div>

  <!-- New Product Drawer -->
  <div id="newProductDrawer" class="fixed inset-0 z-50 translate-x-full transition-transform duration-300">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="document.getElementById('newProductDrawer').classList.add('translate-x-full')"></div>
    <div class="absolute right-0 top-0 h-full w-[600px] bg-[#111113] border-l border-white/5 overflow-y-auto">
      
      <!-- Drawer Header -->
      <div class="sticky top-0 bg-[#111113] border-b border-white/5 px-6 py-4 flex items-center justify-between z-10">
        <div>
          <h2 class="text-xl font-semibold text-white">New Product</h2>
          <p class="text-sm text-white/40 mt-1">Create a new product or set</p>
        </div>
        <button onclick="document.getElementById('newProductDrawer').classList.add('translate-x-full')" class="text-white/40 hover:text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <!-- Steps -->
      <div class="px-6 py-4 border-b border-white/5">
        <div class="flex items-center gap-2">
          <div class="flex items-center justify-center w-8 h-8 rounded-full bg-white text-black text-sm font-medium">1</div>
          <div class="w-12 h-px bg-white/20"></div>
          <div class="flex items-center justify-center w-8 h-8 rounded-full bg-white/5 text-white/40 text-sm font-medium">2</div>
          <div class="w-12 h-px bg-white/20"></div>
          <div class="flex items-center justify-center w-8 h-8 rounded-full bg-white/5 text-white/40 text-sm font-medium">3</div>
          <div class="w-12 h-px bg-white/20"></div>
          <div class="flex items-center justify-center w-8 h-8 rounded-full bg-white/5 text-white/40 text-sm font-medium">4</div>
          <div class="w-12 h-px bg-white/20"></div>
          <div class="flex items-center justify-center w-8 h-8 rounded-full bg-white/5 text-white/40 text-sm font-medium">5</div>
        </div>
      </div>

      <!-- Form Content -->
      <div class="p-6 space-y-6">
        
        <!-- Basic Info -->
        <div class="bg-white/5 rounded-xl p-6 border border-white/5">
          <h3 class="text-sm font-medium text-white mb-4">Basic Information</h3>
          <div class="space-y-4">
            <div>
              <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Product Name</label>
              <input type="text" placeholder="Ex: Set 01 - Arctic" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30">
            </div>
            <div>
              <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Product Type</label>
              <select class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:outline-none">
                <option>Set (Bundle)</option>
                <option>Individual Item</option>
                <option>Full Pack</option>
              </select>
            </div>
            <div>
              <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Collection</label>
              <select class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:outline-none">
                <option>Artic 01</option>
                <option>Noctis Vol. 1</option>
                <option>Puffer Series</option>
                <option>Shadow Line</option>
              </select>
            </div>
            <div>
              <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Short Description</label>
              <textarea rows="3" placeholder="Brief product description..." class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30 resize-none"></textarea>
            </div>
          </div>
        </div>

        <!-- Preview -->
        <div class="bg-white/5 rounded-xl p-6 border border-white/5">
          <h3 class="text-sm font-medium text-white mb-4">Preview</h3>
          <div class="aspect-square rounded-lg bg-white/5 border border-white/10 border-dashed flex items-center justify-center">
            <div class="text-center">
              <svg class="w-12 h-12 text-white/20 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              <p class="text-xs text-white/40">Add Image</p>
              <p class="text-xs text-white/20 mt-1">Recommended: 800x1000px</p>
            </div>
          </div>
          <div class="grid grid-cols-4 gap-2 mt-4">
            <button class="aspect-square rounded-lg bg-white/5 border border-white/10 border-dashed flex items-center justify-center">
              <svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            </button>
            <button class="aspect-square rounded-lg bg-white/5 border border-white/10 border-dashed flex items-center justify-center">
              <svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            </button>
            <button class="aspect-square rounded-lg bg-white/5 border border-white/10 border-dashed flex items-center justify-center">
              <svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            </button>
            <button class="aspect-square rounded-lg bg-white/5 border border-white/10 border-dashed flex items-center justify-center">
              <svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            </button>
          </div>
        </div>

      </div>

      <!-- Drawer Footer -->
      <div class="sticky bottom-0 bg-[#111113] border-t border-white/5 px-6 py-4 flex items-center justify-between">
        <button class="text-sm text-white/60 hover:text-white">Save as Draft</button>
        <button class="bg-white text-black px-6 py-2 rounded-lg text-sm font-medium hover:bg-white/90 transition-colors">Next Step →</button>
      </div>

    </div>
  </div>

</AdminLayout>
