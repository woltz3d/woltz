---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';

// Busca coleções no servidor (isso muda pouco, então pode ser estático)
const { data: collections } = await supabase
  .from('collections')
  .select('id, name')
  .eq('status', 'published');
---

<AdminLayout title="Products" activePage="products">
  
  <header class="bg-[#111113] border-b border-white/5 px-8 py-4 flex items-center justify-between sticky top-0 z-10">
    <div>
      <h1 class="text-2xl font-semibold text-white">Products</h1>
      <p class="text-sm text-white/40 mt-1">Manage your products and sets</p>
    </div>
    <button onclick="document.getElementById('newProductDrawer').classList.remove('translate-x-full')" class="bg-white text-black px-4 py-2 rounded-lg text-sm font-medium hover:bg-white/90 transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Product
    </button>
  </header>

  <div class="p-8">
    <!-- Filters -->
    <div class="bg-[#111113] border border-white/5 rounded-xl p-4 mb-6 flex items-center justify-between">
      <div class="flex items-center gap-4">
        <div class="relative">
          <input type="text" id="searchInput" placeholder="Search products..." class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 pl-10 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30 w-64">
          <svg class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
        <select id="collectionFilter" class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-sm text-white focus:outline-none">
          <option value="">All Collections</option>
          {collections?.map(col => (
            <option value={col.id}>{col.name}</option>
          ))}
        </select>
      </div>
    </div>

    <!-- Table Container (Vazio inicialmente, preenchido via JS) -->
    <div class="bg-[#111113] border border-white/5 rounded-xl overflow-hidden min-h-[200px] flex items-center justify-center" id="tableContainer">
      <p class="text-white/40 animate-pulse">Loading products...</p>
    </div>
  </div>

  <!-- Drawer (Formulário) -->
  <div id="newProductDrawer" class="fixed inset-0 z-50 translate-x-full transition-transform duration-300">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="document.getElementById('newProductDrawer').classList.add('translate-x-full')"></div>
    <div class="absolute right-0 top-0 h-full w-[600px] bg-[#111113] border-l border-white/5 overflow-y-auto">
      
      <div class="sticky top-0 bg-[#111113] border-b border-white/5 px-6 py-4 flex items-center justify-between z-10">
        <div>
          <h2 class="text-xl font-semibold text-white">New Product</h2>
          <p class="text-sm text-white/40 mt-1">Create a new product or set</p>
        </div>
        <button onclick="document.getElementById('newProductDrawer').classList.add('translate-x-full')" class="text-white/40 hover:text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <form id="newProductForm" class="p-6 space-y-6">
        <div class="bg-white/5 rounded-xl p-6 border border-white/5">
          <h3 class="text-sm font-medium text-white mb-4">Basic Information</h3>
          <div class="space-y-4">
            <div>
              <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Product Name *</label>
              <input type="text" name="name" required placeholder="Ex: Set 01 - Arctic" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30">
            </div>
            <div>
              <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Slug *</label>
              <input type="text" name="slug" required placeholder="Ex: set-01-arctic" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30">
            </div>
            <div>
              <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Product Type</label>
              <select name="type" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:outline-none">
                <option value="set">Set (Bundle)</option>
                <option value="item">Individual Item</option>
                <option value="pack">Full Pack</option>
              </select>
            </div>
            <div>
              <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Collection</label>
              <select name="collection_id" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:outline-none">
                <option value="">Select a collection</option>
                {collections?.map(col => (
                  <option value={col.id}>{col.name}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Description</label>
              <textarea name="description" rows="3" placeholder="Brief description..." class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30 resize-none"></textarea>
            </div>
          </div>
        </div>

        <div class="bg-white/5 rounded-xl p-6 border border-white/5">
          <h3 class="text-sm font-medium text-white mb-4">Pricing</h3>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Price (BRL)</label>
              <input type="number" name="price_brl" step="0.01" placeholder="0.00" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30">
            </div>
            <div>
              <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Price (USD)</label>
              <input type="number" name="price_usd" step="0.01" placeholder="0.00" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30">
            </div>
          </div>
        </div>

        <div class="bg-white/5 rounded-xl p-6 border border-white/5">
          <h3 class="text-sm font-medium text-white mb-4">Media</h3>
          <div>
            <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Thumbnail URL</label>
            <input type="url" name="thumbnail_url" placeholder="https://..." class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white placeholder:text-white/40 focus:outline-none focus:border-white/30">
          </div>
        </div>

        <div class="bg-white/5 rounded-xl p-6 border border-white/5">
          <h3 class="text-sm font-medium text-white mb-4">Status</h3>
          <select name="status" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:outline-none">
            <option value="draft">Draft</option>
            <option value="published">Published</option>
            <option value="archived">Archived</option>
          </select>
        </div>
      </form>

      <div class="sticky bottom-0 bg-[#111113] border-t border-white/5 px-6 py-4 flex items-center justify-between">
        <button type="button" onclick="document.getElementById('newProductDrawer').classList.add('translate-x-full')" class="text-sm text-white/60 hover:text-white">Cancel</button>
        <button type="submit" form="newProductForm" id="submitBtn" class="bg-white text-black px-6 py-2 rounded-lg text-sm font-medium hover:bg-white/90 transition-colors">Create Product</button>
      </div>
    </div>
  </div>

  <!-- Script Completo para Carregar Dados e Criar Produto -->
  <script is:inline>
    // Importa o cliente Supabase (funciona no browser porque configuramos no vite/astro)
    import { createClient } from '@supabase/supabase-js';

    document.addEventListener('DOMContentLoaded', async function() {
      // Configuração do Supabase no Frontend
      const supabaseUrl = import.meta.env.SUPABASE_URL;
      const supabaseKey = import.meta.env.SUPABASE_ANON_KEY;
      const supabase = createClient(supabaseUrl, supabaseKey);

      const tableContainer = document.getElementById('tableContainer');

      // 1. Função para buscar e renderizar produtos
      async function loadProducts() {
        try {
          const { data: products, error } = await supabase
            .from('products')
            .select('*, collections(name)')
            .order('created_at', { ascending: false });

          if (error) throw error;

          if (!products || products.length === 0) {
            tableContainer.innerHTML = `
              <div class="w-full py-12 text-center text-white/40">
                <p>No products found in database. Create your first product!</p>
              </div>`;
            return;
          }

          // Gera o HTML da tabela dinamicamente
          let html = `<table class="w-full">
            <thead class="bg-white/5">
              <tr>
                <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Product</th>
                <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Collection</th>
                <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Type</th>
                <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Price (BRL)</th>
                <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Price (USD)</th>
                <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Status</th>
                <th class="text-left text-xs text-white/40 uppercase tracking-wider py-4 px-6 font-medium">Date</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/5" id="productsTableBody">`;

          products.forEach(p => {
            const statusClass = p.status === 'published' ? 'bg-green-500/10 text-green-400' : 
                               p.status === 'draft' ? 'bg-yellow-500/10 text-yellow-400' : 'bg-red-500/10 text-red-400';
            
            const imgUrl = p.thumbnail_url 
              ? `<img src="${p.thumbnail_url}" alt="${p.name}" class="w-full h-full object-cover" />`
              : `<svg class="w-6 h-6 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>`;

            html += `
              <tr class="hover:bg-white/5 transition-colors">
                <td class="py-4 px-6">
                  <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center overflow-hidden">${imgUrl}</div>
                    <div>
                      <p class="text-sm font-medium text-white">${p.name}</p>
                      <p class="text-xs text-white/40">${p.description ? p.description.substring(0, 30) + '...' : ''}</p>
                    </div>
                  </div>
                </td>
                <td class="py-4 px-6 text-sm text-white/60">${p.collections?.name || '-'}</td>
                <td class="py-4 px-6"><span class="px-2 py-1 rounded-full bg-white/5 text-white/60 text-xs capitalize">${p.type}</span></td>
                <td class="py-4 px-6 text-sm text-white">${p.price_brl ? 'R$ ' + Number(p.price_brl).toFixed(2).replace('.', ',') : '-'}</td>
                <td class="py-4 px-6 text-sm text-white">${p.price_usd ? '$ ' + Number(p.price_usd).toFixed(2) : '-'}</td>
                <td class="py-4 px-6"><span class="px-2 py-1 rounded-full ${statusClass} text-xs capitalize">${p.status}</span></td>
                <td class="py-4 px-6 text-sm text-white/60">${new Date(p.created_at).toLocaleDateString('pt-BR')}</td>
              </tr>`;
          });

          html += `</tbody></table>`;
          tableContainer.innerHTML = html;

        } catch (err) {
          console.error(err);
          tableContainer.innerHTML = `<div class="p-8 text-red-400">Error loading products. Check console.</div>`;
        }
      }

      // Carrega os produtos ao abrir a página
      loadProducts();

      // 2. Lógica do Formulário de Criação
      var form = document.getElementById('newProductForm');
      var btn = document.getElementById('submitBtn');

      if (form && btn) {
        form.addEventListener('submit', async function(e) {
          e.preventDefault();
          
          var originalText = btn.innerText;
          btn.innerText = 'Saving...';
          btn.disabled = true;

          var formData = new FormData(form);
          var productData = {};
          
          formData.forEach(function(value, key) {
            productData[key] = value;
          });

          if(productData.price_brl) productData.price_brl = parseFloat(productData.price_brl);
          if(productData.price_usd) productData.price_usd = parseFloat(productData.price_usd);
          if(productData.collection_id === "") productData.collection_id = null;

          try {
            var response = await fetch('/api/products', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(productData)
            });

            var result = await response.json();

            if (response.ok) {
              alert('Product created successfully!');
              document.getElementById('newProductDrawer').classList.add('translate-x-full'); // Fecha drawer
              form.reset();
              loadProducts(); // Recarrega a tabela instantaneamente sem refresh!
            } else {
              alert('Error: ' + (result.error || 'Unknown error'));
            }
          } catch (err) {
            console.error(err);
            alert('Connection error. Please check your internet or try again.');
          } finally {
            btn.innerText = originalText;
            btn.disabled = false;
          }
        });
      }

      // 3. Busca Visual (Filtro na tabela já carregada)
      var searchInput = document.getElementById('searchInput');
      if (searchInput) {
        searchInput.addEventListener('input', function(e) {
          var term = e.target.value.toLowerCase();
          var rows = document.querySelectorAll('#productsTableBody tr');
          rows.forEach(function(row) {
            var text = row.textContent ? row.textContent.toLowerCase() : '';
            row.style.display = text.includes(term) ? '' : 'none';
          });
        });
      }
    });
  </script>

</AdminLayout>
