---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';

const SUPABASE_URL = import.meta.env.SUPABASE_URL;
const SUPABASE_ANON_KEY = import.meta.env.SUPABASE_ANON_KEY;
---

<AdminLayout title="Products" activePage="products">
  
  <style is:global>
    select, option, input, textarea { 
      background-color: #111113 !important; color: white !important; 
      border: 1px solid rgba(255,255,255,0.1) !important; 
    }
    select:focus, input:focus, textarea:focus { border-color: rgba(255,255,255,0.3) !important; outline: none !important; }
    select option { background-color: #111113 !important; }
    
    .file-upload-zone { border: 2px dashed rgba(255,255,255,0.2); transition: all 0.3s ease; cursor: pointer; }
    .file-upload-zone:hover { border-color: white; background-color: rgba(255,255,255,0.05); }
    .upload-progress { height: 3px; background: linear-gradient(90deg, #3b82f6, #8b5cf6); transition: width 0.3s ease; }
    
    .variant-tag {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 4px 10px 4px 4px; background: rgba(255,255,255,0.08);
      border-radius: 20px; font-size: 12px; margin-right: 6px; margin-bottom: 6px;
      border: 1px solid rgba(255,255,255,0.1); user-select: none;
    }
    .variant-preview {
      width: 20px; height: 20px; border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.3); overflow: hidden;
      flex-shrink: 0; display: flex; align-items: center; justify-content: center;
    }
    .variant-preview img { width: 100%; height: 100%; object-fit: cover; }
    .remove-variant { cursor: pointer; opacity: 0.5; margin-left: 4px; font-size: 14px; line-height: 1; }
    .remove-variant:hover { opacity: 1; color: #ef4444; }
    
    .toggle-btn { 
      padding: 6px 12px; font-size: 11px; border-radius: 6px; 
      background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.5); 
      border: 1px solid transparent; cursor: pointer; transition: all 0.2s;
    }
    .toggle-btn.active { background: white; color: black; font-weight: 600; }
  </style>

  <div id="app-config" data-supabase-url={SUPABASE_URL} data-supabase-key={SUPABASE_ANON_KEY} style="display:none;"></div>

  <header class="bg-[#111113] border-b border-white/5 px-8 py-4 flex items-center justify-between sticky top-0 z-10">
    <div>
      <h1 class="text-2xl font-semibold text-white">Products</h1>
      <p class="text-sm text-white/40 mt-1">Manage your products and sets</p>
    </div>
    <button onclick="window.openDrawer()" class="bg-white text-black px-4 py-2 rounded-lg text-sm font-medium hover:bg-white/90 transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Product
    </button>
  </header>

  <div class="p-8">
    <div class="bg-[#111113] border border-white/5 rounded-xl p-4 mb-6 flex items-center gap-4">
      <div class="relative flex-1 max-w-md">
        <input type="text" id="searchInput" placeholder="Search products..." class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 pl-10 w-full text-sm text-white focus:outline-none focus:border-white/30">
        <svg class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      </div>
    </div>

    <div class="bg-[#111113] border border-white/5 rounded-xl overflow-hidden min-h-[200px]" id="tableContainer">
      <p class="py-12 text-center text-white/40 animate-pulse">Loading products...</p>
    </div>
  </div>

  <!-- DRAWER -->
  <div id="productDrawer" class="fixed inset-0 z-50 translate-x-full transition-transform duration-300">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="window.closeDrawer()"></div>
    <div class="absolute right-0 top-0 h-full w-[600px] bg-[#111113] border-l border-white/5 overflow-y-auto">
      
      <div class="sticky top-0 bg-[#111113] border-b border-white/5 px-6 py-4 flex items-center justify-between z-10">
        <div>
          <h2 class="text-xl font-semibold text-white" id="drawerTitle">New Product</h2>
          <p class="text-sm text-white/40 mt-1" id="drawerSubtitle">Create a new product or set</p>
        </div>
        <button onclick="window.closeDrawer()" class="text-white/40 hover:text-white"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>
      </div>

      <form id="productForm" class="p-6 space-y-8">
        <input type="hidden" name="id" id="productId">

        <!-- Info Básica -->
        <div class="space-y-4">
          <h3 class="text-sm font-medium text-white border-b border-white/10 pb-2">Basic Information</h3>
          <div><label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Product Name *</label><input type="text" name="name" required class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none"></div>
          <div><label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Slug *</label><input type="text" name="slug" required class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none"></div>
          
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Type</label>
              <select name="type" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none">
                <option value="set">Set (Bundle)</option>
                <option value="item">Individual Item</option>
                <option value="pack">Full Pack</option>
              </select>
            </div>
            <div>
              <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Collection</label>
              <select name="collection_id" id="collectionSelect" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none">
                <option value="">No Collection</option>
              </select>
            </div>
          </div>
          
          <div><label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Description</label><textarea name="description" rows="3" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none resize-none"></textarea></div>
        </div>

        <!-- SELETOR DE CORES E TEXTURAS -->
        <div class="space-y-4">
          <h3 class="text-sm font-medium text-white border-b border-white/10 pb-2">Colors & Patterns</h3>
          <div class="bg-white/5 p-4 rounded-lg border border-white/10">
            <div id="variantsList" class="flex flex-wrap mb-4 min-h-[40px] p-2 bg-black/20 rounded-lg border border-white/5"></div>
            
            <div class="space-y-3">
              <div class="flex gap-2 mb-2">
                <button type="button" id="btnSolid" class="toggle-btn active">Solid Color</button>
                <button type="button" id="btnPattern" class="toggle-btn">Pattern / Texture</button>
              </div>

              <div id="inputSolid" class="flex gap-2 items-center">
                <input type="text" id="colorNameInput" placeholder="Color name (e.g., Pink)" class="flex-1 bg-black/30 border border-white/10 rounded-lg px-3 py-2 text-sm text-white focus:border-white/30 focus:outline-none">
                <input type="color" id="colorPickerInput" value="#ff0055" class="w-10 h-10 rounded cursor-pointer bg-transparent border-0 p-0">
                <button type="button" id="addColorBtn" class="px-4 py-2 bg-white text-black rounded-lg text-sm font-medium hover:bg-white/90 whitespace-nowrap">Add Color</button>
              </div>

              <div id="inputPattern" class="hidden flex-col gap-2">
                <input type="text" id="patternNameInput" placeholder="Pattern name (e.g., Leopard)" class="w-full bg-black/30 border border-white/10 rounded-lg px-3 py-2 text-sm text-white focus:border-white/30 focus:outline-none">
                
                <div class="file-upload-zone rounded-lg p-4 text-center relative h-24 flex flex-col items-center justify-center" id="patternDropZone">
                  <input type="file" id="patternFileInput" accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer">
                  <div id="patternPreview" class="hidden absolute inset-0 p-1"><img src="" class="w-full h-full object-cover rounded"></div>
                  <div id="patternPlaceholder" class="text-center pointer-events-none">
                    <svg class="w-6 h-6 text-white/40 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                    <p class="text-xs text-white/50">Click to upload texture swatch</p>
                  </div>
                </div>
                <button type="button" id="addPatternBtn" class="w-full py-2 bg-white text-black rounded-lg text-sm font-medium hover:bg-white/90">Add Pattern</button>
              </div>
            </div>
            
            <p class="text-[10px] text-white/40 mt-3">First 4 variants show on homepage. Others appear as "+X".</p>
          </div>
        </div>

        <!-- Calculadora de Preço -->
        <div class="space-y-4">
          <h3 class="text-sm font-medium text-white border-b border-white/10 pb-2 flex items-center justify-between">
            Pricing Calculator
            <span class="text-[10px] text-white/40 font-normal normal-case">Stripe Fees Included</span>
          </h3>
          
          <div class="bg-white/5 p-4 rounded-lg border border-white/10">
            <label class="block text-xs text-green-400 uppercase tracking-wider mb-2 font-bold">💰 Net Amount You Want (BRL)</label>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-white/60">R$</span>
              <input type="number" id="netBrlInput" step="0.01" placeholder="e.g., 100.00" class="w-full bg-black/30 border border-green-500/30 rounded-lg pl-10 pr-4 py-3 text-lg text-white font-mono focus:border-green-500 focus:outline-none">
            </div>
            <p class="text-[10px] text-white/40 mt-2">Enter how much you want to receive after fees.</p>
          </div>

          <div class="grid grid-cols-2 gap-4 opacity-75">
            <div>
              <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Sell Price (BRL)</label>
              <input type="number" name="price_brl" id="sellPriceBrl" readonly class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white/80 cursor-not-allowed">
            </div>
            <div>
              <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Sell Price (USD)</label>
              <input type="number" name="price_usd" id="sellPriceUsd" readonly class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white/80 cursor-not-allowed">
            </div>
          </div>
          
          <input type="hidden" name="net_brl" id="netBrlHidden">
          <div class="flex items-center gap-2 mt-2">
             <label class="text-xs text-white/40">Exchange Rate (1 USD = R$):</label>
             <input type="number" id="exchangeRate" value="5.50" step="0.01" class="w-20 bg-white/5 border border-white/10 rounded px-2 py-1 text-xs text-white text-center">
          </div>
        </div>

        <!-- Media Upload -->
        <div class="space-y-6">
          <h3 class="text-sm font-medium text-white border-b border-white/10 pb-2">Media</h3>
          <div>
            <label class="block text-xs text-white/60 uppercase tracking-wider mb-2">Thumbnail Image</label>
            <div class="file-upload-zone rounded-lg p-6 text-center cursor-pointer relative" id="thumbDropZone">
              <input type="file" id="thumbFileInput" accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer">
              <div id="thumbPreview" class="hidden mb-3"><img src="" alt="Preview" class="max-h-32 mx-auto rounded-lg object-cover"></div>
              <div id="thumbPlaceholder">
                <svg class="w-10 h-10 text-white/30 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                <p class="text-sm text-white/60">Click or drag image here</p>
              </div>
              <div id="thumbProgress" class="hidden mt-3"><div class="upload-progress rounded-full" style="width: 0%"></div><p class="text-xs text-white/40 mt-1">Uploading...</p></div>
            </div>
            <input type="hidden" name="thumbnail_url" id="thumbUrlInput">
          </div>
        </div>

        <!-- UPLOAD DE ARQUIVO DIGITAL (NOVO!) -->
        <div class="space-y-4">
          <h3 class="text-sm font-medium text-white border-b border-white/10 pb-2">Digital File</h3>
          <div class="bg-white/5 p-4 rounded-lg border border-white/10">
            <label class="block text-xs text-blue-400 uppercase tracking-wider mb-2 font-bold">📦 Product File (.zip, .blend, .obj)</label>
            <div class="file-upload-zone rounded-lg p-6 text-center cursor-pointer relative" id="digitalDropZone">
              <input type="file" id="digitalFileInput" accept=".zip,.blend,.obj,.fbx,.dae" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer">
              <div id="digitalPreview" class="hidden mb-3">
                <svg class="w-12 h-12 text-blue-400 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                <p id="digitalFileName" class="text-sm text-white font-mono"></p>
              </div>
              <div id="digitalPlaceholder">
                <svg class="w-10 h-10 text-white/30 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3"/></svg>
                <p class="text-sm text-white/60">Click to upload digital file</p>
                <p class="text-xs text-white/40 mt-1">Max 500MB • .zip, .blend, .obj, .fbx</p>
              </div>
              <div id="digitalProgress" class="hidden mt-3"><div class="upload-progress rounded-full" style="width: 0%"></div><p class="text-xs text-white/40 mt-1">Uploading file...</p></div>
            </div>
            <input type="hidden" name="digital_file_url" id="digitalUrlInput">
          </div>
        </div>

        <!-- Status -->
        <div class="space-y-4">
           <h3 class="text-sm font-medium text-white border-b border-white/10 pb-2">Status</h3>
           <select name="status" class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-white focus:border-white/30 focus:outline-none">
            <option value="draft">Draft</option>
            <option value="published">Published</option>
            <option value="archived">Archived</option>
          </select>
        </div>
      </form>

      <div class="sticky bottom-0 bg-[#111113] border-t border-white/5 px-6 py-4 flex items-center justify-between">
        <button type="button" onclick="window.closeDrawer()" class="text-sm text-white/60 hover:text-white">Cancel</button>
        <button type="submit" form="productForm" id="submitBtn" class="bg-white text-black px-6 py-2 rounded-lg text-sm font-medium hover:bg-white/90">Save Product</button>
      </div>
    </div>
  </div>

  <script type="module">
    import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';

    const configEl = document.getElementById('app-config');
    const supabase = createClient(configEl?.dataset.supabaseUrl, configEl?.dataset.supabaseKey);

    // Elementos DOM
    const tableContainer = document.getElementById('tableContainer');
    const drawer = document.getElementById('productDrawer');
    const form = document.getElementById('productForm');
    const submitBtn = document.getElementById('submitBtn');
    const collectionSelect = document.getElementById('collectionSelect');
    
    // Calculadora
    const netBrlInput = document.getElementById('netBrlInput');
    const sellPriceBrl = document.getElementById('sellPriceBrl');
    const sellPriceUsd = document.getElementById('sellPriceUsd');
    const netBrlHidden = document.getElementById('netBrlHidden');
    const exchangeRateInput = document.getElementById('exchangeRate');

    // Variantes
    const btnSolid = document.getElementById('btnSolid');
    const btnPattern = document.getElementById('btnPattern');
    const inputSolid = document.getElementById('inputSolid');
    const inputPattern = document.getElementById('inputPattern');
    const colorNameInput = document.getElementById('colorNameInput');
    const colorPickerInput = document.getElementById('colorPickerInput');
    const addColorBtn = document.getElementById('addColorBtn');
    const patternNameInput = document.getElementById('patternNameInput');
    const patternFileInput = document.getElementById('patternFileInput');
    const patternDropZone = document.getElementById('patternDropZone');
    const patternPreview = document.getElementById('patternPreview');
    const patternPlaceholder = document.getElementById('patternPlaceholder');
    const addPatternBtn = document.getElementById('addPatternBtn');
    const variantsList = document.getElementById('variantsList');

    // Digital File
    const digitalFileInput = document.getElementById('digitalFileInput');
    const digitalDropZone = document.getElementById('digitalDropZone');
    const digitalPreview = document.getElementById('digitalPreview');
    const digitalPlaceholder = document.getElementById('digitalPlaceholder');
    const digitalProgress = document.getElementById('digitalProgress');
    const digitalFileName = document.getElementById('digitalFileName');
    const digitalUrlInput = document.getElementById('digitalUrlInput');

    // Estado
    let currentMode = 'create';
    let uploadingThumb = false;
    let uploadingPattern = false;
    let uploadingDigital = false;
    let currentVariants = []; 
    let tempPatternUrl = ''; 

    // --- LÓGICA DE VARIANTES ---
    btnSolid.addEventListener('click', () => {
      btnSolid.classList.add('active'); btnPattern.classList.remove('active');
      inputSolid.classList.remove('hidden'); inputPattern.classList.add('hidden');
    });
    btnPattern.addEventListener('click', () => {
      btnPattern.classList.add('active'); btnSolid.classList.remove('active');
      inputPattern.classList.remove('hidden'); inputSolid.classList.add('hidden');
    });

    function renderVariants() {
      variantsList.innerHTML = '';
      currentVariants.forEach((item, index) => {
        const tag = document.createElement('div');
        tag.className = 'variant-tag';
        
        let previewHtml = '';
        if (item.type === 'pattern' && item.url) {
          previewHtml = `<div class="variant-preview"><img src="${item.url}?width=50&quality=50" alt="${item.name}"></div>`;
        } else {
          previewHtml = `<div class="variant-preview" style="background-color: ${item.hex || '#ccc'}"></div>`;
        }

        tag.innerHTML = `${previewHtml}<span>${item.name}</span><span class="remove-variant" data-index="${index}">×</span>`;
        variantsList.appendChild(tag);
      });
      
      document.querySelectorAll('.remove-variant').forEach(btn => {
        btn.addEventListener('click', (e) => {
          currentVariants.splice(parseInt(e.target.dataset.index), 1);
          renderVariants();
        });
      });
    }

    addColorBtn.addEventListener('click', () => {
      const name = colorNameInput.value.trim();
      const hex = colorPickerInput.value;
      if (name) {
        currentVariants.push({ name, hex, type: 'solid' });
        colorNameInput.value = '';
        renderVariants();
      }
    });

    patternFileInput.addEventListener('change', async (e) => {
      const file = e.target.files?.[0];
      if (!file) return;
      
      const reader = new FileReader();
      reader.onload = (ev) => {
        patternPreview.querySelector('img').src = ev.target.result;
        patternPreview.classList.remove('hidden');
        patternPlaceholder.classList.add('hidden');
      };
      reader.readAsDataURL(file);

      try {
        uploadingPattern = true;
        const fileName = `swatch-${Date.now()}-${file.name.replace(/[^a-zA-Z0-9.-]/g, '-')}`;
        const { error } = await supabase.storage.from('woltz-images').upload(fileName, file, { cacheControl: '3600' });
        if (error) throw error;
        const { data } = supabase.storage.from('woltz-images').getPublicUrl(fileName);
        tempPatternUrl = data.publicUrl;
      } catch(err) {
        alert('Upload failed: ' + err.message);
        tempPatternUrl = '';
      } finally { uploadingPattern = false; }
    });

    addPatternBtn.addEventListener('click', () => {
      const name = patternNameInput.value.trim();
      if (name && tempPatternUrl) {
        currentVariants.push({ name, url: tempPatternUrl, type: 'pattern' });
        patternNameInput.value = '';
        tempPatternUrl = '';
        patternPreview.classList.add('hidden');
        patternPlaceholder.classList.remove('hidden');
        patternFileInput.value = '';
        renderVariants();
      } else if (!tempPatternUrl) {
        alert('Please upload a texture image first.');
      }
    });

    // --- UPLOAD ARQUIVO DIGITAL ---
    digitalFileInput?.addEventListener('change', async (e) => {
      const file = e.target.files?.[0];
      if (!file) return;
      
      digitalFileName.textContent = file.name;
      digitalPreview.classList.remove('hidden');
      digitalPlaceholder.classList.add('hidden');

      try {
        uploadingDigital = true;
        digitalProgress.classList.remove('hidden');
        digitalProgress.querySelector('.upload-progress').style.width = '30%';
        
        const fileName = `digital-${Date.now()}-${file.name.replace(/[^a-zA-Z0-9.-]/g, '-')}`;
        const { error } = await supabase.storage.from('woltz-digital').upload(fileName, file, { cacheControl: 'private' });
        if (error) throw error;
        
        const { data } = supabase.storage.from('woltz-digital').getPublicUrl(fileName);
        digitalUrlInput.value = data.publicUrl;
        
        digitalProgress.querySelector('.upload-progress').style.width = '100%';
        setTimeout(() => { digitalProgress.classList.add('hidden'); }, 500);
      } catch(err) {
        alert('Digital file upload failed: ' + err.message);
        digitalProgress.classList.add('hidden');
        digitalUrlInput.value = '';
      } finally { uploadingDigital = false; }
    });

    // --- COLEÇÕES ---
    async function loadCollectionsForDropdown() {
      try {
        const res = await fetch('/api/products?type=collections');
        const result = await res.json();
        const collections = result.data || [];
        collectionSelect.innerHTML = '<option value="">No Collection</option>';
        collections.forEach(c => {
          const opt = document.createElement('option');
          opt.value = c.id; opt.innerText = c.name;
          collectionSelect.appendChild(opt);
        });
      } catch(e) { console.error(e); }
    }

    // --- CALCULADORA ---
    function calculatePrices() {
      const netBrl = parseFloat(netBrlInput.value) || 0;
      const rate = parseFloat(exchangeRateInput.value) || 5.50;
      if (netBrl <= 0) {
        sellPriceBrl.value = ''; sellPriceUsd.value = ''; netBrlHidden.value = ''; return;
      }
      const priceBrl = (netBrl + 0.39) / (1 - 0.0499);
      const priceUsd = ((netBrl / rate) + 0.39) / (1 - 0.0999);
      sellPriceBrl.value = priceBrl.toFixed(2);
      sellPriceUsd.value = priceUsd.toFixed(2);
      netBrlHidden.value = netBrl.toFixed(2);
    }
    netBrlInput.addEventListener('input', calculatePrices);
    exchangeRateInput.addEventListener('input', calculatePrices);

    // --- UPLOAD THUMBNAIL ---
    async function uploadToSupabase(file, bucket = 'woltz-images') {
      const fileName = `${Date.now()}-${file.name.replace(/[^a-zA-Z0-9.-]/g, '-')}`;
      const { error } = await supabase.storage.from(bucket).upload(fileName, file, { cacheControl: '3600', upsert: false });
      if (error) throw error;
      const { data: urlData } = supabase.storage.from(bucket).getPublicUrl(fileName);
      return urlData.publicUrl;
    }

    const thumbInput = document.getElementById('thumbFileInput');
    const thumbDropZone = document.getElementById('thumbDropZone');
    const thumbPreview = document.getElementById('thumbPreview');
    const thumbPlaceholder = document.getElementById('thumbPlaceholder');
    const thumbProgress = document.getElementById('thumbProgress');
    const thumbUrlInput = document.getElementById('thumbUrlInput');

    thumbInput?.addEventListener('change', async (e) => {
      const file = e.target.files?.[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (ev) => {
        thumbPreview.querySelector('img').src = ev.target.result;
        thumbPreview.classList.remove('hidden'); thumbPlaceholder.classList.add('hidden');
      };
      reader.readAsDataURL(file);
      try {
        uploadingThumb = true;
        thumbProgress.classList.remove('hidden');
        thumbProgress.querySelector('.upload-progress').style.width = '30%';
        const url = await uploadToSupabase(file);
        thumbProgress.querySelector('.upload-progress').style.width = '100%';
        setTimeout(() => { thumbProgress.classList.add('hidden'); }, 500);
        thumbUrlInput.value = url;
      } catch(err) { alert('Upload failed: ' + err.message); thumbProgress.classList.add('hidden'); }
      finally { uploadingThumb = false; }
    });

    // --- CRUD PRODUTOS ---
    async function loadProducts() {
      try {
        const res = await fetch('/api/products');
        if(!res.ok) throw new Error('Failed');
        const result = await res.json();
        const products = result.data || [];

        if(products.length === 0) {
          tableContainer.innerHTML = `<div class="py-12 text-center text-white/40">No products found.</div>`;
          return;
        }

        let html = `<table class="w-full"><thead class="bg-white/5"><tr>
          <th class="text-left text-xs text-white/40 uppercase py-4 px-6">Product</th>
          <th class="text-left text-xs text-white/40 uppercase py-4 px-6">Collection</th>
          <th class="text-left text-xs text-white/40 uppercase py-4 px-6">Price (USD)</th>
          <th class="text-left text-xs text-white/40 uppercase py-4 px-6">Est. Net (BRL)</th>
          <th class="text-left text-xs text-white/40 uppercase py-4 px-6">Variants</th>
          <th class="text-left text-xs text-white/40 uppercase py-4 px-6">Status</th>
          <th class="text-right text-xs text-white/40 uppercase py-4 px-6">Actions</th>
        </tr></thead><tbody class="divide-y divide-white/5">`;

        products.forEach(p => {
          const statusClass = p.status === 'published' ? 'text-green-400' : p.status === 'draft' ? 'text-yellow-400' : 'text-red-400';
          const imgUrl = p.thumbnail_url 
            ? `<img src="${p.thumbnail_url}?width=100&quality=80" class="w-10 h-10 rounded object-cover bg-white/5" loading="lazy">`
            : `<div class="w-10 h-10 rounded bg-white/5 flex items-center justify-center"><svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg></div>`;

          let variantsHtml = '';
          if (p.colors && Array.isArray(p.colors) && p.colors.length > 0) {
            p.colors.slice(0, 5).forEach(c => {
              if (c.type === 'pattern' && c.url) {
                variantsHtml += `<div class="w-4 h-4 rounded-full overflow-hidden border border-white/20 inline-block mr-1"><img src="${c.url}?width=20&quality=50" class="w-full h-full object-cover"></div>`;
              } else {
                variantsHtml += `<div class="w-4 h-4 rounded-full border border-white/20 inline-block mr-1" style="background-color: ${c.hex}" title="${c.name}"></div>`;
              }
            });
            if (p.colors.length > 5) variantsHtml += `<span class="text-[10px] text-white/40 ml-1">+${p.colors.length - 5}</span>`;
          } else {
            variantsHtml = '<span class="text-white/30 text-xs">-</span>';
          }

          const safeJson = JSON.stringify(p).replace(/'/g, "&#39;");

          html += `<tr class="hover:bg-white/5 transition-colors">
            <td class="py-4 px-6"><div class="flex items-center gap-3">${imgUrl}<div><p class="text-sm font-medium text-white">${p.name}</p><p class="text-xs text-white/40">${p.type}</p></div></div></td>
            <td class="py-4 px-6 text-sm text-white/60">${p.collections?.name || '-'}</td>
            <td class="py-4 px-6 text-sm text-white font-mono">$ ${Number(p.price_usd || 0).toFixed(2)}</td>
            <td class="py-4 px-6 text-sm text-green-400 font-mono">R$ ${Number(p.net_brl || 0).toFixed(2).replace('.', ',')}</td>
            <td class="py-4 px-6 flex items-center">${variantsHtml}</td>
            <td class="py-4 px-6 text-sm capitalize ${statusClass}">${p.status}</td>
            <td class="py-4 px-6 text-right">
              <button onclick='window.editProduct(${safeJson})' class="p-2 text-white/40 hover:text-blue-400 inline-block"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg></button>
              <button onclick="window.deleteProduct('${p.id}', '${p.name}')" class="p-2 text-white/40 hover:text-red-400 inline-block"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg></button>
            </td>
          </tr>`;
        });
        html += `</tbody></table>`;
        tableContainer.innerHTML = html;

      } catch(err) {
        console.error(err);
        tableContainer.innerHTML = `<div class="p-8 text-red-400">Error loading products.</div>`;
      }
    }

    window.openDrawer = () => {
      currentMode = 'create';
      currentVariants = [];
      tempPatternUrl = '';
      renderVariants();
      document.getElementById('drawerTitle').innerText = 'New Product';
      document.getElementById('submitBtn').innerText = 'Create Product';
      form.reset();
      document.getElementById('productId').value = '';
      netBrlInput.value = ''; sellPriceBrl.value = ''; sellPriceUsd.value = '';
      thumbPreview.classList.add('hidden'); thumbPlaceholder.classList.remove('hidden'); thumbUrlInput.value = '';
      patternPreview.classList.add('hidden'); patternPlaceholder.classList.remove('hidden'); patternFileInput.value = '';
      digitalPreview.classList.add('hidden'); digitalPlaceholder.classList.remove('hidden'); digitalUrlInput.value = '';
      drawer.classList.remove('translate-x-full');
    };

    window.closeDrawer = () => drawer.classList.add('translate-x-full');

    window.editProduct = (p) => {
      currentMode = 'edit';
      currentVariants = (p.colors && Array.isArray(p.colors)) ? [...p.colors] : [];
      renderVariants();
      
      document.getElementById('drawerTitle').innerText = 'Edit Product';
      document.getElementById('submitBtn').innerText = 'Save Changes';
      document.getElementById('productId').value = p.id;
      
      form.name.value = p.name; form.slug.value = p.slug; form.type.value = p.type;
      form.collection_id.value = p.collection_id || ''; form.description.value = p.description || ''; form.status.value = p.status;
      
      if (p.net_brl) netBrlInput.value = p.net_brl;
      else if (p.price_brl) netBrlInput.value = ((parseFloat(p.price_brl) * 0.9501) - 0.39).toFixed(2);
      calculatePrices();

      if(p.thumbnail_url) {
        thumbUrlInput.value = p.thumbnail_url;
        thumbPreview.querySelector('img').src = p.thumbnail_url;
        thumbPreview.classList.remove('hidden'); thumbPlaceholder.classList.add('hidden');
      }

      if(p.digital_file_url) {
        digitalUrlInput.value = p.digital_file_url;
        digitalFileName.textContent = p.digital_file_url.split('/').pop();
        digitalPreview.classList.remove('hidden'); digitalPlaceholder.classList.add('hidden');
      }
      
      drawer.classList.remove('translate-x-full');
    };

    window.deleteProduct = async (id, name) => {
      if(!confirm(`Delete "${name}"?`)) return;
      try {
        const res = await fetch(`/api/products?id=${id}`, { method: 'DELETE' });
        if(!res.ok) throw new Error('Delete failed');
        alert('Deleted!'); loadProducts();
      } catch(e) { alert('Error: ' + e.message); }
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if(uploadingThumb || uploadingPattern || uploadingDigital) { alert('Wait for uploads!'); return; }
      
      const originalText = submitBtn.innerText;
      submitBtn.innerText = 'Saving...'; submitBtn.disabled = true;

      const fd = new FormData(form);
      const data = {};
      fd.forEach((v,k) => data[k] = v);
      
      Object.keys(data).forEach(key => { if(data[key] === "") data[key] = null; });
      if(data.price_brl) data.price_brl = parseFloat(data.price_brl);
      if(data.price_usd) data.price_usd = parseFloat(data.price_usd);
      if(data.net_brl) data.net_brl = parseFloat(data.net_brl);
      
      data.colors = currentVariants; 

      const id = document.getElementById('productId').value;
      const method = id ? 'PUT' : 'POST';
      const url = id ? `/api/products?id=${id}` : '/api/products';

      try {
        const res = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify(data) });
        const result = await res.json();
        if(res.ok) { 
          alert(id ? 'Updated!' : 'Created!'); 
          closeDrawer(); 
          loadProducts(); 
        }
        else { alert('Error: ' + (result.error || 'Unknown')); }
      } catch(err) { alert('Connection error'); }
      finally { submitBtn.innerText = originalText; submitBtn.disabled = false; }
    });

    loadCollectionsForDropdown();
    loadProducts();
    
    document.getElementById('searchInput')?.addEventListener('input', (e) => {
      const term = e.target.value.toLowerCase();
      document.querySelectorAll('tbody tr').forEach(row => row.style.display = row.textContent?.toLowerCase().includes(term) ? '' : 'none');
    });
  </script>
</AdminLayout>
