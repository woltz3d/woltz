---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Emails" activePage="emails">
  
  <!-- Top Bar -->
  <header class="bg-[#111113] border-b border-white/5 px-8 py-4 flex items-center justify-between sticky top-0 z-10">
    <div>
      <h1 class="text-2xl font-semibold text-white">Emails</h1>
      <p class="text-sm text-white/40 mt-1">Manage email campaigns</p>
    </div>
    <button class="bg-white text-black px-4 py-2 rounded-lg text-sm font-medium hover:bg-white/90 transition-colors flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Campaign
    </button>
  </header>

  <!-- Content -->
  <div class="p-8">
    
    <!-- Email Templates Grid -->
    <div class="grid grid-cols-3 gap-6 mb-8">
      
      <!-- Template Card -->
      <div class="bg-[#111113] border border-white/5 rounded-xl overflow-hidden hover:border-white/20 transition-colors cursor-pointer group">
        <div class="aspect-video bg-gradient-to-br from-white/5 to-white/10 flex items-center justify-center">
          <svg class="w-16 h-16 text-white/20 group-hover:text-white/30 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </div>
        <div class="p-4">
          <h3 class="text-sm font-medium text-white mb-1">Welcome Email</h3>
          <p class="text-xs text-white/40 mb-3">Sent when customer makes first purchase</p>
          <div class="flex items-center justify-between">
            <span class="px-2 py-1 rounded-full bg-green-500/10 text-green-400 text-xs">Active</span>
            <button class="text-xs text-white/60 hover:text-white">Edit</button>
          </div>
        </div>
      </div>

      <div class="bg-[#111113] border border-white/5 rounded-xl overflow-hidden hover:border-white/20 transition-colors cursor-pointer group">
        <div class="aspect-video bg-gradient-to-br from-white/5 to-white/10 flex items-center justify-center">
          <svg class="w-16 h-16 text-white/20 group-hover:text-white/30 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
        </div>
        <div class="p-4">
          <h3 class="text-sm font-medium text-white mb-1">Order Confirmation</h3>
          <p class="text-xs text-white/40 mb-3">Sent after successful payment</p>
          <div class="flex items-center justify-between">
            <span class="px-2 py-1 rounded-full bg-green-500/10 text-green-400 text-xs">Active</span>
            <button class="text-xs text-white/60 hover:text-white">Edit</button>
          </div>
        </div>
      </div>

      <div class="bg-[#111113] border border-white/5 rounded-xl overflow-hidden hover:border-white/20 transition-colors cursor-pointer group">
        <div class="aspect-video bg-gradient-to-br from-white/5 to-white/10 flex items-center justify-center">
          <svg class="w-16 h-16 text-white/20 group-hover:text-white/30 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        </div>
        <div class="p-4">
          <h3 class="text-sm font-medium text-white mb-1">Download Ready</h3>
          <p class="text-xs text-white/40 mb-3">Sent when files are available</p>
          <div class="flex items-center justify-between">
            <span class="px-2 py-1 rounded-full bg-green-500/10 text-green-400 text-xs">Active</span>
            <button class="text-xs text-white/60 hover:text-white">Edit</button>
          </div>
        </div>
      </div>

      <div class="bg-[#111113] border border-white/5 rounded-xl overflow-hidden hover:border-white/20 transition-colors cursor-pointer group">
        <div class="aspect-video bg-gradient-to-br from-white/5 to-white/10 flex items-center justify-center">
          <svg class="w-16 h-16 text-white/20 group-hover:text-white/30 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div class="p-4">
          <h3 class="text-sm font-medium text-white mb-1">Abandoned Cart</h3>
          <p class="text-xs text-white/40 mb-3">Reminder for incomplete purchases</p>
          <div class="flex items-center justify-between">
            <span class="px-2 py-1 rounded-full bg-yellow-500/10 text-yellow-400 text-xs">Draft</span>
            <button class="text-xs text-white/60 hover:text-white">Edit</button>
          </div>
        </div>
      </div>

      <div class="bg-[#111113] border border-white/5 rounded-xl overflow-hidden hover:border-white/20 transition-colors cursor-pointer group">
        <div class="aspect-video bg-gradient-to-br from-white/5 to-white/10 flex items-center justify-center">
          <svg class="w-16 h-16 text-white/20 group-hover:text-white/30 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
        </div>
        <div class="p-4">
          <h3 class="text-sm font-medium text-white mb-1">Newsletter</h3>
          <p class="text-xs text-white/40 mb-3">Monthly product updates</p>
          <div class="flex items-center justify-between">
            <span class="px-2 py-1 rounded-full bg-green-500/10 text-green-400 text-xs">Active</span>
            <button class="text-xs text-white/60 hover:text-white">Edit</button>
          </div>
        </div>
      </div>

      <div class="bg-[#111113] border border-dashed border-white/20 rounded-xl overflow-hidden hover:border-white/40 transition-colors cursor-pointer flex flex-col items-center justify-center p-8">
        <svg class="w-12 h-12 text-white/20 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/></svg>
        <p class="text-sm font-medium text-white mb-1">Create New Template</p>
        <p class="text-xs text-white/40">Custom email design</p>
      </div>

    </div>

    <!-- Recent Campaigns -->
    <div class="bg-[#111113] border border-white/5 rounded-xl p-6">
      <h3 class="text-lg font-semibold text-white mb-6">Recent Campaigns</h3>
      
      <div class="space-y-4">
        <div class="flex items-center justify-between p-4 bg-white/5 rounded-lg">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center">
              <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <p class="text-sm font-medium text-white">New Collection Launch - Artic 01</p>
              <p class="text-xs text-white/40">Sent to 1,247 subscribers</p>
            </div>
          </div>
          <div class="flex items-center gap-6">
            <div class="text-right">
              <p class="text-sm text-white/60">Open Rate</p>
              <p class="text-sm font-medium text-white">42.3%</p>
            </div>
            <div class="text-right">
              <p class="text-sm text-white/60">Sent</p>
              <p class="text-sm font-medium text-white">28 Jun, 2026</p>
            </div>
            <button class="text-white/40 hover:text-white">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/></svg>
            </button>
          </div>
        </div>

        <div class="flex items-center justify-between p-4 bg-white/5 rounded-lg">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-white/5 flex items-center justify-center">
              <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <p class="text-sm font-medium text-white">Summer Sale - 20% Off</p>
              <p class="text-xs text-white/40">Sent to 3,892 subscribers</p>
            </div>
          </div>
          <div class="flex items-center gap-6">
            <div class="text-right">
              <p class="text-sm text-white/60">Open Rate</p>
              <p class="text-sm font-medium text-white">38.7%</p>
            </div>
            <div class="text-right">
              <p class="text-sm text-white/60">Sent</p>
              <p class="text-sm font-medium text-white">15 Jun, 2026</p>
            </div>
            <button class="text-white/40 hover:text-white">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z"/></svg>
            </button>
          </div>
        </div>
      </div>
    </div>

  </div>

</AdminLayout>
