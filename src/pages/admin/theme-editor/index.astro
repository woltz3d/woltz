---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';

const SUPABASE_URL = import.meta.env.SUPABASE_URL;
const SUPABASE_ANON_KEY = import.meta.env.SUPABASE_ANON_KEY;
---

<AdminLayout title="Theme Editor" activePage="theme-editor">
  
  <div id="app-config" data-supabase-url={SUPABASE_URL} data-supabase-key={SUPABASE_ANON_KEY} style="display:none;"></div>
  
  <style>
    .editor-container {
      display: grid;
      grid-template-columns: 300px 1fr 350px;
      height: calc(100vh - 80px);
      gap: 1px;
      background: rgba(255,255,255,0.1);
    }
    
    .sidebar-left, .sidebar-right {
      background: #111113;
      overflow-y: auto;
    }
    
    .preview-frame {
      background: #1a1a1e;
      position: relative;
    }
    
    .preview-frame iframe {
      width: 100%;
      height: 100%;
      border: none;
    }
    
    .section-item {
      padding: 1rem;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      cursor: pointer;
      transition: background 0.2s;
    }
    
    .section-item:hover, .section-item.active {
      background: rgba(255,255,255,0.05);
    }
    
    .section-item h3 {
      font-size: 0.9rem;
      margin-bottom: 0.25rem;
    }
    
    .section-item p {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.5);
    }
    
    .control-group {
      padding: 1.5rem;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    
    .control-group label {
      display: block;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.6);
      margin-bottom: 0.75rem;
    }
    
    .color-input-wrapper {
      display: flex;
      gap: 0.75rem;
      align-items: center;
    }
    
    input[type="color"] {
      width: 50px;
      height: 40px;
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 6px;
      cursor: pointer;
      background: none;
    }
    
    input[type="text"], input[type="number"], select, textarea {
      flex: 1;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 6px;
      padding: 0.5rem 0.75rem;
      color: white;
      font-size: 0.875rem;
    }
    
    input[type="text"]:focus, input[type="number"]:focus, select:focus, textarea:focus {
      outline: none;
      border-color: rgba(255,255,255,0.3);
    }
    
    .save-btn {
      position: fixed;
      top: 1rem;
      right: 1rem;
      background: white;
      color: black;
      padding: 0.75rem 2rem;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.875rem;
      z-index: 100;
      transition: transform 0.2s;
    }
    
    .save-btn:hover {
      transform: translateY(-2px);
    }
    
    .save-btn.saving {
      opacity: 0.7;
      cursor: not-allowed;
    }
  </style>

  <div class="editor-container">
    <!-- Sidebar Esquerda: Lista de Seções -->
    <div class="sidebar-left">
      <div class="p-6 border-b border-white/10">
        <h2 class="text-lg font-semibold">Page Structure</h2>
        <p class="text-xs text-white/50 mt-1">Select a section to edit</p>
      </div>
      
      <div id="sections-list">
        <div class="section-item active" data-section="colors">
          <h3>🎨 Colors</h3>
          <p>Global color palette</p>
        </div>
        <div class="section-item" data-section="typography">
          <h3>🔤 Typography</h3>
          <p>Fonts and text sizes</p>
        </div>
        <div class="section-item" data-section="layout">
          <h3>📐 Layout</h3>
          <p>Spacing and dimensions</p>
        </div>
        <div class="section-item" data-section="branding">
          <h3>🏷️ Branding</h3>
          <p>Logo and site identity</p>
        </div>
        <div class="section-item" data-section="footer">
          <h3>📄 Footer</h3>
          <p>Footer content and links</p>
        </div>
      </div>
    </div>
    
    <!-- Centro: Preview -->
    <div class="preview-frame">
      <iframe id="preview-frame" src="/" sandbox="allow-same-origin allow-scripts"></iframe>
    </div>
    
    <!-- Sidebar Direita: Editor -->
    <div class="sidebar-right" id="editor-panel">
      <div class="p-6 border-b border-white/10">
        <h2 class="text-lg font-semibold">Edit Section</h2>
        <p class="text-xs text-white/50 mt-1" id="section-description">Global color palette</p>
      </div>
      
      <div id="controls-container">
        <!-- Controles serão injetados via JS -->
      </div>
    </div>
  </div>

  <button id="save-btn" class="save-btn">Save Changes</button>

  <script type="module">
    import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';

    const configEl = document.getElementById('app-config');
    const supabase = createClient(configEl?.dataset.supabaseUrl, configEl?.dataset.supabaseKey);

    let currentSection = 'colors';
    let themeData: any = {};
    let hasChanges = false;

    // Carrega configurações atuais
    async function loadThemeSettings() {
      try {
        const { data, error } = await supabase
          .from('theme_settings')
          .select('*');
        
        if (error) throw error;
        
        data.forEach((row: any) => {
          themeData[row.key] = row.value;
        });
        
        renderControls();
      } catch (err) {
        console.error('Error loading theme:', err);
      }
    }

    // Renderiza controles baseados na seção atual
    function renderControls() {
      const container = document.getElementById('controls-container');
      if (!container) return;

      const controls: any = {
        colors: [
          { key: 'colors.primary', label: 'Primary Color', type: 'color' },
          { key: 'colors.secondary', label: 'Secondary Color', type: 'color' },
          { key: 'colors.background', label: 'Background Color', type: 'color' },
          { key: 'colors.background_alt', label: 'Alt Background', type: 'color' },
          { key: 'colors.text', label: 'Text Color', type: 'color' },
          { key: 'colors.text_muted', label: 'Muted Text', type: 'color' },
          { key: 'colors.accent', label: 'Accent Color', type: 'color' },
          { key: 'colors.success', label: 'Success Color', type: 'color' },
          { key: 'colors.error', label: 'Error Color', type: 'color' },
        ],
        
        typography: [
          { key: 'typography.font_heading', label: 'Heading Font', type: 'select', options: ['Anton', 'Playfair Display', 'Oswald', 'Bebas Neue'] },
          { key: 'typography.font_body', label: 'Body Font', type: 'select', options: ['Inter, sans-serif', 'Roboto, sans-serif', 'Open Sans, sans-serif'] },
          { key: 'typography.font_mono', label: 'Monospace Font', type: 'text' },
          { key: 'typography.size_h1', label: 'H1 Size', type: 'text', placeholder: 'clamp(3rem, 8vw, 6rem)' },
          { key: 'typography.size_h2', label: 'H2 Size', type: 'text', placeholder: 'clamp(2rem, 5vw, 4rem)' },
          { key: 'typography.weight_heading', label: 'Heading Weight', type: 'select', options: ['300', '400', '500', '600', '700'] },
          { key: 'typography.tracking_heading', label: 'Heading Tracking', type: 'text', placeholder: '-0.02em' },
        ],
        
        layout: [
          { key: 'layout.container_max_width', label: 'Max Width', type: 'text', placeholder: '1536px' },
          { key: 'layout.section_padding', label: 'Section Padding', type: 'text', placeholder: '3rem' },
          { key: 'layout.grid_gap', label: 'Grid Gap', type: 'text', placeholder: '1.5rem' },
          { key: 'layout.border_radius', label: 'Border Radius', type: 'text', placeholder: '0px' },
          { key: 'layout.hero_height', label: 'Hero Height', type: 'text', placeholder: '100vh' },
        ],
        
        branding: [
          { key: 'branding.site_name', label: 'Site Name', type: 'text' },
          { key: 'branding.tagline', label: 'Tagline', type: 'text' },
          { key: 'branding.logo_url', label: 'Logo URL', type: 'text' },
          { key: 'branding.favicon_url', label: 'Favicon URL', type: 'text' },
        ],
        
        footer: [
          { key: 'footer.text_left', label: 'Left Text', type: 'textarea', rows: 3 },
          { key: 'footer.text_center', label: 'Center Text', type: 'textarea', rows: 3 },
          { key: 'footer.lettering_text', label: 'Giant Lettering', type: 'text' },
          { key: 'footer.show_social', label: 'Show Social Icons', type: 'checkbox' },
          { key: 'footer.social_instagram', label: 'Instagram URL', type: 'text' },
          { key: 'footer.social_twitter', label: 'Twitter URL', type: 'text' },
          { key: 'footer.social_youtube', label: 'YouTube URL', type: 'text' },
        ],
      };

      const sectionControls = controls[currentSection] || [];
      const descriptions: any = {
        colors: 'Global color palette',
        typography: 'Fonts and text sizes',
        layout: 'Spacing and dimensions',
        branding: 'Logo and site identity',
        footer: 'Footer content and links',
      };

      document.getElementById('section-description')!.textContent = descriptions[currentSection];

      container.innerHTML = sectionControls.map((control: any) => {
        const value = themeData[control.key]?.value || '';
        
        if (control.type === 'color') {
          return `
            <div class="control-group">
              <label>${control.label}</label>
              <div class="color-input-wrapper">
                <input type="color" 
                       data-key="${control.key}" 
                       value="${value}" 
                       class="color-picker" />
                <input type="text" 
                       data-key="${control.key}" 
                       value="${value}" 
                       class="color-text" />
              </div>
            </div>
          `;
        } else if (control.type === 'select') {
          return `
            <div class="control-group">
              <label>${control.label}</label>
              <select data-key="${control.key}">
                ${control.options.map((opt: string) => `
                  <option value="${opt}" ${value === opt ? 'selected' : ''}>${opt}</option>
                `).join('')}
              </select>
            </div>
          `;
        } else if (control.type === 'checkbox') {
          return `
            <div class="control-group">
              <label>${control.label}</label>
              <input type="checkbox" 
                     data-key="${control.key}" 
                     ${value ? 'checked' : ''} 
                     class="mt-2" />
            </div>
          `;
        } else if (control.type === 'textarea') {
          return `
            <div class="control-group">
              <label>${control.label}</label>
              <textarea data-key="${control.key}" 
                        rows="${control.rows || 3}"
                        class="w-full">${value}</textarea>
            </div>
          `;
        } else {
          return `
            <div class="control-group">
              <label>${control.label}</label>
              <input type="${control.type}" 
                     data-key="${control.key}" 
                     value="${value}"
                     placeholder="${control.placeholder || ''}"
                     class="w-full" />
            </div>
          `;
        }
      }).join('');

      // Adiciona event listeners
      container.querySelectorAll('input, select, textarea').forEach((input: any) => {
        input.addEventListener('change', (e: any) => {
          const key = e.target.dataset.key;
          const value = e.target.type === 'checkbox' ? e.target.checked : e.target.value;
          
          if (!themeData[key]) {
            themeData[key] = {};
          }
          themeData[key].value = value;
          hasChanges = true;
          
          // Atualiza preview se for cor
          if (e.target.classList.contains('color-picker')) {
            const textInput = input.parentElement?.querySelector('.color-text');
            if (textInput) textInput.value = value;
          }
          if (e.target.classList.contains('color-text')) {
            const colorInput = input.parentElement?.querySelector('.color-picker');
            if (colorInput) colorInput.value = value;
          }
        });
      });
    }

    // Salva alterações
    document.getElementById('save-btn')?.addEventListener('click', async () => {
      if (!hasChanges) return;
      
      const btn = document.getElementById('save-btn');
      if (!btn) return;
      
      btn.classList.add('saving');
      btn.textContent = 'Saving...';
      
      try {
        const updates: any = {};
        Object.entries(themeData).forEach(([key, value]: any) => {
          updates[key] = value;
        });
        
        const { error } = await supabase
          .from('theme_settings')
          .upsert(
            Object.entries(updates).map(([key, value]: any) => ({
              key,
              value,
              category: key.split('.')[0],
              updated_at: new Date().toISOString(),
            })),
            { onConflict: 'key' }
          );
        
        if (error) throw error;
        
        hasChanges = false;
        btn.textContent = 'Saved!';
        setTimeout(() => {
          btn.textContent = 'Save Changes';
          btn.classList.remove('saving');
        }, 2000);
        
        // Atualiza preview
        const iframe = document.getElementById('preview-frame') as HTMLIFrameElement;
        if (iframe) {
          iframe.src = iframe.src;
        }
        
      } catch (err: any) {
        console.error('Error saving:', err);
        alert('Error saving: ' + err.message);
        btn.classList.remove('saving');
        btn.textContent = 'Save Changes';
      }
    });

    // Seleção de seções
    document.querySelectorAll('.section-item').forEach(item => {
      item.addEventListener('click', () => {
        document.querySelectorAll('.section-item').forEach(i => i.classList.remove('active'));
        item.classList.add('active');
        currentSection = item.dataset.section!;
        renderControls();
      });
    });

    // Inicializa
    loadThemeSettings();
  </script>
</AdminLayout>
