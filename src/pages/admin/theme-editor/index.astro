---
import AdminLayout from '../../../layouts/AdminLayout.astro';
const SUPABASE_URL = import.meta.env.SUPABASE_URL;
const SUPABASE_ANON_KEY = import.meta.env.SUPABASE_ANON_KEY;
---
<AdminLayout title="Theme Editor" activePage="theme-editor">
<div id="app-config" data-supabase-url={SUPABASE_URL} data-supabase-key={SUPABASE_ANON_KEY} style="display:none;"></div>
<style is:global>
/* ... (Mantenha todo o seu CSS original aqui, ele está ótimo) ... */
.theme-editor-wrapper { display: grid; grid-template-columns: 200px 1fr; height: calc(100vh - 73px); background: #0a0a0c; overflow: hidden; }
.te-sidebar-left { background: #111113; border-right: 1px solid rgba(255, 255, 255, 0.06); display: flex; flex-direction: column; }
.te-sections-list { flex: 1; overflow-y: auto; padding: 0.5rem; }
.te-section-item { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem; border-radius: 6px; cursor: pointer; transition: all 0.2s; margin-bottom: 2px; color: rgba(255,255,255,0.6); }
.te-section-item:hover { background: rgba(255, 255, 255, 0.04); color: #fff; }
.te-section-item.active { background: rgba(255, 255, 255, 0.08); color: #fff; }
.te-preview { background: #1a1a1e; position: relative; display: flex; flex-direction: column; }
.te-preview-container { flex: 1; position: relative; background: #fff; }
.te-preview-frame { width: 100%; height: 100%; border: none; }
.te-editor-panel { position: absolute; top: 0; right: 0; width: 320px; height: 100%; background: #111113; border-left: 1px solid rgba(255, 255, 255, 0.06); transform: translateX(100%); transition: transform 0.3s ease; z-index: 100; display: flex; flex-direction: column; }
.te-editor-panel.open { transform: translateX(0); }
.te-controls { flex: 1; overflow-y: auto; padding: 1rem; }
.te-control-group { margin-bottom: 1rem; }
.te-control-label { display: block; font-size: 0.7rem; text-transform: uppercase; color: rgba(255,255,255,0.5); margin-bottom: 0.5rem; }
.te-color-row { display: flex; gap: 0.5rem; align-items: center; }
.te-text-input, .te-select-input { width: 100%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; padding: 0.5rem; border-radius: 4px; }
.te-save-btn { background: #fff; color: #000; border: none; padding: 0.5rem 1rem; border-radius: 4px; cursor: pointer; font-weight: bold; }
</style>

<div class="theme-editor-wrapper">
  <div class="te-sidebar-left">
    <div class="te-sections-list" id="sections-list">
      <!-- Sidebar Items -->
      <div class="te-section-item active" data-section="header"><span>Header</span></div>
      <div class="te-section-item" data-section="hero"><span>Hero Section</span></div>
      <div class="te-section-item" data-section="collection"><span>New Collection</span></div>
      <div class="te-section-item" data-section="footer"><span>Footer</span></div>
      <div class="te-section-item" data-section="global"><span>Global</span></div>
    </div>
  </div>
  
  <div class="te-preview">
    <div class="te-preview-container">
      <iframe id="preview-frame" class="te-preview-frame" src="/" sandbox="allow-same-origin allow-scripts"></iframe>
      <button id="open-editor-btn" style="position:absolute; top:10px; right:10px; z-index:50;">Edit</button>
      
      <div class="te-editor-panel" id="editor-panel">
        <div style="padding:1rem; border-bottom:1px solid rgba(255,255,255,0.1); display:flex; justify-content:space-between;">
          <h3>Edit Settings</h3>
          <div style="display:flex; gap:0.5rem;">
            <button id="reset-btn" style="background:#ef4444; color:#fff; border:none; padding:0.25rem 0.5rem; border-radius:4px;">Reset</button>
            <button id="save-btn" class="te-save-btn">Save</button>
            <button id="close-panel-btn" style="background:transparent; border:none; color:#fff; cursor:pointer;"></button>
          </div>
        </div>
        <div class="te-controls" id="controls-container"></div>
      </div>
    </div>
  </div>
</div>

<script type="module">
import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';
const configEl = document.getElementById('app-config');
const supabase = createClient(configEl.dataset.supabaseUrl, configEl.dataset.supabaseKey);

// Configuração dos controles
const sectionControls = {
  header: [
    { key: 'header.bg_color', label: 'Background Color', type: 'color' },
    { key: 'header.text_color', label: 'Text Color', type: 'color' },
  ],
  hero: [
    { key: 'hero.title_color', label: 'Title Color', type: 'color' },
    { key: 'hero.subtitle_color', label: 'Subtitle Color', type: 'color' },
  ],
  collection: [
    { key: 'collection.bg_color', label: 'Section Background', type: 'color' },
    { key: 'collection.card_bg', label: 'Card Background', type: 'color' },
  ],
  footer: [
    { key: 'footer.bg_color', label: 'Footer Background', type: 'color' },
    { key: 'footer.text_color', label: 'Footer Text', type: 'color' },
  ],
  global: [
    { key: 'global.cursor_color', label: 'Cursor Color', type: 'color' },
  ]
};

let currentSection = 'header';
let themeData = {};
let hasChanges = false;

async function loadThemeSettings() {
  const { data } = await supabase.from('theme_settings').select('*');
  if (data) {
    // Armazena como string direta: themeData['key'] = 'valor'
    data.forEach(row => { themeData[row.key] = row.value; });
    renderControls();
  }
}

function renderControls() {
  const container = document.getElementById('controls-container');
  const controls = sectionControls[currentSection] || [];
  
  container.innerHTML = controls.map(c => {
    const val = themeData[c.key] || (c.type === 'color' ? '#ffffff' : '');
    if (c.type === 'color') {
      return `
        <div class="te-control-group">
          <label class="te-control-label">${c.label}</label>
          <div class="te-color-row">
            <input type="color" name="${c.key}" id="${c.key}-color" data-key="${c.key}" value="${val}" />
            <input type="text" name="${c.key}" id="${c.key}-text" data-key="${c.key}" value="${val}" class="te-text-input" />
          </div>
        </div>`;
    }
    return `<div class="te-control-group"><label class="te-control-label">${c.label}</label><input type="text" name="${c.key}" id="${c.key}" data-key="${c.key}" value="${val}" class="te-text-input" /></div>`;
  }).join('');

  // Event Listeners
  container.querySelectorAll('input').forEach(input => {
    input.addEventListener('input', (e) => {
      const key = e.target.dataset.key;
      themeData[key] = e.target.value;
      hasChanges = true;
      
      // Sync color/text inputs
      if (e.target.type === 'color') {
        container.querySelector(`#${key}-text`).value = e.target.value;
      } else if (e.target.type === 'text' && container.querySelector(`#${key}-color`)) {
        container.querySelector(`#${key}-color`).value = e.target.value;
      }
      
      // Refresh Preview
      const iframe = document.getElementById('preview-frame');
      if(iframe) iframe.src = iframe.src.split('?')[0] + '?t=' + Date.now();
    });
  });
}

async function saveChanges() {
  if (!hasChanges) return;
  const btn = document.getElementById('save-btn');
  btn.textContent = 'Saving...';
  
  const updates = Object.entries(themeData).map(([k, v]) => ({ key: k, value: String(v), category: k.split('.')[0] }));
  await supabase.from('theme_settings').upsert(updates, { onConflict: 'key' });
  
  btn.textContent = 'Save';
  hasChanges = false;
  alert('Saved! Reloading site...');
  window.location.reload();
}

// UI Logic
document.querySelectorAll('.te-section-item').forEach(item => {
  item.addEventListener('click', () => {
    document.querySelectorAll('.te-section-item').forEach(i => i.classList.remove('active'));
    item.classList.add('active');
    currentSection = item.dataset.section;
    renderControls();
    document.getElementById('editor-panel').classList.add('open');
  });
});

document.getElementById('open-editor-btn').onclick = () => document.getElementById('editor-panel').classList.add('open');
document.getElementById('close-panel-btn').onclick = () => document.getElementById('editor-panel').classList.remove('open');
document.getElementById('save-btn').onclick = saveChanges;
document.getElementById('reset-btn').onclick = async () => {
  if(confirm('Reset all?')) {
    await supabase.from('theme_settings').delete().neq('id', '00000000-0000-0000-0000-000000000000');
    window.location.reload();
  }
};

loadThemeSettings();
</script>
</AdminLayout>
